@inherits LayoutComponentBase

@inject ILayoutService LayoutService

@implements IAsyncDisposable

<AuthorizeView>
    <Authorized>
        <!-- Premium Authenticated Layout -->
        <div class="min-h-screen bg-gray-100 dark:bg-[#0f0e1a] transition-colors duration-200">
            <!-- Sidebar -->
            <aside class="@(_sidebarCollapsed ? "sidebar-collapsed" : "sidebar-expanded") fixed inset-y-0 left-0 z-50 transform transition-all duration-300 ease-in-out @(_mobileSidebarOpen ? "" : "-translate-x-full") md:translate-x-0 sidebar-bg"
                   id="sidebar">
                <NavMenu />
            </aside>

            <!-- Main Content Area -->
            <div id="main-content" class="@(_sidebarCollapsed ? "sidebar-collapsed-margin" : "sidebar-expanded-margin") min-h-screen flex flex-col transition-all duration-300">
                <!-- Top Header Bar -->
                <header class="sticky top-0 z-40 bg-white/80 dark:bg-[#0f0e1a]/90 backdrop-blur-md transition-colors">
                    <div class="flex items-center justify-between h-16 px-6 lg:px-8 border-b border-gray-100 dark:border-indigo-900/30">
                        <!-- Menu Buttons -->
                        <div class="flex items-center gap-2">
                            <!-- Mobile Menu Button -->
                            <button type="button"
                                    class="md:hidden p-2 -ml-2 rounded-xl text-gray-500 dark:text-slate-400 hover:text-gray-700 dark:hover:text-slate-200 hover:bg-gray-100 dark:hover:bg-slate-800 transition-colors"
                                    @onclick="ToggleMobileSidebar">
                                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                                </svg>
                            </button>
                            <!-- Desktop Collapse Toggle -->
                            <button type="button"
                                    class="hidden md:flex p-2 -ml-2 rounded-xl text-gray-400 dark:text-slate-500 hover:text-gray-600 dark:hover:text-slate-300 hover:bg-gray-100 dark:hover:bg-slate-800 transition-colors"
                                    @onclick="ToggleSidebarCollapse"
                                    title="Toggle sidebar">
                                <svg class="h-5 w-5 transition-transform duration-300 @(_sidebarCollapsed ? "rotate-180" : "")" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7" />
                                </svg>
                            </button>
                        </div>

                        <!-- Spacer -->
                        <div class="flex-1"></div>

                        <!-- Right Side Actions -->
                        <div class="flex items-center gap-4">
                            <!-- Quick Actions -->
                            <div class="hidden sm:flex items-center gap-2">
                                <a href="clients/new" class="p-2 rounded-xl text-gray-400 dark:text-slate-500 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-indigo-50 dark:hover:bg-indigo-900/50 transition-colors" title="New Client">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
                                    </svg>
                                </a>
                                <a href="invoices/new" class="p-2 rounded-xl text-gray-400 dark:text-slate-500 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-indigo-50 dark:hover:bg-indigo-900/50 transition-colors" title="New Invoice">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                    </svg>
                                </a>
                            </div>

                            <!-- Dark Mode Toggle -->
                            <button type="button"
                                    class="p-2 rounded-xl text-gray-400 dark:text-slate-400 hover:text-gray-600 dark:hover:text-slate-200 hover:bg-gray-100 dark:hover:bg-slate-800 transition-colors"
                                    @onclick="ToggleDarkMode"
                                    title="Toggle dark mode">
                                @if (_isDarkMode)
                                {
                                    <!-- Sun icon (shown in dark mode) -->
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
                                    </svg>
                                }
                                else
                                {
                                    <!-- Moon icon (shown in light mode) -->
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
                                    </svg>
                                }
                            </button>

                            <!-- Divider -->
                            <div class="hidden sm:block h-6 w-px bg-gray-200 dark:bg-slate-700"></div>

                            <!-- User Menu -->
                            @if (_userMenuOpen)
                            {
                                <div class="fixed inset-0 z-40" @onclick="CloseUserMenu"></div>
                            }
                            <div class="relative">
                                <button type="button"
                                        class="flex items-center gap-3 p-1 -m-1 rounded-xl hover:bg-gray-100 dark:hover:bg-slate-800 transition-colors"
                                        @onclick="ToggleUserMenu"
                                        @onclick:stopPropagation="true">
                                    <div class="w-9 h-9 rounded-full flex items-center justify-center text-white text-sm font-semibold"
                                         style="background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%); box-shadow: 0 2px 8px rgba(99, 102, 241, 0.3);">
                                        @context.User.Identity?.Name?[0].ToString().ToUpper()
                                    </div>
                                    <div class="hidden lg:flex items-center gap-2">
                                        <span class="text-sm font-medium text-gray-900 dark:text-slate-100">@context.User.Identity?.Name</span>
                                        <svg class="w-4 h-4 text-gray-400 dark:text-slate-500 transition-transform duration-200 @(_userMenuOpen ? "rotate-180" : "")" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                        </svg>
                                    </div>
                                </button>

                                <!-- Dropdown Menu -->
                                @if (_userMenuOpen)
                                {
                                    <div class="absolute right-0 mt-2 w-56 bg-white dark:bg-[#1a1827] rounded-xl shadow-lg ring-1 ring-black/5 dark:ring-white/10 py-1 z-50">
                                        <a href="/"
                                           class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 dark:text-slate-300 hover:bg-gray-50 dark:hover:bg-[#2d2a4a] transition-colors"
                                           @onclick="CloseUserMenu">
                                            <svg class="w-5 h-5 text-gray-400 dark:text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z" />
                                            </svg>
                                            Dashboard
                                        </a>
                                        <a href="account/manage"
                                           class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 dark:text-slate-300 hover:bg-gray-50 dark:hover:bg-[#2d2a4a] transition-colors"
                                           @onclick="CloseUserMenu">
                                            <svg class="w-5 h-5 text-gray-400 dark:text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                            </svg>
                                            Settings
                                        </a>
                                        <div class="border-t border-gray-100 dark:border-[#2d2a4a] my-1"></div>
                                        <button type="button"
                                                class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 dark:text-slate-300 hover:bg-gray-50 dark:hover:bg-[#2d2a4a] transition-colors w-full text-left"
                                                @onclick="ShowSignOutConfirmation">
                                            <svg class="w-5 h-5 text-gray-400 dark:text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                                            </svg>
                                            Sign Out
                                        </button>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </header>

                <!-- Page Content -->
                <main class="flex-1 p-6 lg:p-8">
                    @Body
                </main>

                <!-- Footer -->
                <footer class="py-4 px-6 lg:px-8 border-t border-gray-100 dark:border-[#2d2a4a] bg-white/50 dark:bg-[#0f0e1a]/50 transition-colors">
                    <p class="text-xs text-gray-400 dark:text-[#64748b] text-center">Invoice Software &copy; @DateTime.Now.Year</p>
                </footer>
            </div>
        </div>

        <!-- Mobile Overlay -->
        @if (_mobileSidebarOpen)
        {
            <div class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm z-40 md:hidden"
                 @onclick="ToggleMobileSidebar">
            </div>
        }

        <style>
            .sidebar-bg {
                background: linear-gradient(180deg, #1e1b4b 0%, #312e81 50%, #3730a3 100%);
            }
            :root.dark .sidebar-bg {
                background: #1a1827;
                border-right: 1px solid #2d2a4a;
            }
            .sidebar-expanded { width: 18rem; }
            .sidebar-collapsed { width: 5rem; }
            .sidebar-expanded-margin { margin-left: 0; }
            @@media (min-width: 768px) {
                .sidebar-expanded-margin { margin-left: 18rem; }
                .sidebar-collapsed-margin { margin-left: 5rem; }
            }
            .sidebar-collapsed .nav-text { display: none; }
            .sidebar-collapsed .nav-section-title { display: none; }
            .sidebar-collapsed .user-section-expanded { display: none; }
            .sidebar-collapsed .user-section-collapsed { display: flex; }
            .sidebar-collapsed .nav-link { justify-content: center; padding-left: 0; padding-right: 0; }
            .sidebar-collapsed .logo-text { display: none; }
            .sidebar-collapsed .logo-section { justify-content: center; }
        </style>
    </Authorized>
    <NotAuthorized>
        <!-- Clean Unauthenticated Layout -->
        <div class="min-h-screen flex flex-col bg-gray-50">
            <!-- Header -->
            <header class="py-6 px-4 border-b border-gray-100 bg-white">
                <div class="max-w-7xl mx-auto flex justify-between items-center">
                    <a href="/" class="flex items-center gap-3">
                        <div class="w-9 h-9 rounded-xl flex items-center justify-center"
                             style="background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%); box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);">
                            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                            </svg>
                        </div>
                        <span class="text-lg font-bold text-gray-900" style="font-family: 'Plus Jakarta Sans', sans-serif;">
                            Invoice<span class="text-indigo-600">Pro</span>
                        </span>
                    </a>
                </div>
            </header>

            <!-- Main Content -->
            <main class="flex-1 flex items-center justify-center p-6">
                @Body
            </main>

            <!-- Footer -->
            <footer class="py-6 px-4 border-t border-gray-100 bg-white">
                <p class="text-center text-gray-400 text-sm">&copy; @DateTime.Now.Year InvoicePro. All rights reserved.</p>
            </footer>
        </div>
    </NotAuthorized>
</AuthorizeView>

<!-- Modal Host -->
<ModalHost />

<div id="blazor-error-ui" data-nosnippet class="fixed bottom-0 left-0 right-0 bg-red-600 text-white p-4 hidden z-50">
    <div class="max-w-7xl mx-auto flex items-center justify-between">
        <span>An unhandled error has occurred.</span>
        <div class="flex items-center gap-4">
            <a href="." class="underline hover:no-underline">Reload</a>
            <span class="dismiss cursor-pointer hover:opacity-80">Dismiss</span>
        </div>
    </div>
</div>

@code {
    private bool _isDarkMode;
    private bool _sidebarCollapsed;
    private bool _mobileSidebarOpen;
    private bool _userMenuOpen;
    private bool _initialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialized)
        {
            _initialized = true;
            try
            {
                _isDarkMode = await LayoutService.GetDarkModeAsync();
                _sidebarCollapsed = await LayoutService.GetSidebarCollapsedAsync();
                StateHasChanged();
            }
            catch
            {
                // JS interop not available during prerendering
            }
        }
    }

    private async Task ToggleMobileSidebar()
    {
        _mobileSidebarOpen = !_mobileSidebarOpen;
        await LayoutService.ToggleMobileSidebarAsync();
    }

    private async Task ToggleSidebarCollapse()
    {
        _sidebarCollapsed = await LayoutService.ToggleSidebarCollapseAsync();
    }

    private async Task ToggleDarkMode()
    {
        _isDarkMode = await LayoutService.ToggleDarkModeAsync();
    }

    private void ToggleUserMenu()
    {
        _userMenuOpen = !_userMenuOpen;
    }

    private void CloseUserMenu()
    {
        _userMenuOpen = false;
    }

    private async Task ShowSignOutConfirmation()
    {
        _userMenuOpen = false;

        var confirmed = await ModalService.ShowAsync<bool>(
            typeof(SignOutConfirmationModal),
            "Sign Out");

        if (confirmed)
        {
            NavigationManager.NavigateTo("account/logout", forceLoad: true);
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (LayoutService is IAsyncDisposable disposable)
        {
            await disposable.DisposeAsync();
        }
    }
}
