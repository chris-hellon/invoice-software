            <svg class="w-5 h-5 opacity-70 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            <span class="nav-text flex-1 text-left">Account</span>
            <svg class="w-4 h-4 opacity-60 shrink-0 nav-text transition-transform @(_accountExpanded ? "rotate-90" : "")" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
        </button>

        @if (_accountExpanded)
        {
            <NavLink href="account/manage" Match="NavLinkMatch.All"
                     class="nav-link group relative flex items-center gap-3 pl-12 pr-4 py-2 text-sm font-medium rounded-xl text-indigo-200/80 dark:text-[#a5b4fc] hover:bg-white/8 dark:hover:bg-[#2d2a4a] hover:text-white dark:hover:text-[#e0e7ff] transition-all duration-200"
                     ActiveClass="!bg-gradient-to-r !from-indigo-500/20 !to-purple-500/10 dark:!from-indigo-600/30 dark:!to-indigo-500/20 !text-white dark:!text-[#e0e7ff]">
                <span class="nav-text">Profile</span>
            </NavLink>
            <NavLink href="account/manage/email"
                     class="nav-link group relative flex items-center gap-3 pl-12 pr-4 py-2 text-sm font-medium rounded-xl text-indigo-200/80 dark:text-[#a5b4fc] hover:bg-white/8 dark:hover:bg-[#2d2a4a] hover:text-white dark:hover:text-[#e0e7ff] transition-all duration-200"
                     ActiveClass="!bg-gradient-to-r !from-indigo-500/20 !to-purple-500/10 dark:!from-indigo-600/30 dark:!to-indigo-500/20 !text-white dark:!text-[#e0e7ff]">
                <span class="nav-text">Email</span>
            </NavLink>
            <NavLink href="account/manage/change-password"
                     class="nav-link group relative flex items-center gap-3 pl-12 pr-4 py-2 text-sm font-medium rounded-xl text-indigo-200/80 dark:text-[#a5b4fc] hover:bg-white/8 dark:hover:bg-[#2d2a4a] hover:text-white dark:hover:text-[#e0e7ff] transition-all duration-200"
                     ActiveClass="!bg-gradient-to-r !from-indigo-500/20 !to-purple-500/10 dark:!from-indigo-600/30 dark:!to-indigo-500/20 !text-white dark:!text-[#e0e7ff]">
                <span class="nav-text">Password</span>
            </NavLink>
            <NavLink href="account/manage/two-factor-authentication"
                     class="nav-link group relative flex items-center gap-3 pl-12 pr-4 py-2 text-sm font-medium rounded-xl text-indigo-200/80 dark:text-[#a5b4fc] hover:bg-white/8 dark:hover:bg-[#2d2a4a] hover:text-white dark:hover:text-[#e0e7ff] transition-all duration-200"
                     ActiveClass="!bg-gradient-to-r !from-indigo-500/20 !to-purple-500/10 dark:!from-indigo-600/30 dark:!to-indigo-500/20 !text-white dark:!text-[#e0e7ff]">
                <span class="nav-text">Two-Factor Auth</span>
            </NavLink>
        }
    </nav>

    <!-- Sign Out Section -->
    <div class="px-3 pb-6 border-t border-white/10 dark:border-[#2d2a4a] pt-4">
        <AuthorizeView>
            <Authorized>
                <!-- Expanded sign out button -->
                <button @onclick="ShowSignOutConfirmation"
                        class="user-section-expanded nav-link group relative flex items-center gap-3 px-4 py-2.5 text-sm font-medium rounded-xl text-indigo-200/80 dark:text-[#a5b4fc] hover:bg-white/8 dark:hover:bg-[#2d2a4a] hover:text-white dark:hover:text-[#e0e7ff] transition-all duration-200 w-full">
                    <svg class="w-5 h-5 opacity-70 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                    </svg>
                    <span class="nav-text">Sign Out</span>
                </button>
                <!-- Collapsed sign out button -->
                <button @onclick="ShowSignOutConfirmation"
                        class="user-section-collapsed hidden nav-link group relative flex items-center justify-center px-4 py-2.5 text-sm font-medium rounded-xl text-indigo-200/80 dark:text-[#a5b4fc] hover:bg-white/8 dark:hover:bg-[#2d2a4a] hover:text-white dark:hover:text-[#e0e7ff] transition-all duration-200 w-full"
                        title="Sign Out">
                    <svg class="w-5 h-5 opacity-70 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                    </svg>
                </button>
            </Authorized>
            <NotAuthorized>
                <NavLink href="account/login"
                         class="user-section-expanded nav-link group relative flex items-center gap-3 px-4 py-2.5 text-sm font-medium rounded-xl text-indigo-200/80 dark:text-[#a5b4fc] hover:bg-white/8 dark:hover:bg-[#2d2a4a] hover:text-white dark:hover:text-[#e0e7ff] transition-all duration-200 w-full">
                    <svg class="w-5 h-5 opacity-70 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" />
                    </svg>
                    <span class="nav-text">Sign In</span>
                </NavLink>
                <NavLink href="account/login"
                         class="user-section-collapsed hidden nav-link group relative flex items-center justify-center px-4 py-2.5 text-sm font-medium rounded-xl text-indigo-200/80 dark:text-[#a5b4fc] hover:bg-white/8 dark:hover:bg-[#2d2a4a] hover:text-white dark:hover:text-[#e0e7ff] transition-all duration-200 w-full"
                         title="Sign In">
                    <svg class="w-5 h-5 opacity-70 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" />
                    </svg>
                </NavLink>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</div>


@code {
    private string? _currentUrl;
    private bool _expensesExpanded;
    private bool _invoicesExpanded;
    private bool _accountExpanded;

    protected override void OnInitialized()
    {
        _currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;

        // Set initial expanded state based on current URL
        _expensesExpanded = _currentUrl != null &&
            (_currentUrl.StartsWith("expenses", StringComparison.OrdinalIgnoreCase) ||
             _currentUrl.StartsWith("recurring-expenses", StringComparison.OrdinalIgnoreCase));

        _invoicesExpanded = _currentUrl != null &&
            (_currentUrl.StartsWith("invoices", StringComparison.OrdinalIgnoreCase) ||
             _currentUrl.StartsWith("recurring-invoices", StringComparison.OrdinalIgnoreCase));

        _accountExpanded = _currentUrl != null &&
            _currentUrl.StartsWith("account/manage", StringComparison.OrdinalIgnoreCase);
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _currentUrl = NavigationManager.ToBaseRelativePath(e.Location);

        // Auto-expand/collapse expenses based on current URL
        var isOnExpensesPage = _currentUrl != null &&
            (_currentUrl.StartsWith("expenses", StringComparison.OrdinalIgnoreCase) ||
             _currentUrl.StartsWith("recurring-expenses", StringComparison.OrdinalIgnoreCase));
        _expensesExpanded = isOnExpensesPage;

        // Auto-expand/collapse invoices based on current URL
        var isOnInvoicesPage = _currentUrl != null &&
            (_currentUrl.StartsWith("invoices", StringComparison.OrdinalIgnoreCase) ||
             _currentUrl.StartsWith("recurring-invoices", StringComparison.OrdinalIgnoreCase));
        _invoicesExpanded = isOnInvoicesPage;

        // Auto-expand/collapse account based on current URL
        var isOnAccountPage = _currentUrl != null &&
            _currentUrl.StartsWith("account/manage", StringComparison.OrdinalIgnoreCase);
        _accountExpanded = isOnAccountPage;

        StateHasChanged();
    }

    private void ToggleExpenses()
    {
        _expensesExpanded = !_expensesExpanded;
    }

    private void ToggleInvoices()
    {
        _invoicesExpanded = !_invoicesExpanded;
    }

    private void ToggleAccount()
    {
        _accountExpanded = !_accountExpanded;
    }

    private async Task ShowSignOutConfirmation()
    {
        var confirmed = await ModalService.ShowAsync<bool>(
            typeof(SignOutConfirmationModal),
            "Sign Out",
            new Dictionary<string, object>
            {
                { "ReturnUrl", _currentUrl ?? "" }
            });

        if (confirmed)
        {
            NavigationManager.NavigateTo("account/logout", forceLoad: true);
        }
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
