<div class="space-y-6">
    <!-- Icon -->
    <div class="flex justify-center">
        <div class="w-16 h-16 rounded-full flex items-center justify-center"
             style="background: linear-gradient(135deg, #eef2ff 0%, #e0e7ff 100%);">
            <svg class="w-8 h-8 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
        </div>
    </div>

    <!-- Message -->
    <div class="text-center">
        <p class="text-gray-900 dark:text-slate-100">
            Are you sure you want to sign out?
        </p>
        <p class="mt-2 text-sm text-gray-500 dark:text-slate-400">
            You will need to sign in again to access your account.
        </p>
    </div>

    <!-- Actions -->
    <div class="flex justify-center gap-3 pt-2">
        <button @onclick="Cancel"
                class="px-5 py-2.5 text-sm font-medium text-gray-700 dark:text-slate-300 bg-white dark:bg-slate-700 border border-gray-200 dark:border-slate-600 rounded-xl hover:bg-gray-50 dark:hover:bg-slate-600 transition-colors">
            Cancel
        </button>
        <button @onclick="Confirm"
                class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium text-white rounded-xl transition-all duration-200 hover:shadow-lg"
                style="background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); box-shadow: 0 4px 14px rgba(99, 102, 241, 0.35);">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
            Sign Out
        </button>
    </div>
</div>

@code {
    [Parameter] public string? ReturnUrl { get; set; }

    private void Cancel()
    {
        ModalService.Close(false);
    }

    private void Confirm()
    {
        ModalService.Close(true);
    }
}
