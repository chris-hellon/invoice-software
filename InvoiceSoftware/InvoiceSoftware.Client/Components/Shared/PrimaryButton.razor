@* Primary button component with gradient styling *@

@if (!string.IsNullOrEmpty(Href))
{
    <a href="@Href" class="inline-flex items-center justify-center gap-2 px-5 py-2.5 text-sm font-medium text-white rounded-xl shadow-md transition-all duration-200 hover:shadow-lg active:scale-[0.98]"
       style="background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); box-shadow: 0 4px 14px rgba(99, 102, 241, 0.35);">
        @if (ShowIcon && IconType == ButtonIcon.Plus)
        {
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
            </svg>
        }
        else if (ShowIcon && IconType == ButtonIcon.Check)
        {
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
        }
        @Text
    </a>
}
else
{
    <button type="@ButtonType" disabled="@IsLoading"
            @onclick="OnClick"
            class="inline-flex items-center justify-center gap-2 px-5 py-2.5 text-sm font-medium text-white rounded-xl shadow-md transition-all duration-200 hover:shadow-lg active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:shadow-md disabled:active:scale-100"
            style="background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); box-shadow: 0 4px 14px rgba(99, 102, 241, 0.35);">
        @if (IsLoading)
        {
            <div class="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>
        }
        else if (ShowIcon && IconType == ButtonIcon.Plus)
        {
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
            </svg>
        }
        else if (ShowIcon && IconType == ButtonIcon.Check)
        {
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
        }
        @(IsLoading && !string.IsNullOrEmpty(LoadingText) ? LoadingText : Text)
    </button>
}

@code {
    [Parameter, EditorRequired]
    public string Text { get; set; } = "";

    [Parameter]
    public string? Href { get; set; }

    [Parameter]
    public string ButtonType { get; set; } = "button";

    [Parameter]
    public bool ShowIcon { get; set; } = true;

    [Parameter]
    public ButtonIcon IconType { get; set; } = ButtonIcon.Plus;

    [Parameter]
    public bool IsLoading { get; set; }

    [Parameter]
    public string? LoadingText { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    public enum ButtonIcon
    {
        Plus,
        Check
    }
}
