@* Shared card component for entity listings (clients, projects, etc.) *@

<a href="@Href" class="group block bg-white dark:bg-slate-800 rounded-2xl border border-gray-100 dark:border-slate-700 overflow-hidden transition-all duration-200 hover:border-indigo-100 dark:hover:border-indigo-900 hover:shadow-lg hover:shadow-indigo-500/5 dark:hover:shadow-indigo-500/10">
    <div class="p-6">
        <div class="flex items-start justify-between mb-4">
            <div class="flex items-center gap-4 min-w-0 flex-1">
                @if (ShowAvatar)
                {
                    <div class="w-12 h-12 rounded-full flex items-center justify-center text-white text-lg font-semibold shrink-0"
                         style="background: linear-gradient(135deg, @AvatarGradientStart 0%, @AvatarGradientEnd 100%); box-shadow: 0 4px 12px @AvatarShadow;">
                        @AvatarText?.ToUpper()
                    </div>
                }
                <div class="min-w-0">
                    <h3 class="text-base font-semibold text-gray-900 dark:text-slate-100 truncate group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">@Title</h3>
                    @if (!string.IsNullOrEmpty(Subtitle))
                    {
                        <p class="text-sm text-gray-500 dark:text-slate-400 truncate">@Subtitle</p>
                    }
                </div>
            </div>
            @if (BadgeTemplate != null)
            {
                @BadgeTemplate
            }
        </div>

        @if (DetailsTemplate != null)
        {
            <div class="mb-4">
                @DetailsTemplate
            </div>
        }

        @if (FooterTemplate != null || ActionsTemplate != null)
        {
            <div class="flex items-center justify-between pt-4 border-t border-gray-100 dark:border-slate-700">
                @if (FooterTemplate != null)
                {
                    @FooterTemplate
                }
                else
                {
                    <div></div>
                }
                <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity" @onclick:stopPropagation="true">
                    @if (ActionsTemplate != null)
                    {
                        @ActionsTemplate
                    }
                    <span class="p-2 text-gray-400 dark:text-slate-500 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-indigo-50 dark:hover:bg-indigo-900/50 rounded-lg transition-colors" title="View">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                    </span>
                </div>
            </div>
        }
    </div>
</a>

@code {
    [Parameter, EditorRequired]
    public string Href { get; set; } = "";

    [Parameter, EditorRequired]
    public string Title { get; set; } = "";

    [Parameter]
    public string? Subtitle { get; set; }

    [Parameter]
    public bool ShowAvatar { get; set; } = true;

    [Parameter]
    public string? AvatarText { get; set; }

    [Parameter]
    public string AvatarGradientStart { get; set; } = "#6366f1";

    [Parameter]
    public string AvatarGradientEnd { get; set; } = "#8b5cf6";

    [Parameter]
    public string AvatarShadow { get; set; } = "rgba(99, 102, 241, 0.3)";

    [Parameter]
    public RenderFragment? BadgeTemplate { get; set; }

    [Parameter]
    public RenderFragment? DetailsTemplate { get; set; }

    [Parameter]
    public RenderFragment? FooterTemplate { get; set; }

    [Parameter]
    public RenderFragment? ActionsTemplate { get; set; }
}
