@* Generic Status Banner Component - Used by Invoices and Estimates *@

@if (Variant != StatusVariant.None)
{
    var config = GetVariantConfig();
    <div class="px-8 py-4 border-b @config.BgClass @config.BorderClass dark:@config.DarkBgClass dark:@config.DarkBorderClass">
        <div class="flex items-center gap-3">
            <div class="flex items-center justify-center w-6 h-6 rounded-full @config.IconBgClass">
                @switch (config.IconType)
                {
                    case IconType.Check:
                        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        break;
                    case IconType.X:
                        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                        break;
                    case IconType.Warning:
                        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                        </svg>
                        break;
                    case IconType.Clock:
                        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        break;
                    case IconType.Mail:
                        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                        </svg>
                        break;
                    case IconType.Edit:
                        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                        </svg>
                        break;
                    case IconType.Dollar:
                        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        break;
                    case IconType.CheckCircle:
                        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        break;
                    case IconType.Ban:
                        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
                        </svg>
                        break;
                }
            </div>
            <div class="flex items-center gap-2">
                <span class="font-semibold @config.TextClass dark:@config.DarkTextClass">@Title</span>
                @if (!string.IsNullOrEmpty(Subtitle))
                {
                    <span class="text-sm @config.TextClass dark:@config.DarkTextClass">@Subtitle</span>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public StatusVariant Variant { get; set; } = StatusVariant.None;

    [Parameter]
    public string? Title { get; set; }

    [Parameter]
    public string? Subtitle { get; set; }

    public enum StatusVariant
    {
        None,
        Success,     // Green - Paid, Accepted
        Danger,      // Red - Overdue, Rejected
        Warning,     // Amber - Draft, Expired
        Info,        // Blue - Sent, Awaiting
        Purple,      // Purple - Converted
        Muted        // Gray - Void
    }

    private enum IconType
    {
        Check,
        X,
        Warning,
        Clock,
        Mail,
        Edit,
        Dollar,
        CheckCircle,
        Ban
    }

    private record VariantConfig(
        string BgClass,
        string BorderClass,
        string DarkBgClass,
        string DarkBorderClass,
        string IconBgClass,
        string TextClass,
        string DarkTextClass,
        IconType IconType
    );

    private VariantConfig GetVariantConfig() => Variant switch
    {
        StatusVariant.Success => new(
            "bg-emerald-50", "border-emerald-300",
            "bg-emerald-900/30", "border-emerald-800",
            "bg-emerald-600",
            "text-emerald-600", "text-emerald-400",
            IconType.Check
        ),
        StatusVariant.Danger => new(
            "bg-red-50", "border-red-300",
            "bg-red-900/30", "border-red-800",
            "bg-red-600",
            "text-red-600", "text-red-400",
            IconType.Warning
        ),
        StatusVariant.Warning => new(
            "bg-amber-50", "border-amber-300",
            "bg-amber-900/30", "border-amber-800",
            "bg-amber-600",
            "text-amber-600", "text-amber-400",
            IconType.Edit
        ),
        StatusVariant.Info => new(
            "bg-blue-50", "border-blue-300",
            "bg-blue-900/30", "border-blue-800",
            "bg-blue-600",
            "text-blue-600", "text-blue-400",
            IconType.Mail
        ),
        StatusVariant.Purple => new(
            "bg-purple-50", "border-purple-300",
            "bg-purple-900/30", "border-purple-800",
            "bg-purple-600",
            "text-purple-600", "text-purple-400",
            IconType.CheckCircle
        ),
        StatusVariant.Muted => new(
            "bg-gray-50", "border-gray-300",
            "bg-slate-800", "border-slate-700",
            "bg-gray-600",
            "text-gray-600", "text-slate-400",
            IconType.Ban
        ),
        _ => new(
            "bg-gray-50", "border-gray-300",
            "bg-slate-800", "border-slate-700",
            "bg-gray-600",
            "text-gray-600", "text-slate-400",
            IconType.Edit
        )
    };

}
