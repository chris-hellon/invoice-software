@* Pagination component for list pages *@

@if (TotalPages > 1)
{
    <div class="flex items-center justify-between pt-4 border-t border-gray-100 dark:border-slate-700">
        <div class="text-sm text-gray-500 dark:text-slate-400">
            Showing <span class="font-medium text-gray-900 dark:text-slate-100">@StartItem</span> to <span class="font-medium text-gray-900 dark:text-slate-100">@EndItem</span> of <span class="font-medium text-gray-900 dark:text-slate-100">@TotalItems</span> @ItemName
        </div>
        <div class="flex items-center gap-2">
            <button @onclick="GoToPrevious"
                    disabled="@(CurrentPage == 1)"
                    class="inline-flex items-center gap-1 px-3 py-2 text-sm font-medium text-gray-700 dark:text-slate-200 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-600 rounded-lg hover:bg-gray-50 dark:hover:bg-[#2d2a4a] disabled:opacity-50 disabled:cursor-not-allowed transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                </svg>
                Previous
            </button>

            <div class="flex items-center gap-1">
                @foreach (var pageNum in GetPageNumbers())
                {
                    if (pageNum == -1)
                    {
                        <span class="px-2 text-gray-400 dark:text-slate-500">...</span>
                    }
                    else
                    {
                        <button @onclick="() => GoToPage(pageNum)"
                                class="min-w-[36px] h-9 text-sm font-medium rounded-lg transition-colors @(pageNum == CurrentPage ? "bg-indigo-600 text-white" : "text-gray-700 dark:text-slate-200 hover:bg-gray-100 dark:hover:bg-[#2d2a4a]")">
                            @pageNum
                        </button>
                    }
                }
            </div>

            <button @onclick="GoToNext"
                    disabled="@(CurrentPage == TotalPages)"
                    class="inline-flex items-center gap-1 px-3 py-2 text-sm font-medium text-gray-700 dark:text-slate-200 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-600 rounded-lg hover:bg-gray-50 dark:hover:bg-[#2d2a4a] disabled:opacity-50 disabled:cursor-not-allowed transition-colors">
                Next
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
            </button>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired]
    public int CurrentPage { get; set; } = 1;

    [Parameter, EditorRequired]
    public int TotalItems { get; set; }

    [Parameter]
    public int PageSize { get; set; } = 12;

    [Parameter]
    public string ItemName { get; set; } = "items";

    [Parameter]
    public EventCallback<int> OnPageChanged { get; set; }

    private int TotalPages => (int)Math.Ceiling((double)TotalItems / PageSize);
    private int StartItem => TotalItems == 0 ? 0 : ((CurrentPage - 1) * PageSize) + 1;
    private int EndItem => Math.Min(CurrentPage * PageSize, TotalItems);

    private async Task GoToPrevious()
    {
        if (CurrentPage > 1)
        {
            await OnPageChanged.InvokeAsync(CurrentPage - 1);
        }
    }

    private async Task GoToNext()
    {
        if (CurrentPage < TotalPages)
        {
            await OnPageChanged.InvokeAsync(CurrentPage + 1);
        }
    }

    private async Task GoToPage(int page)
    {
        if (page != CurrentPage && page >= 1 && page <= TotalPages)
        {
            await OnPageChanged.InvokeAsync(page);
        }
    }

    private IEnumerable<int> GetPageNumbers()
    {
        var pages = new List<int>();
        var maxVisible = 5;

        if (TotalPages <= maxVisible)
        {
            for (int i = 1; i <= TotalPages; i++)
                pages.Add(i);
        }
        else
        {
            pages.Add(1);

            var start = Math.Max(2, CurrentPage - 1);
            var end = Math.Min(TotalPages - 1, CurrentPage + 1);

            if (start > 2)
                pages.Add(-1); // ellipsis

            for (int i = start; i <= end; i++)
                pages.Add(i);

            if (end < TotalPages - 1)
                pages.Add(-1); // ellipsis

            pages.Add(TotalPages);
        }

        return pages;
    }
}
