@* Loading skeleton grid for card layouts *@

<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5">
    @for (int i = 0; i < Count; i++)
    {
        <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-100 dark:border-slate-700 p-6 animate-pulse">
            @if (Variant == LoadingGridVariant.ClientCard)
            {
                <!-- Client card skeleton -->
                <div class="flex items-start gap-4 mb-4">
                    <div class="w-12 h-12 bg-gray-100 dark:bg-slate-700 rounded-full"></div>
                    <div class="flex-1">
                        <div class="h-5 w-32 bg-gray-100 dark:bg-slate-700 rounded mb-2"></div>
                        <div class="h-4 w-24 bg-gray-100 dark:bg-slate-700 rounded"></div>
                    </div>
                </div>
                <div class="space-y-2">
                    <div class="h-4 w-full bg-gray-100 dark:bg-slate-700 rounded"></div>
                    <div class="h-4 w-2/3 bg-gray-100 dark:bg-slate-700 rounded"></div>
                </div>
            }
            else if (Variant == LoadingGridVariant.ProjectCard)
            {
                <!-- Project card skeleton -->
                <div class="flex items-start justify-between mb-4">
                    <div class="flex-1">
                        <div class="h-5 w-40 bg-gray-100 dark:bg-slate-700 rounded mb-2"></div>
                        <div class="h-4 w-28 bg-gray-100 dark:bg-slate-700 rounded"></div>
                    </div>
                    <div class="h-6 w-16 bg-gray-100 dark:bg-slate-700 rounded-full"></div>
                </div>
                <div class="space-y-2">
                    <div class="h-4 w-full bg-gray-100 dark:bg-slate-700 rounded"></div>
                    <div class="h-4 w-2/3 bg-gray-100 dark:bg-slate-700 rounded"></div>
                </div>
            }
            else
            {
                <!-- Default card skeleton -->
                <div class="flex items-start justify-between mb-4">
                    <div class="flex-1">
                        <div class="h-5 w-40 bg-gray-100 dark:bg-slate-700 rounded mb-2"></div>
                        <div class="h-4 w-28 bg-gray-100 dark:bg-slate-700 rounded"></div>
                    </div>
                    <div class="h-6 w-16 bg-gray-100 dark:bg-slate-700 rounded-full"></div>
                </div>
                <div class="space-y-2">
                    <div class="h-4 w-full bg-gray-100 dark:bg-slate-700 rounded"></div>
                    <div class="h-4 w-2/3 bg-gray-100 dark:bg-slate-700 rounded"></div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter]
    public int Count { get; set; } = 6;

    [Parameter]
    public LoadingGridVariant Variant { get; set; } = LoadingGridVariant.Default;

    public enum LoadingGridVariant
    {
        Default,
        ClientCard,
        ProjectCard
    }
}
