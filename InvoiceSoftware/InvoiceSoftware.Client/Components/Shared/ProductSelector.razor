@if (IsLoading)
{
    <div class="flex justify-center py-12">
        <div class="w-8 h-8 border-2 border-gray-200 border-t-indigo-600 rounded-full animate-spin"></div>
    </div>
}
else if (Products == null || !Products.Any())
{
    <div class="py-8 text-center">
        <svg class="w-12 h-12 mx-auto text-gray-300 dark:text-slate-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
        </svg>
        <p class="text-sm text-gray-500 dark:text-slate-400">No products available</p>
        <a href="products/new" class="mt-2 text-sm text-indigo-600 hover:text-indigo-700 dark:text-indigo-400">
            Create your first product
        </a>
    </div>
}
else
{
    <div class="p-6 space-y-4">
        @if (LineItems.Any())
        {
            @for (var i = 0; i < LineItems.Count; i++)
            {
                var index = i;
                var item = LineItems[index];
                <div class="p-4 bg-gray-50 dark:bg-slate-700/50 rounded-xl space-y-4">
                    <div class="flex items-start justify-between gap-4">
                        <div class="flex-1 grid grid-cols-1 sm:grid-cols-12 gap-4">
                            <div class="sm:col-span-5">
                                <label class="block text-xs font-medium text-gray-500 dark:text-slate-400 mb-1">Description</label>
                                <input type="text" @bind="item.Description" @bind:event="oninput" @bind:after="NotifyChanged"
                                    class="w-full px-3 py-2 text-sm text-gray-900 dark:text-slate-100 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-600 rounded-lg focus:outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-500/10"
                                    placeholder="Product or service description" />
                            </div>
                            <div class="sm:col-span-2">
                                <label class="block text-xs font-medium text-gray-500 dark:text-slate-400 mb-1">Qty</label>
                                <input type="number" step="0.01" @bind="item.Quantity" @bind:event="oninput" @bind:after="NotifyChanged"
                                    class="w-full px-3 py-2 text-sm text-gray-900 dark:text-slate-100 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-600 rounded-lg focus:outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-500/10" />
                            </div>
                            <div class="sm:col-span-3">
                                <label class="block text-xs font-medium text-gray-500 dark:text-slate-400 mb-1">Unit Price</label>
                                <div class="relative">
                                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                        <span class="text-gray-400 dark:text-slate-500 text-sm">@CurrencyExtensions.GetSymbol(Currency)</span>
                                    </div>
                                    <input type="number" step="0.01" @bind="item.UnitPrice" @bind:event="oninput" @bind:after="NotifyChanged"
                                        class="w-full pl-7 pr-3 py-2 text-sm text-gray-900 dark:text-slate-100 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-600 rounded-lg focus:outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-500/10" />
                                </div>
                            </div>
                            <div class="sm:col-span-2 flex items-end">
                                <div class="w-full text-right">
                                    <label class="block text-xs font-medium text-gray-500 dark:text-slate-400 mb-1">Amount</label>
                                    <p class="py-2 text-sm font-semibold text-gray-900 dark:text-slate-100">@CurrencyExtensions.GetSymbol(Currency)@((item.Quantity * item.UnitPrice).ToString("N2"))</p>
                                </div>
                            </div>
                        </div>
                        <button type="button" @onclick="() => RemoveLineItem(index)"
                            class="mt-6 p-2 text-gray-400 hover:text-red-500 dark:text-slate-500 dark:hover:text-red-400 transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                            </svg>
                        </button>
                    </div>

                    <!-- Product Quick Add -->
                    <div>
                        <select @onchange="e => AddProductToLine(index, e)"
                            class="text-xs text-gray-500 dark:text-slate-400 bg-transparent border-0 p-0 focus:outline-none focus:ring-0 cursor-pointer hover:text-indigo-600 dark:hover:text-indigo-400">
                            <option value="">+ Fill from product catalog...</option>
                            @foreach (var product in Products)
                            {
                                <option value="@product.Id">@product.Name (@CurrencyExtensions.GetSymbol(product.Currency)@product.UnitPrice.ToString("N2"))</option>
                            }
                        </select>
                    </div>
                </div>
            }
        }

        <button type="button" @onclick="AddLineItem"
            class="w-full py-3 border-2 border-dashed border-gray-200 dark:border-slate-600 rounded-xl text-sm font-medium text-gray-500 dark:text-slate-400 hover:border-blue-400 hover:text-blue-600 dark:hover:border-blue-500 dark:hover:text-blue-400 transition-all">
            <span class="flex items-center justify-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                </svg>
                Add Product
            </span>
        </button>

        <!-- Selection Summary -->
        @if (LineItems.Any(li => !string.IsNullOrEmpty(li.Description)))
        {
            var validItems = LineItems.Where(li => !string.IsNullOrEmpty(li.Description)).ToList();
            var total = validItems.Sum(li => li.Quantity * li.UnitPrice);
            <div class="px-4 py-4 bg-blue-50 dark:bg-blue-900/30 rounded-xl border border-blue-100 dark:border-blue-800">
                <div class="flex items-center justify-between">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-full bg-blue-100 dark:bg-blue-800 flex items-center justify-center">
                            <svg class="w-4 h-4 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                            </svg>
                        </div>
                        <div>
                            <div class="text-sm font-medium text-blue-800 dark:text-blue-200">@validItems.Count product(s) added</div>
                        </div>
                    </div>
                    <div class="text-right">
                        <div class="text-lg font-bold text-blue-700 dark:text-blue-300">@CurrencyExtensions.GetSymbol(Currency)@total.ToString("N2")</div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter]
    public List<ProductDto>? Products { get; set; }

    [Parameter]
    public string Currency { get; set; } = "USD";

    [Parameter]
    public bool IsLoading { get; set; }

    [Parameter]
    public List<ProductLineItemModel> LineItems { get; set; } = [];

    [Parameter]
    public EventCallback<List<ProductLineItemModel>> LineItemsChanged { get; set; }

    private void AddLineItem()
    {
        LineItems.Add(new ProductLineItemModel());
        _ = LineItemsChanged.InvokeAsync(LineItems);
    }

    private void RemoveLineItem(int index)
    {
        LineItems.RemoveAt(index);
        _ = LineItemsChanged.InvokeAsync(LineItems);
    }

    private void AddProductToLine(int index, ChangeEventArgs e)
    {
        if (Products != null && Guid.TryParse(e.Value?.ToString(), out var productId))
        {
            var product = Products.FirstOrDefault(p => p.Id == productId);
            if (product != null)
            {
                LineItems[index].ProductId = productId;
                LineItems[index].Description = product.Name + (product.Description != null ? $" - {product.Description}" : "");
                LineItems[index].UnitPrice = product.UnitPrice;
                LineItems[index].Quantity = product.DefaultQuantity;
                _ = LineItemsChanged.InvokeAsync(LineItems);
            }
        }
    }

    private void NotifyChanged()
    {
        _ = LineItemsChanged.InvokeAsync(LineItems);
    }

    public class ProductLineItemModel
    {
        public Guid? ProductId { get; set; }
        public string Description { get; set; } = "";
        public decimal Quantity { get; set; } = 1;
        public decimal UnitPrice { get; set; } = 0;
    }
}
