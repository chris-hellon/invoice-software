@* Reusable filter select dropdown *@
@typeparam TValue

@if (!string.IsNullOrEmpty(Label))
{
    <span class="text-sm text-gray-500 whitespace-nowrap">@Label</span>
}
<select value="@Value"
        @onchange="OnChange"
        class="py-3 px-4 text-sm text-gray-700 bg-gray-50 border-0 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500/20 cursor-pointer">
    @ChildContent
</select>

@code {
    [Parameter]
    public string? Label { get; set; }

    [Parameter]
    public TValue? Value { get; set; }

    [Parameter]
    public EventCallback<TValue> ValueChanged { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private async Task OnChange(ChangeEventArgs e)
    {
        var stringValue = e.Value?.ToString();

        if (typeof(TValue) == typeof(string))
        {
            await ValueChanged.InvokeAsync((TValue)(object)(stringValue ?? ""));
        }
        else if (typeof(TValue) == typeof(Guid) || typeof(TValue) == typeof(Guid?))
        {
            if (Guid.TryParse(stringValue, out var guid))
            {
                await ValueChanged.InvokeAsync((TValue)(object)guid);
            }
            else
            {
                await ValueChanged.InvokeAsync(default!);
            }
        }
    }
}
