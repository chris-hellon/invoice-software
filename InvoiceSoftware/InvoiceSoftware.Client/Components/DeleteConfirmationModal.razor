<div class="space-y-6">
    <!-- Warning Icon -->
    <div class="flex justify-center">
        <div class="w-16 h-16 rounded-full flex items-center justify-center"
             style="background: linear-gradient(135deg, #fef2f2 0%, #fee2e2 100%);">
            <svg class="w-8 h-8 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
        </div>
    </div>

    <!-- Message -->
    <div class="text-center">
        <p class="text-gray-900 dark:text-slate-100">
            Are you sure you want to delete <span class="font-semibold">@ItemName</span>?
        </p>
        @if (!string.IsNullOrEmpty(WarningMessage))
        {
            <p class="mt-2 text-sm text-gray-500 dark:text-slate-400">@WarningMessage</p>
        }
        else
        {
            <p class="mt-2 text-sm text-gray-500 dark:text-slate-400">This action cannot be undone.</p>
        }
    </div>

    <!-- Actions -->
    <div class="flex justify-center gap-3 pt-2">
        <button @onclick="Cancel"
                class="px-5 py-2.5 text-sm font-medium text-gray-700 dark:text-slate-300 bg-white dark:bg-slate-700 border border-gray-200 dark:border-slate-600 rounded-xl hover:bg-gray-50 dark:hover:bg-slate-600 transition-colors">
            Cancel
        </button>
        <button @onclick="Confirm"
                disabled="@_isDeleting"
                class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium text-white bg-red-600 rounded-xl hover:bg-red-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                style="box-shadow: 0 4px 14px rgba(239, 68, 68, 0.35);">
            @if (_isDeleting)
            {
                <div class="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>
            }
            else
            {
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
            }
            @(_isDeleting ? "Deleting..." : "Delete")
        </button>
    </div>
</div>

@code {
    [Parameter] public string ItemName { get; set; } = "this item";
    [Parameter] public string? WarningMessage { get; set; }
    [Parameter] public Func<Task>? OnDelete { get; set; }

    private bool _isDeleting;

    private void Cancel()
    {
        ModalService.Close(false);
    }

    private async Task Confirm()
    {
        if (OnDelete != null)
        {
            _isDeleting = true;
            try
            {
                await OnDelete.Invoke();
                ModalService.Close(true);
            }
            catch
            {
                _isDeleting = false;
                throw;
            }
        }
        else
        {
            ModalService.Close(true);
        }
    }
}
