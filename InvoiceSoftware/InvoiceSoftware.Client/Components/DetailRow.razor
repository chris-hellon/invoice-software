@* Simple detail row component for displaying label-value pairs *@

<div class="flex justify-between items-start py-3 border-b border-gray-100 dark:border-[#2d2a4a] last:border-0">
    <dt class="text-sm font-medium text-gray-500 dark:text-slate-400">@Label</dt>
    <dd class="text-sm text-gray-900 dark:text-slate-100 text-right">
        @if (ChildContent != null)
        {
            @ChildContent
        }
        else
        {
            @Value
        }
    </dd>
</div>

@code {
    [Parameter]
    public string Label { get; set; } = "";

    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }
}
