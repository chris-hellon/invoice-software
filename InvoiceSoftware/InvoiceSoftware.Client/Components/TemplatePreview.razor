@* Shared template preview component - used in template cards and template editor *@

<div class="aspect-[3/4] rounded-xl overflow-hidden border border-gray-100 dark:border-slate-700"
     style="background-color: @BackgroundColor; font-family: @(FontFamily ?? "system-ui")">
    <div class="h-full flex flex-col p-4" style="color: @TextColor">
        <!-- Header - changes based on HeaderLayout -->
        @if (HeaderLayout?.ToLower() == "centered")
        {
            <div class="rounded-lg p-3 mb-4 text-center" style="background-color: @PrimaryColor">
                @if (ShowLogo)
                {
                    <div class="h-6 w-12 bg-white/30 rounded mx-auto mb-2"></div>
                }
                <div class="h-4 w-24 bg-white/30 rounded mx-auto mb-1"></div>
                <div class="h-3 w-16 bg-white/20 rounded mx-auto"></div>
            </div>
        }
        else if (HeaderLayout?.ToLower() == "minimal")
        {
            <div class="flex justify-between items-center mb-4 pb-2" style="border-bottom: 1px solid @AccentColor">
                @if (ShowLogo)
                {
                    <div class="h-5 w-10 rounded opacity-50" style="background-color: @PrimaryColor"></div>
                }
                <div class="h-5 w-16 rounded" style="background-color: @PrimaryColor"></div>
            </div>
        }
        else
        {
            <div class="rounded-lg p-3 mb-4" style="background-color: @PrimaryColor">
                <div class="flex items-center gap-2">
                    @if (ShowLogo)
                    {
                        <div class="h-6 w-10 bg-white/30 rounded"></div>
                    }
                    <div>
                        <div class="h-4 w-20 bg-white/30 rounded mb-1"></div>
                        <div class="h-3 w-16 bg-white/20 rounded"></div>
                    </div>
                </div>
            </div>
        }

        <!-- Invoice Details -->
        <div class="flex justify-between mb-4 text-xs opacity-70">
            <div>
                <div class="h-2 w-12 bg-current rounded mb-1 opacity-50"></div>
                <div class="h-2 w-16 bg-current rounded opacity-30"></div>
            </div>
            <div class="text-right">
                <div class="h-2 w-12 bg-current rounded mb-1 opacity-50"></div>
                <div class="h-2 w-8 bg-current rounded opacity-30"></div>
            </div>
        </div>

        <!-- Line Items - changes based on ItemsLayout -->
        <div class="flex-1 space-y-2">
            <div class="h-6 rounded px-2 flex items-center" style="background-color: @AccentColor; opacity: 0.2">
                <div class="h-2 w-full bg-current rounded opacity-50"></div>
            </div>
            @for (int i = 0; i < 3; i++)
            {
                var itemClass = (ItemsLayout?.ToLower() == "bordered" ? "border border-current/10" : "") +
                               (ItemsLayout?.ToLower() == "striped" && i % 2 == 0 ? " bg-current/5" : "");
                <div class="h-5 rounded px-2 flex items-center @itemClass">
                    <div class="h-2 bg-current rounded opacity-30" style="width: @(70 - i * 10)%"></div>
                    @if (ShowItemDescriptions)
                    {
                        <div class="ml-auto h-1.5 w-8 bg-current rounded opacity-20"></div>
                    }
                </div>
            }
        </div>

        <!-- Footer - changes based on FooterLayout -->
        <div class="mt-auto pt-3 border-t" style="border-color: @AccentColor; opacity: 0.3">
            @if (FooterLayout?.ToLower() == "detailed")
            {
                <div class="space-y-2">
                    <div class="flex justify-between items-center">
                        <div class="h-2 w-10 bg-current rounded opacity-40"></div>
                        <div class="h-2 w-12 bg-current rounded opacity-40"></div>
                    </div>
                    <div class="flex justify-between items-center">
                        <div class="h-2 w-8 bg-current rounded opacity-40"></div>
                        <div class="h-2 w-10 bg-current rounded opacity-40"></div>
                    </div>
                    <div class="flex justify-between items-center pt-1 border-t border-current/20">
                        <div class="h-2 w-12 bg-current rounded opacity-50"></div>
                        <div class="h-4 w-16 rounded" style="background-color: @PrimaryColor"></div>
                    </div>
                </div>
            }
            else
            {
                <div class="flex justify-between items-center">
                    <div class="h-2 w-12 bg-current rounded opacity-50"></div>
                    <div class="h-4 w-16 rounded" style="background-color: @PrimaryColor"></div>
                </div>
            }
            @if (ShowBankDetails)
            {
                <div class="mt-2 pt-2 border-t border-current/10">
                    <div class="h-2 w-20 bg-current rounded opacity-30 mb-1"></div>
                    <div class="h-1.5 w-24 bg-current rounded opacity-20"></div>
                </div>
            }
            @if (ShowPaymentQR)
            {
                <div class="mt-2 flex justify-end">
                    <div class="w-8 h-8 rounded opacity-30" style="background-color: @AccentColor"></div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public string PrimaryColor { get; set; } = "#4F46E5";
    [Parameter] public string AccentColor { get; set; } = "#6366F1";
    [Parameter] public string TextColor { get; set; } = "#1F2937";
    [Parameter] public string BackgroundColor { get; set; } = "#FFFFFF";
    [Parameter] public string? HeaderLayout { get; set; } = "standard";
    [Parameter] public string? ItemsLayout { get; set; } = "standard";
    [Parameter] public string? FooterLayout { get; set; } = "standard";
    [Parameter] public bool ShowLogo { get; set; } = true;
    [Parameter] public bool ShowPaymentQR { get; set; } = true;
    [Parameter] public bool ShowBankDetails { get; set; } = true;
    [Parameter] public bool ShowItemDescriptions { get; set; } = true;
    [Parameter] public string? FontFamily { get; set; }
}
