@page "/recurring-invoices"

@inject ICall<GetRecurringInvoices, PaginatedResponse<RecurringInvoiceSummaryDto>> GetRecurringInvoicesCall
@inject ICall<DeleteRecurringInvoice> DeleteRecurringInvoiceCall
@inject ICall<PauseRecurringInvoice> PauseRecurringInvoiceCall
@inject ICall<ResumeRecurringInvoice> ResumeRecurringInvoiceCall

<PageTitle>Recurring Invoices - InvoicePro</PageTitle>

<ListPageLayout Title="Recurring Invoices"
                Description="Manage scheduled invoices that auto-generate."
                ActionUrl="recurring-invoices/new"
                ActionText="New Recurring Invoice"
                SearchPlaceholder="Search recurring invoices..."
                SearchValue="@_searchTerm"
                SearchValueChanged="OnSearchChanged"
                Breadcrumbs="@(new List<PageHeader.BreadcrumbItem> { new("Recurring Invoices") })">
    <Filters>
        <select @bind="_selectedActive" @bind:after="OnFilterChanged" class="py-3 px-4 text-sm text-gray-700 dark:text-slate-200 bg-gray-50 dark:bg-slate-700 border-0 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500/20 cursor-pointer">
            <option value="">All Status</option>
            <option value="true">Active</option>
            <option value="false">Paused</option>
        </select>
    </Filters>
    <ChildContent>
        @if (_isLoading)
        {
            <LoadingTable Rows="5" Columns="7" />
        }
        else if (_response == null || !_response.Items.Any())
        {
            <EmptyState Title="No recurring invoices found"
                        Message="@(HasActiveFilters ? "No recurring invoices match your filters. Try adjusting your search." : "Set up recurring invoices to auto-generate invoices on a schedule.")"
                        IconType="EmptyState.EmptyStateIcon.Refresh"
                        ActionUrl="@(HasActiveFilters ? null : "recurring-invoices/new")"
                        ActionText="@(HasActiveFilters ? null : "New Recurring Invoice")" />
        }
        else
        {
            <DataTable TItem="RecurringInvoiceSummaryDto"
                       Items="_response.Items"
                       CurrentPage="_response.Page"
                       TotalCount="_response.TotalCount"
                       PageSize="_response.PageSize"
                       ItemName="recurring invoices"
                       OnPageChanged="OnPageChanged">
                <HeaderTemplate>
                    <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-gray-500 dark:text-slate-400 uppercase tracking-wider">Template</th>
                    <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-gray-500 dark:text-slate-400 uppercase tracking-wider">Client</th>
                    <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-gray-500 dark:text-slate-400 uppercase tracking-wider">Frequency</th>
                    <th scope="col" class="px-6 py-4 text-right text-xs font-semibold text-gray-500 dark:text-slate-400 uppercase tracking-wider">Est. Total</th>
                    <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-gray-500 dark:text-slate-400 uppercase tracking-wider">Next Invoice</th>
                    <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-gray-500 dark:text-slate-400 uppercase tracking-wider">Status</th>
                    <th scope="col" class="relative px-6 py-4"><span class="sr-only">Actions</span></th>
                </HeaderTemplate>
                <RowTemplate Context="invoice">
                    <tr class="group hover:bg-gray-50/50 dark:hover:bg-[#2d2a4a]/50 transition-colors">
                        <td class="px-6 py-4">
                            <a href="recurring-invoices/@invoice.Id" class="text-sm font-medium text-gray-900 dark:text-slate-100 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors hover:underline">@invoice.TemplateName</a>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            <div class="text-sm text-gray-700 dark:text-slate-300">@invoice.ClientName</div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            <div class="text-sm text-gray-900 dark:text-slate-100">@invoice.FrequencyDescription</div>
                            <div class="text-xs text-gray-500 dark:text-slate-400">@invoice.GeneratedCount generated</div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-right">
                            <div class="text-sm font-semibold text-gray-900 dark:text-slate-100">@CurrencyExtensions.GetSymbol(invoice.Currency)@invoice.EstimatedTotal.ToString("N2")</div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            @if (invoice.IsActive)
                            {
                                <div class="text-sm text-gray-900 dark:text-slate-100">@invoice.NextInvoiceDate.ToString("MMM d, yyyy")</div>
                                @if (GetDaysUntil(invoice.NextInvoiceDate) <= 0)
                                {
                                    <div class="text-xs text-amber-600 dark:text-amber-400">Due now</div>
                                }
                                else if (GetDaysUntil(invoice.NextInvoiceDate) <= 7)
                                {
                                    var days = GetDaysUntil(invoice.NextInvoiceDate);
                                    <div class="text-xs text-gray-500 dark:text-slate-400">In @days day@(days > 1 ? "s" : "")</div>
                                }
                            }
                            else
                            {
                                <div class="text-sm text-gray-400 dark:text-slate-500">-</div>
                            }
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            @if (invoice.IsActive)
                            {
                                <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-medium bg-emerald-50 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400">Active</span>
                            }
                            else
                            {
                                <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-medium bg-gray-100 text-gray-600 dark:bg-slate-700 dark:text-slate-400">Paused</span>
                            }
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-right">
                            <div class="flex items-center justify-end gap-1">
                                @if (invoice.IsActive)
                                {
                                    <IconButton OnClick="() => PauseInvoiceAsync(invoice)" Title="Pause">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                                        </svg>
                                    </IconButton>
                                }
                                else
                                {
                                    <IconButton OnClick="() => ResumeInvoiceAsync(invoice)" Title="Resume">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                        </svg>
                                    </IconButton>
                                }
                                <IconButton Href="@($"recurring-invoices/{invoice.Id}")" Title="View">
                                    <ViewIcon />
                                </IconButton>
                                <IconButton Href="@($"recurring-invoices/{invoice.Id}/edit")" Title="Edit">
                                    <EditIcon />
                                </IconButton>
                                <IconButton OnClick="() => DeleteInvoiceAsync(invoice)" Variant="IconButton.IconButtonVariant.Danger" Title="Delete">
                                    <DeleteIcon />
                                </IconButton>
                            </div>
                        </td>
                    </tr>
                </RowTemplate>
            </DataTable>
        }
    </ChildContent>
</ListPageLayout>

@code {
    private PaginatedResponse<RecurringInvoiceSummaryDto>? _response;
    private bool _isLoading = true;
    private string _searchTerm = "";
    private string _selectedActive = "";
    private int _currentPage = 1;
    private const int PageSize = 15;

    private bool HasActiveFilters => !string.IsNullOrEmpty(_searchTerm) || !string.IsNullOrEmpty(_selectedActive);

    protected override async Task OnInitializedAsync()
    {
        await LoadInvoices();
    }

    private async Task LoadInvoices()
    {
        _isLoading = true;
        try
        {
            _response = await GetRecurringInvoicesCall.Call(new GetRecurringInvoices
            {
                ActiveOnly = string.IsNullOrEmpty(_selectedActive) || bool.Parse(_selectedActive),
                Page = _currentPage,
                PageSize = PageSize,
                Search = _searchTerm
            });
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading recurring invoices: {ex.Message}");
            _response = new PaginatedResponse<RecurringInvoiceSummaryDto>();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnFilterChanged()
    {
        _currentPage = 1;
        await LoadInvoices();
    }

    private async Task OnSearchChanged(string value)
    {
        _searchTerm = value;
        _currentPage = 1;
        await LoadInvoices();
    }

    private async Task OnPageChanged(int page)
    {
        _currentPage = page;
        await LoadInvoices();
    }

    private async Task PauseInvoiceAsync(RecurringInvoiceSummaryDto invoice)
    {
        try
        {
            await PauseRecurringInvoiceCall.Call(new PauseRecurringInvoice { Id = invoice.Id });
            await LoadInvoices();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error pausing invoice: {ex.Message}");
        }
    }

    private async Task ResumeInvoiceAsync(RecurringInvoiceSummaryDto invoice)
    {
        try
        {
            await ResumeRecurringInvoiceCall.Call(new ResumeRecurringInvoice { Id = invoice.Id });
            await LoadInvoices();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error resuming invoice: {ex.Message}");
        }
    }

    private async Task DeleteInvoiceAsync(RecurringInvoiceSummaryDto invoice)
    {
        var confirmed = await ModalService.ShowAsync<bool>(
            typeof(DeleteConfirmationModal),
            "Delete Recurring Invoice",
            new Dictionary<string, object>
            {
                { "ItemName", invoice.TemplateName },
                { "WarningMessage", $"This will stop future invoices from being generated. {invoice.GeneratedCount} invoices have already been created." }
            },
            new ModalOptions { Size = ModalSize.Small });

        if (!confirmed) return;

        try
        {
            await DeleteRecurringInvoiceCall.Call(new DeleteRecurringInvoice { Id = invoice.Id });
            await LoadInvoices();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting recurring invoice: {ex.Message}");
        }
    }

    private static int GetDaysUntil(DateOnly date) =>
        date.DayNumber - DateOnly.FromDateTime(DateTime.Today).DayNumber;
}
