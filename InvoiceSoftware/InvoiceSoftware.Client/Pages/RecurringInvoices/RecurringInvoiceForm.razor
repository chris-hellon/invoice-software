@page "/recurring-invoices/new"
@page "/recurring-invoices/{Id:guid}/edit"

@inject ICall<GetRecurringInvoice, RecurringInvoiceDetailDto> GetRecurringInvoiceCall
@inject ICall<GetClients, PaginatedResponse<ClientDto>> GetClientsCall
@inject ICall<GetProducts, PaginatedResponse<ProductDto>> GetProductsCall
@inject ICall<CreateRecurringInvoice, Guid> CreateRecurringInvoiceCall
@inject ICall<UpdateRecurringInvoice> UpdateRecurringInvoiceCall

<PageTitle>@(Id.HasValue ? "Edit Recurring Invoice" : "New Recurring Invoice") - InvoicePro</PageTitle>

<div class="space-y-6">
    <PageHeader Title="@(Id.HasValue ? "Edit Recurring Invoice" : "New Recurring Invoice")"
                Description="@(Id.HasValue ? "Update recurring invoice settings" : "Set up an invoice that generates automatically")"
                ShowBackButton="true"
                BackUrl="recurring-invoices"
                Breadcrumbs="@_breadcrumbs" />

    @if (_isLoading)
    {
        <LoadingSpinner Padding="py-20" />
    }
    else
    {
        <EditForm Model="_model" OnValidSubmit="HandleSubmit" class="space-y-6">
            <DataAnnotationsValidator />

            <!-- Client & Schedule Section -->
            <Card Title="Schedule Details" Description="Configure when invoices should be generated.">
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
                    @if (!Id.HasValue)
                    {
                        <div class="sm:col-span-2">
                            <label for="clientId" class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-2">Client <span class="text-red-500">*</span></label>
                            <InputSelect id="clientId" @bind-Value="_model.ClientId"
                                class="w-full px-4 py-3 text-sm text-gray-900 dark:text-slate-100 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-600 rounded-xl transition-all duration-200 focus:outline-none focus:border-indigo-400 focus:ring-4 focus:ring-indigo-500/10 hover:border-gray-300 dark:hover:border-slate-500 cursor-pointer">
                                <option value="">Select a client...</option>
                                @foreach (var client in _clients)
                                {
                                    <option value="@client.Id">@client.Name @(client.CompanyName != null ? $"({client.CompanyName})" : "")</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => _model.ClientId)" class="mt-1.5 text-xs text-red-600" />
                        </div>
                    }

                    <div class="@(Id.HasValue ? "sm:col-span-2" : "")">
                        <label for="templateName" class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-2">Template Name <span class="text-red-500">*</span></label>
                        <InputText id="templateName" @bind-Value="_model.TemplateName"
                            class="w-full px-4 py-3 text-sm text-gray-900 dark:text-slate-100 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-600 rounded-xl transition-all duration-200 placeholder:text-gray-400 dark:placeholder:text-slate-500 focus:outline-none focus:border-indigo-400 focus:ring-4 focus:ring-indigo-500/10 hover:border-gray-300 dark:hover:border-slate-500"
                            placeholder="Monthly Retainer" />
                        <ValidationMessage For="@(() => _model.TemplateName)" class="mt-1.5 text-xs text-red-600" />
                    </div>

                    @if (!Id.HasValue)
                    {
                        <div>
                            <label for="currency" class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-2">Currency <span class="text-red-500">*</span></label>
                            <InputSelect id="currency" @bind-Value="_model.Currency"
                                class="w-full px-4 py-3 text-sm text-gray-900 dark:text-slate-100 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-600 rounded-xl transition-all duration-200 focus:outline-none focus:border-indigo-400 focus:ring-4 focus:ring-indigo-500/10 hover:border-gray-300 dark:hover:border-slate-500 cursor-pointer">
                                @foreach (var currency in Enum.GetValues<Currency>())
                                {
                                    <option value="@currency.ToString()">@currency.ToString() (@currency.GetSymbol())</option>
                                }
                            </InputSelect>
                        </div>
                    }
                </div>

                <hr class="border-gray-100 dark:border-slate-700" />

                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
                    <div>
                        <label for="frequencyInterval" class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-2">Every</label>
                        <InputNumber id="frequencyInterval" @bind-Value="_model.FrequencyInterval"
                            class="w-full px-4 py-3 text-sm text-gray-900 dark:text-slate-100 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-600 rounded-xl transition-all duration-200 focus:outline-none focus:border-indigo-400 focus:ring-4 focus:ring-indigo-500/10 hover:border-gray-300 dark:hover:border-slate-500" />
                    </div>

                    <div>
                        <label for="frequency" class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-2">Period</label>
                        <InputSelect id="frequency" @bind-Value="_model.Frequency"
                            class="w-full px-4 py-3 text-sm text-gray-900 dark:text-slate-100 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-600 rounded-xl transition-all duration-200 focus:outline-none focus:border-indigo-400 focus:ring-4 focus:ring-indigo-500/10 hover:border-gray-300 dark:hover:border-slate-500 cursor-pointer">
                            <option value="Day">Day(s)</option>
                            <option value="Week">Week(s)</option>
                            <option value="Month">Month(s)</option>
                            <option value="Year">Year(s)</option>
                        </InputSelect>
                    </div>

                    <div>
                        <label for="startDate" class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-2">Start Date <span class="text-red-500">*</span></label>
                        <InputDate id="startDate" @bind-Value="_model.StartDate"
                            class="w-full px-4 py-3 text-sm text-gray-900 dark:text-slate-100 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-600 rounded-xl transition-all duration-200 focus:outline-none focus:border-indigo-400 focus:ring-4 focus:ring-indigo-500/10 hover:border-gray-300 dark:hover:border-slate-500" />
                    </div>

                    <div>
                        <label for="endDate" class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-2">End Date (Optional)</label>
                        <InputDate id="endDate" @bind-Value="_model.EndDate"
                            class="w-full px-4 py-3 text-sm text-gray-900 dark:text-slate-100 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-600 rounded-xl transition-all duration-200 focus:outline-none focus:border-indigo-400 focus:ring-4 focus:ring-indigo-500/10 hover:border-gray-300 dark:hover:border-slate-500" />
                    </div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                    <div>
                        <label for="dueDays" class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-2">Payment Due (Days)</label>
                        <InputNumber id="dueDays" @bind-Value="_model.DueDays"
                            class="w-full px-4 py-3 text-sm text-gray-900 dark:text-slate-100 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-600 rounded-xl transition-all duration-200 focus:outline-none focus:border-indigo-400 focus:ring-4 focus:ring-indigo-500/10 hover:border-gray-300 dark:hover:border-slate-500" />
                        <p class="mt-1 text-xs text-gray-500 dark:text-slate-400">Days after invoice date when payment is due</p>
                    </div>
                </div>
            </Card>

            <!-- Line Items Section -->
            <Card Title="Line Items" Description="Configure the default line items for generated invoices.">
                <div class="space-y-4">
                    @for (var i = 0; i < _model.LineItems.Count; i++)
                    {
                        var index = i;
                        var item = _model.LineItems[index];
                        <div class="p-4 bg-gray-50 dark:bg-slate-700/50 rounded-xl space-y-4">
                            <div class="flex items-start justify-between gap-4">
                                <div class="flex-1 grid grid-cols-1 sm:grid-cols-12 gap-4">
                                    <div class="sm:col-span-5">
                                        <label class="block text-xs font-medium text-gray-500 dark:text-slate-400 mb-1">Description</label>
                                        <InputText @bind-Value="item.Description"
                                            class="w-full px-3 py-2 text-sm text-gray-900 dark:text-slate-100 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-600 rounded-lg focus:outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-500/10"
                                            placeholder="Product or service description" />
                                    </div>
                                    <div class="sm:col-span-2">
                                        <label class="block text-xs font-medium text-gray-500 dark:text-slate-400 mb-1">Qty</label>
                                        <InputNumber @bind-Value="item.Quantity"
                                            class="w-full px-3 py-2 text-sm text-gray-900 dark:text-slate-100 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-600 rounded-lg focus:outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-500/10" />
                                    </div>
                                    <div class="sm:col-span-3">
                                        <label class="block text-xs font-medium text-gray-500 dark:text-slate-400 mb-1">Unit Price</label>
                                        <div class="relative">
                                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                                <span class="text-gray-400 dark:text-slate-500 text-sm">@CurrencyExtensions.GetSymbol(_model.Currency)</span>
                                            </div>
                                            <InputNumber @bind-Value="item.UnitPrice"
                                                class="w-full pl-7 pr-3 py-2 text-sm text-gray-900 dark:text-slate-100 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-600 rounded-lg focus:outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-500/10" />
                                        </div>
                                    </div>
                                    <div class="sm:col-span-2 flex items-end">
                                        <div class="w-full text-right">
                                            <label class="block text-xs font-medium text-gray-500 dark:text-slate-400 mb-1">Amount</label>
                                            <p class="py-2 text-sm font-semibold text-gray-900 dark:text-slate-100">@CurrencyExtensions.GetSymbol(_model.Currency)@((item.Quantity * item.UnitPrice).ToString("N2"))</p>
                                        </div>
                                    </div>
                                </div>
                                <button type="button" @onclick="() => RemoveLineItem(index)"
                                    class="mt-6 p-2 text-gray-400 hover:text-red-500 dark:text-slate-500 dark:hover:text-red-400 transition-colors">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                    </svg>
                                </button>
                            </div>

                            <!-- Product Quick Add -->
                            @if (_products.Any())
                            {
                                <div>
                                    <select @onchange="e => AddProductToLine(index, e)"
                                        class="text-xs text-gray-500 dark:text-slate-400 bg-transparent border-0 p-0 focus:outline-none focus:ring-0 cursor-pointer hover:text-indigo-600 dark:hover:text-indigo-400">
                                        <option value="">+ Add from products...</option>
                                        @foreach (var product in _products)
                                        {
                                            <option value="@product.Id">@product.Name (@CurrencyExtensions.GetSymbol(product.Currency)@product.UnitPrice.ToString("N2"))</option>
                                        }
                                    </select>
                                </div>
                            }
                        </div>
                    }

                    <button type="button" @onclick="AddLineItem"
                        class="w-full py-3 border-2 border-dashed border-gray-200 dark:border-slate-600 rounded-xl text-sm font-medium text-gray-500 dark:text-slate-400 hover:border-indigo-400 hover:text-indigo-600 dark:hover:border-indigo-500 dark:hover:text-indigo-400 transition-all">
                        + Add Line Item
                    </button>

                    <!-- Totals -->
                    <div class="pt-4 border-t border-gray-200 dark:border-slate-600">
                        <div class="flex justify-end">
                            <div class="w-64 space-y-2">
                                <div class="flex justify-between text-sm">
                                    <span class="text-gray-600 dark:text-slate-400">Subtotal</span>
                                    <span class="font-medium text-gray-900 dark:text-slate-100">@CurrencyExtensions.GetSymbol(_model.Currency)@Subtotal.ToString("N2")</span>
                                </div>
                                <div class="flex justify-between items-center text-sm">
                                    <div class="flex items-center gap-2">
                                        <span class="text-gray-600 dark:text-slate-400">Tax</span>
                                        <InputNumber @bind-Value="_model.TaxRate"
                                            class="w-16 px-2 py-1 text-xs text-gray-900 dark:text-slate-100 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-600 rounded focus:outline-none focus:border-indigo-400" />
                                        <span class="text-gray-400 dark:text-slate-500">%</span>
                                    </div>
                                    <span class="text-gray-900 dark:text-slate-100">@CurrencyExtensions.GetSymbol(_model.Currency)@TaxAmount.ToString("N2")</span>
                                </div>
                                <div class="flex justify-between text-base font-bold pt-2 border-t border-gray-200 dark:border-slate-600">
                                    <span class="text-gray-900 dark:text-slate-100">Total</span>
                                    <span class="text-gray-900 dark:text-slate-100">@CurrencyExtensions.GetSymbol(_model.Currency)@Total.ToString("N2")</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </Card>

            <!-- Notes & Terms -->
            <Card Title="Notes & Terms" Description="Add any additional notes or terms for generated invoices.">
                <div class="grid grid-cols-1 gap-5">
                    <div>
                        <label for="notes" class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-2">Notes</label>
                        <InputTextArea id="notes" @bind-Value="_model.Notes" rows="3"
                            class="w-full px-4 py-3 text-sm text-gray-900 dark:text-slate-100 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-600 rounded-xl transition-all duration-200 placeholder:text-gray-400 dark:placeholder:text-slate-500 focus:outline-none focus:border-indigo-400 focus:ring-4 focus:ring-indigo-500/10 resize-none"
                            placeholder="Additional notes for the client..." />
                    </div>
                    <div>
                        <label for="terms" class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-2">Terms & Conditions</label>
                        <InputTextArea id="terms" @bind-Value="_model.Terms" rows="3"
                            class="w-full px-4 py-3 text-sm text-gray-900 dark:text-slate-100 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-600 rounded-xl transition-all duration-200 placeholder:text-gray-400 dark:placeholder:text-slate-500 focus:outline-none focus:border-indigo-400 focus:ring-4 focus:ring-indigo-500/10 resize-none"
                            placeholder="Terms and conditions..." />
                    </div>
                    <div>
                        <label for="footer" class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-2">Footer</label>
                        <InputTextArea id="footer" @bind-Value="_model.Footer" rows="2"
                            class="w-full px-4 py-3 text-sm text-gray-900 dark:text-slate-100 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-600 rounded-xl transition-all duration-200 placeholder:text-gray-400 dark:placeholder:text-slate-500 focus:outline-none focus:border-indigo-400 focus:ring-4 focus:ring-indigo-500/10 resize-none"
                            placeholder="Footer text for generated invoices..." />
                    </div>
                </div>
            </Card>

            <ErrorAlert Message="@_errorMessage" />

            <div class="flex items-center justify-end gap-3 pt-4">
                <a href="recurring-invoices" class="px-5 py-2.5 text-sm font-medium text-gray-700 dark:text-slate-300 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-600 rounded-xl hover:bg-gray-50 dark:hover:bg-slate-700 hover:border-gray-300 dark:hover:border-slate-500 transition-all duration-200">
                    Cancel
                </a>
                <PrimaryButton ButtonType="submit"
                               Text="@(Id.HasValue ? "Save Changes" : "Create Recurring Invoice")"
                               IsLoading="@_isSaving"
                               ShowIcon="false" />
            </div>
        </EditForm>
    }
</div>

@code {
    [Parameter]
    public Guid? Id { get; set; }

    private RecurringInvoiceFormModel _model = new();
    private List<ClientDto> _clients = [];
    private List<ProductDto> _products = [];
    private bool _isLoading = true;
    private bool _isSaving;
    private string? _errorMessage;
    private List<PageHeader.BreadcrumbItem> _breadcrumbs = [];

    private decimal Subtotal => _model.LineItems.Sum(i => i.Quantity * i.UnitPrice);
    private decimal TaxAmount => Subtotal * _model.TaxRate / 100;
    private decimal Total => Subtotal + TaxAmount;

    protected override async Task OnInitializedAsync()
    {
        _breadcrumbs =
        [
            new PageHeader.BreadcrumbItem("Recurring Invoices", "/recurring-invoices"),
            new PageHeader.BreadcrumbItem(Id.HasValue ? "Edit" : "New")
        ];

        try
        {
            // Load clients and products in parallel for faster loading
            var clientsTask = GetClientsCall.Call(new GetClients { ActiveOnly = true, PageSize = 1000 });
            var productsTask = GetProductsCall.Call(new GetProducts { ActiveOnly = true, PageSize = 1000 });

            await Task.WhenAll(clientsTask, productsTask);

            _clients = (await clientsTask)?.Items?.ToList() ?? [];
            _products = (await productsTask)?.Items?.ToList() ?? [];

            if (Id.HasValue)
            {
                var invoice = await GetRecurringInvoiceCall.Call(new GetRecurringInvoice { Id = Id.Value });
                if (invoice != null)
                {
                    _model = new RecurringInvoiceFormModel
                    {
                        ClientId = invoice.ClientId.ToString(),
                        TemplateName = invoice.TemplateName,
                        Currency = invoice.Currency,
                        FrequencyInterval = invoice.FrequencyInterval,
                        Frequency = invoice.Frequency,
                        StartDate = invoice.StartDate,
                        EndDate = invoice.EndDate,
                        DueDays = invoice.DueDays,
                        TaxRate = invoice.TaxRate,
                        Notes = invoice.Notes,
                        Terms = invoice.Terms,
                        Footer = invoice.Footer,
                        LineItems = invoice.LineItems.Select(li => new LineItemModel
                        {
                            ProductId = li.ProductId,
                            Description = li.Description,
                            Quantity = li.Quantity,
                            UnitPrice = li.UnitPrice
                        }).ToList()
                    };
                }
            }
            else
            {
                _model.LineItems.Add(new LineItemModel());
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load data: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void AddLineItem()
    {
        _model.LineItems.Add(new LineItemModel());
    }

    private void RemoveLineItem(int index)
    {
        if (_model.LineItems.Count > 1)
        {
            _model.LineItems.RemoveAt(index);
        }
    }

    private void AddProductToLine(int index, ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out var productId))
        {
            var product = _products.FirstOrDefault(p => p.Id == productId);
            if (product != null)
            {
                _model.LineItems[index].ProductId = productId;
                _model.LineItems[index].Description = product.Name + (product.Description != null ? $" - {product.Description}" : "");
                _model.LineItems[index].UnitPrice = product.UnitPrice;
                _model.LineItems[index].Quantity = product.DefaultQuantity;
            }
        }
    }

    private async Task HandleSubmit()
    {
        if (!Id.HasValue && (string.IsNullOrEmpty(_model.ClientId) || !Guid.TryParse(_model.ClientId, out var clientId)))
        {
            _errorMessage = "Please select a client";
            return;
        }

        if (string.IsNullOrEmpty(_model.TemplateName))
        {
            _errorMessage = "Please enter a template name";
            return;
        }

        if (!_model.LineItems.Any(li => !string.IsNullOrEmpty(li.Description)))
        {
            _errorMessage = "Please add at least one line item";
            return;
        }

        _isSaving = true;
        _errorMessage = null;

        try
        {
            if (Id.HasValue)
            {
                var updateLineItems = _model.LineItems
                    .Where(li => !string.IsNullOrEmpty(li.Description))
                    .Select(li => new UpdateRecurringInvoiceLineItem
                    {
                        ProductId = li.ProductId,
                        Description = li.Description,
                        Quantity = li.Quantity,
                        UnitPrice = li.UnitPrice
                    }).ToList();

                await UpdateRecurringInvoiceCall.Call(new UpdateRecurringInvoice
                {
                    Id = Id.Value,
                    TemplateName = _model.TemplateName,
                    FrequencyInterval = _model.FrequencyInterval,
                    Frequency = _model.Frequency,
                    StartDate = _model.StartDate,
                    EndDate = _model.EndDate,
                    DueDays = _model.DueDays,
                    TaxRate = _model.TaxRate,
                    Notes = _model.Notes,
                    Terms = _model.Terms,
                    Footer = _model.Footer,
                    LineItems = updateLineItems
                });
                NavigationManager.NavigateTo($"recurring-invoices/{Id.Value}");
            }
            else
            {
                var createLineItems = _model.LineItems
                    .Where(li => !string.IsNullOrEmpty(li.Description))
                    .Select(li => new CreateRecurringInvoiceLineItem
                    {
                        ProductId = li.ProductId,
                        Description = li.Description,
                        Quantity = li.Quantity,
                        UnitPrice = li.UnitPrice
                    }).ToList();

                var newId = await CreateRecurringInvoiceCall.Call(new CreateRecurringInvoice
                {
                    ClientId = Guid.Parse(_model.ClientId),
                    TemplateName = _model.TemplateName,
                    Currency = _model.Currency,
                    FrequencyInterval = _model.FrequencyInterval,
                    Frequency = _model.Frequency,
                    StartDate = _model.StartDate,
                    EndDate = _model.EndDate,
                    DueDays = _model.DueDays,
                    TaxRate = _model.TaxRate,
                    Notes = _model.Notes,
                    Terms = _model.Terms,
                    Footer = _model.Footer,
                    LineItems = createLineItems
                });
                NavigationManager.NavigateTo($"recurring-invoices/{newId}");
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            _isSaving = false;
        }
    }

    public class RecurringInvoiceFormModel
    {
        [Required(ErrorMessage = "Client is required")]
        public string ClientId { get; set; } = "";

        [Required(ErrorMessage = "Template name is required")]
        [StringLength(200, ErrorMessage = "Name cannot exceed 200 characters")]
        public string TemplateName { get; set; } = "";

        public string Currency { get; set; } = "GBP";

        [Range(1, 365, ErrorMessage = "Interval must be between 1 and 365")]
        public int FrequencyInterval { get; set; } = 1;

        public string Frequency { get; set; } = "Month";

        public DateOnly StartDate { get; set; } = DateOnly.FromDateTime(DateTime.Today);

        public DateOnly? EndDate { get; set; }

        [Range(0, 365, ErrorMessage = "Due days must be between 0 and 365")]
        public int DueDays { get; set; } = 30;

        [Range(0, 100, ErrorMessage = "Tax rate must be between 0 and 100")]
        public decimal TaxRate { get; set; }

        public string? Notes { get; set; }

        public string? Terms { get; set; }

        public string? Footer { get; set; }

        public List<LineItemModel> LineItems { get; set; } = [];
    }

    public class LineItemModel
    {
        public Guid? ProductId { get; set; }
        public string Description { get; set; } = "";
        public decimal Quantity { get; set; } = 1;
        public decimal UnitPrice { get; set; } = 0;
    }
}
