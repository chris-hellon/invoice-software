@page "/clients/{Id:guid}"

@inject ICall<GetClient, ClientDetailDto> GetClientCall
@inject ICall<GetProjects, PaginatedResponse<ProjectDto>> GetProjectsCall
@inject ICall<DeleteClient> DeleteClientCall

<PageTitle>@(_client != null ? _client.Name : "Client") - InvoicePro</PageTitle>

<div class="space-y-6">
    <!-- Header with Breadcrumbs -->
    <PageHeader Title="@(_client != null ? _client.Name : "Client")"
                Description="@(_client != null && !string.IsNullOrEmpty(_client.CompanyName) ? _client.CompanyName : null)"
                ShowBackButton="true"
                BackUrl="clients"
                Breadcrumbs="@_breadcrumbs">
        @if (_client != null)
        {
            <div class="flex items-center gap-3">
                <a href="clients/@Id/edit" class="btn-secondary">
                    <EditIcon />
                    Edit Client
                </a>
                <button @onclick="DeleteClientAsync" disabled="@_isDeleting"
                        class="inline-flex items-center gap-2 px-4 py-2.5 text-sm font-medium text-red-700 dark:text-red-300 bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 rounded-xl hover:bg-red-100 dark:hover:bg-red-900/50 transition-all duration-200 disabled:opacity-50 disabled:cursor-not-allowed">
                    @if (_isDeleting)
                    {
                        <div class="w-4 h-4 border-2 border-red-300 border-t-red-600 rounded-full animate-spin"></div>
                    }
                    else
                    {
                        <DeleteIcon />
                    }
                    Delete
                </button>
            </div>
        }
    </PageHeader>

    @if (_isLoading)
    {
        <div class="flex justify-center py-20">
            <div class="w-8 h-8 border-2 border-gray-200 border-t-indigo-600 rounded-full animate-spin"></div>
        </div>
    }
    else if (_client == null)
    {
        <div class="card">
            <div class="text-center py-16 px-6">
                <div class="mx-auto w-16 h-16 rounded-2xl flex items-center justify-center mb-4"
                     style="background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);">
                    <svg class="h-8 w-8 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
                <h3 class="text-base font-semibold text-gray-900 dark:text-slate-100">Client not found</h3>
                <p class="mt-1 text-sm text-gray-500 dark:text-slate-400">The requested client could not be found.</p>
                <div class="mt-6">
                    <a href="clients" class="btn-primary">Back to Clients</a>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Client Info Column -->
            <div class="space-y-6">
                <!-- Status & Rate Card -->
                <div class="card overflow-hidden">
                    <div class="p-6">
                        <div class="flex items-center justify-between mb-6">
                            @if (_client.IsActive)
                            {
                                <span class="badge-success">Active</span>
                            }
                            else
                            {
                                <span class="badge-neutral">Inactive</span>
                            }
                        </div>
                        <div class="text-center py-4">
                            <div class="mx-auto w-20 h-20 rounded-full flex items-center justify-center text-white text-3xl font-bold mb-4"
                                 style="background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%); box-shadow: 0 8px 24px rgba(99, 102, 241, 0.35);">
                                @_client.Name[0].ToString().ToUpper()
                            </div>
                            <div class="text-3xl font-bold text-gray-900 dark:text-slate-100" style="font-family: 'Plus Jakarta Sans', sans-serif;">
                                @CurrencyExtensions.GetSymbol(_client.Currency)@_client.DefaultHourlyRate.ToString("N2")
                            </div>
                            <div class="text-sm text-gray-500 dark:text-slate-400 mt-1">per hour (@_client.Currency)</div>
                        </div>
                    </div>
                </div>

                <!-- Contact Info Card -->
                <div class="card overflow-hidden">
                    <div class="card-header">
                        <h3 class="text-sm font-semibold text-gray-900 dark:text-slate-100">Contact Information</h3>
                    </div>
                    <div class="p-6 space-y-5">
                        <div class="flex items-start gap-4">
                            <div class="p-2 rounded-lg bg-gray-50 dark:bg-slate-700">
                                <svg class="w-5 h-5 text-gray-400 dark:text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                                </svg>
                            </div>
                            <div>
                                <div class="text-xs text-gray-500 dark:text-slate-500 mb-1">Email</div>
                                <a href="mailto:@_client.Email" class="text-sm text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 font-medium">@_client.Email</a>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(_client.Phone))
                        {
                            <div class="flex items-start gap-4">
                                <div class="p-2 rounded-lg bg-gray-50 dark:bg-slate-700">
                                    <svg class="w-5 h-5 text-gray-400 dark:text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                                    </svg>
                                </div>
                                <div>
                                    <div class="text-xs text-gray-500 dark:text-slate-500 mb-1">Phone</div>
                                    <a href="tel:@_client.Phone" class="text-sm text-gray-900 dark:text-slate-200">@_client.Phone</a>
                                </div>
                            </div>
                        }
                        @if (HasAddress)
                        {
                            <div class="flex items-start gap-4">
                                <div class="p-2 rounded-lg bg-gray-50 dark:bg-slate-700">
                                    <svg class="w-5 h-5 text-gray-400 dark:text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                                    </svg>
                                </div>
                                <div>
                                    <div class="text-xs text-gray-500 dark:text-slate-500 mb-1">Address</div>
                                    <div class="text-sm text-gray-900 dark:text-slate-200 space-y-0.5">
                                        @if (!string.IsNullOrEmpty(_client.Street))
                                        {
                                            <div>@_client.Street</div>
                                        }
                                        @if (!string.IsNullOrEmpty(_client.City) || !string.IsNullOrEmpty(_client.State) || !string.IsNullOrEmpty(_client.PostalCode))
                                        {
                                            <div>@_client.City@(string.IsNullOrEmpty(_client.State) ? "" : $", {_client.State}") @_client.PostalCode</div>
                                        }
                                        @if (!string.IsNullOrEmpty(_client.Country))
                                        {
                                            <div>@_client.Country</div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Projects Column -->
            <div class="lg:col-span-2">
                <div class="card overflow-hidden">
                    <div class="card-header flex items-center justify-between">
                        <div>
                            <h3 class="text-sm font-semibold text-gray-900 dark:text-slate-100">Projects</h3>
                            <p class="text-xs text-gray-500 dark:text-slate-400 mt-0.5">@_client.ActiveProjectCount active of @_client.ProjectCount total</p>
                        </div>
                        <a href="projects/new" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 hover:bg-indigo-50 dark:hover:bg-indigo-900/50 rounded-lg transition-colors">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                            </svg>
                            Add Project
                        </a>
                    </div>
                    @if (_projects == null || !_projects.Any())
                    {
                        <div class="text-center py-12 px-6">
                            <div class="mx-auto w-14 h-14 rounded-2xl flex items-center justify-center mb-4"
                                 style="background: linear-gradient(135deg, #eef2ff 0%, #e0e7ff 100%);">
                                <svg class="h-7 w-7 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
                                </svg>
                            </div>
                            <p class="text-sm text-gray-500 dark:text-slate-400">No projects yet</p>
                        </div>
                    }
                    else
                    {
                        <div class="divide-y divide-gray-100 dark:divide-slate-700">
                            @foreach (var project in _projects)
                            {
                                <a href="projects/@project.Id" class="flex items-center justify-between px-6 py-4 hover:bg-gray-50 dark:hover:bg-[#2d2a4a]/50 transition-colors group">
                                    <div class="min-w-0 flex-1">
                                        <div class="flex items-center gap-3">
                                            <span class="font-medium text-gray-900 dark:text-slate-100 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">@project.Name</span>
                                            <span class="@ProjectStatusExtensions.Parse(project.Status).GetSmallBadgeClass()">@ProjectStatusExtensions.Parse(project.Status).GetDisplayName()</span>
                                        </div>
                                        @if (!string.IsNullOrEmpty(project.Description))
                                        {
                                            <p class="text-sm text-gray-500 dark:text-slate-400 truncate mt-0.5">@project.Description</p>
                                        }
                                    </div>
                                    <div class="ml-4 flex items-center gap-4">
                                        <span class="text-sm text-gray-500 dark:text-slate-400">@project.JobCount jobs</span>
                                        <svg class="w-4 h-4 text-gray-400 dark:text-slate-500 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                        </svg>
                                    </div>
                                </a>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private ClientDetailDto? _client;
    private List<ProjectDto>? _projects;
    private bool _isLoading = true;
    private bool _isDeleting;
    private List<PageHeader.BreadcrumbItem> _breadcrumbs = [];

    private bool HasAddress => (_client != null && !string.IsNullOrEmpty(_client.Street)) ||
                               (_client != null && !string.IsNullOrEmpty(_client.City)) ||
                               (_client != null && !string.IsNullOrEmpty(_client.State)) ||
                               (_client != null && !string.IsNullOrEmpty(_client.PostalCode)) ||
                               (_client != null && !string.IsNullOrEmpty(_client.Country));

    protected override async Task OnInitializedAsync()
    {
        _breadcrumbs =
        [
            new PageHeader.BreadcrumbItem("Clients", "/clients"),
            new PageHeader.BreadcrumbItem("Client Details")
        ];

        try
        {
            _client = await GetClientCall.Call(new GetClient { Id = Id });
            if (_client != null)
            {
                _breadcrumbs[1] = new PageHeader.BreadcrumbItem(_client.Name);
                var projectsResponse = await GetProjectsCall.Call(new GetProjects { ClientId = Id, PageSize = 1000 });
                _projects = projectsResponse?.Items ?? [];
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading client: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task DeleteClientAsync()
    {
        var confirmed = await ModalService.ShowAsync<bool>(
            typeof(DeleteConfirmationModal),
            "Delete Client",
            new Dictionary<string, object>
            {
                { "ItemName", _client?.Name ?? "this client" },
                { "WarningMessage", "This will deactivate the client. Associated projects and data will be preserved." }
            },
            new ModalOptions { Size = ModalSize.Small });

        if (!confirmed) return;

        _isDeleting = true;

        try
        {
            await DeleteClientCall.Call(new DeleteClient { Id = Id });
            NavigationManager.NavigateTo("clients");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting client: {ex.Message}");
        }
        finally
        {
            _isDeleting = false;
        }
    }
}
