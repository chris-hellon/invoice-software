@page "/clients/new"
@page "/clients/{Id:guid}/edit"

@inject ICall<GetClient, ClientDetailDto> GetClientCall
@inject ICall<CreateClient, Guid> CreateClientCall
@inject ICall<UpdateClient> UpdateClientCall

<PageTitle>@(Id.HasValue ? "Edit Client" : "New Client") - InvoicePro</PageTitle>

<div class="space-y-6">
    <!-- Header with Breadcrumbs -->
    <PageHeader Title="@(Id.HasValue ? "Edit Client" : "New Client")"
                Description="@(Id.HasValue ? "Update client information" : "Add a new client to your account")"
                ShowBackButton="true"
                BackUrl="clients"
                Breadcrumbs="@_breadcrumbs" />

    @if (_isLoading)
    {
        <LoadingSpinner Padding="py-20" />
    }
    else
    {
        <EditForm Model="_model" OnValidSubmit="HandleSubmit" class="space-y-6">
            <DataAnnotationsValidator />

            <!-- Basic Information Section -->
            <Card Title="Basic Information" Description="Primary contact details for this client.">
                    <div>
                        <label for="name" class="block text-sm font-medium text-gray-700 mb-2">Client Name <span class="text-red-500">*</span></label>
                        <InputText id="name" @bind-Value="_model.Name"
                            class="w-full px-4 py-3 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl transition-all duration-200 placeholder:text-gray-400 focus:outline-none focus:border-indigo-400 focus:ring-4 focus:ring-indigo-500/10 hover:border-gray-300"
                            placeholder="John Smith" />
                        <ValidationMessage For="@(() => _model.Name)" class="mt-1.5 text-xs text-red-600" />
                    </div>

                    <div>
                        <label for="companyName" class="block text-sm font-medium text-gray-700 mb-2">Company Name</label>
                        <InputText id="companyName" @bind-Value="_model.CompanyName"
                            class="w-full px-4 py-3 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl transition-all duration-200 placeholder:text-gray-400 focus:outline-none focus:border-indigo-400 focus:ring-4 focus:ring-indigo-500/10 hover:border-gray-300"
                            placeholder="Acme Inc." />
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                        <div>
                            <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Email <span class="text-red-500">*</span></label>
                            <InputText id="email" @bind-Value="_model.Email" type="email"
                                class="w-full px-4 py-3 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl transition-all duration-200 placeholder:text-gray-400 focus:outline-none focus:border-indigo-400 focus:ring-4 focus:ring-indigo-500/10 hover:border-gray-300"
                                placeholder="john@example.com" />
                            <ValidationMessage For="@(() => _model.Email)" class="mt-1.5 text-xs text-red-600" />
                        </div>

                        <div>
                            <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">Phone</label>
                            <InputText id="phone" @bind-Value="_model.Phone"
                                class="w-full px-4 py-3 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl transition-all duration-200 placeholder:text-gray-400 focus:outline-none focus:border-indigo-400 focus:ring-4 focus:ring-indigo-500/10 hover:border-gray-300"
                                placeholder="+1 (555) 000-0000" />
                        </div>
                    </div>
            </Card>

            <!-- Billing Section -->
            <Card Title="Billing" Description="Default billing rate and address.">
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
                        <div>
                            <label for="currency" class="block text-sm font-medium text-gray-700 mb-2">Currency <span class="text-red-500">*</span></label>
                            <InputSelect id="currency" @bind-Value="_model.Currency"
                                class="w-full px-4 py-3 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl transition-all duration-200 focus:outline-none focus:border-indigo-400 focus:ring-4 focus:ring-indigo-500/10 hover:border-gray-300 cursor-pointer">
                                @foreach (var currency in Enum.GetValues<Currency>())
                                {
                                    <option value="@currency.ToString()">@currency.ToString() (@currency.GetSymbol())</option>
                                }
                            </InputSelect>
                        </div>

                        <div>
                            <label for="hourlyRate" class="block text-sm font-medium text-gray-700 mb-2">Hourly Rate <span class="text-red-500">*</span></label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                    <span class="text-gray-500 text-sm">@CurrencyExtensions.GetSymbol(_model.Currency)</span>
                                </div>
                                <InputNumber id="hourlyRate" @bind-Value="_model.DefaultHourlyRate"
                                    class="w-full pl-8 pr-16 py-3 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl transition-all duration-200 focus:outline-none focus:border-indigo-400 focus:ring-4 focus:ring-indigo-500/10 hover:border-gray-300" />
                                <div class="absolute inset-y-0 right-0 pr-4 flex items-center pointer-events-none">
                                    <span class="text-gray-400 text-sm">/ hour</span>
                                </div>
                            </div>
                            <ValidationMessage For="@(() => _model.DefaultHourlyRate)" class="mt-1.5 text-xs text-red-600" />
                        </div>

                        <div class="flex items-end pb-1">
                            <label class="relative flex items-center gap-3 cursor-pointer group">
                                <div class="relative">
                                    <InputCheckbox id="isActive" @bind-Value="_model.IsActive" class="sr-only peer" />
                                    <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all after:shadow-sm peer-checked:bg-indigo-600"></div>
                                </div>
                                <span class="text-sm font-medium text-gray-700 group-hover:text-gray-900">Active Client</span>
                            </label>
                        </div>
                    </div>

                    <hr class="border-gray-100" />

                    <div>
                        <label for="street" class="block text-sm font-medium text-gray-700 mb-2">Street Address</label>
                        <InputText id="street" @bind-Value="_model.Street"
                            class="w-full px-4 py-3 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl transition-all duration-200 placeholder:text-gray-400 focus:outline-none focus:border-indigo-400 focus:ring-4 focus:ring-indigo-500/10 hover:border-gray-300"
                            placeholder="123 Main Street" />
                    </div>

                    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
                        <div class="col-span-2 sm:col-span-1">
                            <label for="city" class="block text-sm font-medium text-gray-700 mb-2">City</label>
                            <InputText id="city" @bind-Value="_model.City"
                                class="w-full px-4 py-3 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl transition-all duration-200 focus:outline-none focus:border-indigo-400 focus:ring-4 focus:ring-indigo-500/10 hover:border-gray-300" />
                        </div>

                        <div>
                            <label for="state" class="block text-sm font-medium text-gray-700 mb-2">State</label>
                            <InputText id="state" @bind-Value="_model.State"
                                class="w-full px-4 py-3 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl transition-all duration-200 focus:outline-none focus:border-indigo-400 focus:ring-4 focus:ring-indigo-500/10 hover:border-gray-300" />
                        </div>

                        <div>
                            <label for="postalCode" class="block text-sm font-medium text-gray-700 mb-2">Postal Code</label>
                            <InputText id="postalCode" @bind-Value="_model.PostalCode"
                                class="w-full px-4 py-3 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl transition-all duration-200 focus:outline-none focus:border-indigo-400 focus:ring-4 focus:ring-indigo-500/10 hover:border-gray-300" />
                        </div>

                        <div class="col-span-2 sm:col-span-1">
                            <label for="country" class="block text-sm font-medium text-gray-700 mb-2">Country</label>
                            <InputText id="country" @bind-Value="_model.Country"
                                class="w-full px-4 py-3 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl transition-all duration-200 focus:outline-none focus:border-indigo-400 focus:ring-4 focus:ring-indigo-500/10 hover:border-gray-300" />
                        </div>
                    </div>
            </Card>

            <!-- Error Message -->
            <ErrorAlert Message="@_errorMessage" />

            <!-- Actions -->
            <div class="flex items-center justify-end gap-3 pt-4">
                <a href="clients" class="px-5 py-2.5 text-sm font-medium text-gray-700 bg-white border border-gray-200 rounded-xl hover:bg-gray-50 hover:border-gray-300 transition-all duration-200">
                    Cancel
                </a>
                <PrimaryButton ButtonType="submit"
                               Text="@(Id.HasValue ? "Save Changes" : "Create Client")"
                               IsLoading="@_isSaving"
                               ShowIcon="false" />
            </div>
        </EditForm>
    }
</div>

@code {
    [Parameter]
    public Guid? Id { get; set; }

    private ClientFormModel _model = new();
    private bool _isLoading;
    private bool _isSaving;
    private string? _errorMessage;
    private List<PageHeader.BreadcrumbItem> _breadcrumbs = [];

    protected override async Task OnInitializedAsync()
    {
        _breadcrumbs =
        [
            new PageHeader.BreadcrumbItem("Clients", "/clients"),
            new PageHeader.BreadcrumbItem(Id.HasValue ? "Edit Client" : "New Client")
        ];

        if (Id.HasValue)
        {
            _isLoading = true;
            try
            {
                var client = await GetClientCall.Call(new GetClient { Id = Id.Value });
                if (client != null)
                {
                    _model = new ClientFormModel
                    {
                        Name = client.Name,
                        CompanyName = client.CompanyName,
                        Email = client.Email,
                        Phone = client.Phone,
                        DefaultHourlyRate = client.DefaultHourlyRate,
                        Currency = client.Currency,
                        IsActive = client.IsActive,
                        Street = client.Street,
                        City = client.City,
                        State = client.State,
                        PostalCode = client.PostalCode,
                        Country = client.Country
                    };
                }
            }
            catch (Exception ex)
            {
                _errorMessage = $"Failed to load client: {ex.Message}";
            }
            finally
            {
                _isLoading = false;
            }
        }
        else
        {
            _model.IsActive = true;
            _model.DefaultHourlyRate = 100;
        }
    }

    private async Task HandleSubmit()
    {
        _isSaving = true;
        _errorMessage = null;

        try
        {
            if (Id.HasValue)
            {
                await UpdateClientCall.Call(new UpdateClient
                {
                    Id = Id.Value,
                    Name = _model.Name,
                    CompanyName = _model.CompanyName,
                    Email = _model.Email,
                    Phone = _model.Phone,
                    DefaultHourlyRate = _model.DefaultHourlyRate,
                    Currency = _model.Currency,
                    IsActive = _model.IsActive,
                    Street = _model.Street,
                    City = _model.City,
                    State = _model.State,
                    PostalCode = _model.PostalCode,
                    Country = _model.Country
                });
            }
            else
            {
                await CreateClientCall.Call(new CreateClient
                {
                    Name = _model.Name,
                    CompanyName = _model.CompanyName,
                    Email = _model.Email,
                    Phone = _model.Phone,
                    DefaultHourlyRate = _model.DefaultHourlyRate,
                    Currency = _model.Currency,
                    Street = _model.Street,
                    City = _model.City,
                    State = _model.State,
                    PostalCode = _model.PostalCode,
                    Country = _model.Country
                });
            }
            NavigationManager.NavigateTo("clients");
        }
        catch (Exception ex)
        {
            _errorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            _isSaving = false;
        }
    }

    public class ClientFormModel
    {
        [Required(ErrorMessage = "Name is required")]
        [StringLength(200, ErrorMessage = "Name cannot exceed 200 characters")]
        public string Name { get; set; } = "";

        [StringLength(200)]
        public string? CompanyName { get; set; }

        [Required(ErrorMessage = "Email is required")]
        [EmailAddress(ErrorMessage = "Invalid email address")]
        [StringLength(256)]
        public string Email { get; set; } = "";

        [StringLength(20)]
        public string? Phone { get; set; }

        [Required(ErrorMessage = "Hourly rate is required")]
        [Range(0.01, 10000000, ErrorMessage = "Hourly rate must be between 0.01 and 10,000,000")]
        public decimal DefaultHourlyRate { get; set; }

        [Required]
        public string Currency { get; set; } = "GBP";

        public bool IsActive { get; set; } = true;

        public string? Street { get; set; }
        public string? City { get; set; }
        public string? State { get; set; }
        public string? PostalCode { get; set; }
        public string? Country { get; set; }
    }
}
