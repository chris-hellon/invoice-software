@page "/clients"

@inject ICall<GetClients, PaginatedResponse<ClientDto>> GetClientsCall
@inject ICall<DeleteClient> DeleteClientCall

<PageTitle>Clients - InvoicePro</PageTitle>

<ListPageLayout Title="Clients"
                Description="Manage your client relationships and billing information."
                ActionUrl="clients/new"
                ActionText="Add Client"
                SearchPlaceholder="Search by name, company, or email..."
                SearchValue="@_searchTerm"
                SearchValueChanged="OnSearchChanged"
                Breadcrumbs="@(new List<PageHeader.BreadcrumbItem> { new("Clients") })">
    <Filters>
        <select @bind="_showInactive" @bind:after="OnFilterChanged" class="py-3 px-4 text-sm text-gray-700 dark:text-slate-200 bg-gray-50 dark:bg-slate-700 border-0 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500/20 cursor-pointer">
            <option value="false">Active clients</option>
            <option value="true">All clients</option>
        </select>
    </Filters>
    <ChildContent>
        @if (_isLoading)
        {
            <LoadingGrid Variant="LoadingGrid.LoadingGridVariant.ClientCard" />
        }
        else if (_response == null || !_response.Items.Any())
        {
            <EmptyState Title="No clients found"
                        Message="@(HasActiveFilters ? "No clients match your filters. Try adjusting your search." : "Get started by adding your first client.")"
                        IconType="EmptyState.EmptyStateIcon.Users"
                        ActionUrl="@(HasActiveFilters ? null : "clients/new")"
                        ActionText="@(HasActiveFilters ? null : "Add Client")" />
        }
        else
        {
            <CardGrid>
                @foreach (var client in _response.Items)
                {
                    <EntityCard Href="@($"clients/{client.Id}")"
                                Title="@client.Name"
                                Subtitle="@client.CompanyName"
                                AvatarText="@client.Name[..1]">
                        <BadgeTemplate>
                            @if (client.IsActive)
                            {
                                <span class="inline-flex items-center px-2.5 py-1 text-xs font-medium rounded-lg bg-emerald-50 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400 ring-1 ring-inset ring-emerald-600/20">Active</span>
                            }
                            else
                            {
                                <span class="inline-flex items-center px-2.5 py-1 text-xs font-medium rounded-lg bg-gray-50 dark:bg-slate-700 text-gray-600 dark:text-slate-400 ring-1 ring-inset ring-gray-500/20 dark:ring-slate-500/30">Inactive</span>
                            }
                        </BadgeTemplate>
                        <DetailsTemplate>
                            <div class="space-y-2.5">
                                <div class="flex items-center gap-3 text-sm">
                                    <svg class="w-4 h-4 text-gray-400 dark:text-slate-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                                    </svg>
                                    <span class="text-gray-600 dark:text-slate-300 truncate">@client.Email</span>
                                </div>
                                @if (!string.IsNullOrEmpty(client.Phone))
                                {
                                    <div class="flex items-center gap-3 text-sm">
                                        <svg class="w-4 h-4 text-gray-400 dark:text-slate-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                                        </svg>
                                        <span class="text-gray-600 dark:text-slate-300">@client.Phone</span>
                                    </div>
                                }
                            </div>
                        </DetailsTemplate>
                        <FooterTemplate>
                            <div class="text-sm">
                                <span class="text-gray-500 dark:text-slate-400">Rate:</span>
                                <span class="font-semibold text-gray-900 dark:text-slate-100 ml-1">@CurrencyExtensions.GetSymbol(client.Currency)@client.DefaultHourlyRate.ToString("N2")</span>
                                <span class="text-gray-400 dark:text-slate-500">/hr</span>
                            </div>
                        </FooterTemplate>
                        <ActionsTemplate>
                            <IconButton Href="@($"clients/{client.Id}/edit")" Title="Edit">
                                <EditIcon />
                            </IconButton>
                            <IconButton OnClick="() => DeleteClientAsync(client)" Variant="IconButton.IconButtonVariant.Danger" Title="Delete">
                                <DeleteIcon />
                            </IconButton>
                        </ActionsTemplate>
                    </EntityCard>
                }
            </CardGrid>

            <Pagination CurrentPage="_response.Page"
                        TotalItems="_response.TotalCount"
                        PageSize="_response.PageSize"
                        ItemName="clients"
                        OnPageChanged="OnPageChanged" />
        }
    </ChildContent>
</ListPageLayout>

@code {
    private PaginatedResponse<ClientDto>? _response;
    private bool _isLoading = true;
    private string _searchTerm = "";
    private bool _showInactive;
    private int _currentPage = 1;
    private const int PageSize = 12;

    private bool HasActiveFilters => !string.IsNullOrEmpty(_searchTerm);

    protected override async Task OnInitializedAsync()
    {
        await LoadClients();
    }

    private async Task LoadClients()
    {
        _isLoading = true;
        try
        {
            _response = await GetClientsCall.Call(new GetClients
            {
                ActiveOnly = !_showInactive,
                Page = _currentPage,
                PageSize = PageSize,
                Search = _searchTerm
            });
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading clients: {ex.Message}");
            _response = new PaginatedResponse<ClientDto>();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnFilterChanged()
    {
        _currentPage = 1;
        await LoadClients();
    }

    private async Task OnPageChanged(int page)
    {
        _currentPage = page;
        await LoadClients();
    }

    private async Task OnSearchChanged(string value)
    {
        _searchTerm = value;
        _currentPage = 1;
        await LoadClients();
    }

    private async Task DeleteClientAsync(ClientDto client)
    {
        var confirmed = await ModalService.ShowAsync<bool>(
            typeof(DeleteConfirmationModal),
            "Delete Client",
            new Dictionary<string, object>
            {
                { "ItemName", client.Name },
                { "WarningMessage", "This will deactivate the client. Associated projects and data will be preserved." }
            },
            new ModalOptions { Size = ModalSize.Small });

        if (!confirmed) return;

        try
        {
            await DeleteClientCall.Call(new DeleteClient { Id = client.Id });
            await LoadClients();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting client: {ex.Message}");
        }
    }
}
