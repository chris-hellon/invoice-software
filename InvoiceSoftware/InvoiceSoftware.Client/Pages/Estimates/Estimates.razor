@page "/estimates"

@inject ICall<GetEstimates, PaginatedResponse<EstimateSummaryDto>> GetEstimatesCall
@inject ICall<DeleteEstimate> DeleteEstimateCall

<PageTitle>Estimates - InvoicePro</PageTitle>

<ListPageLayout Title="Estimates"
                Description="Create and manage quotes and estimates for your clients."
                ActionUrl="estimates/new"
                ActionText="New Estimate"
                SearchPlaceholder="Search by estimate number or client..."
                SearchValue="@_searchTerm"
                SearchValueChanged="OnSearchChanged"
                Breadcrumbs="@(new List<PageHeader.BreadcrumbItem> { new("Estimates") })">
    <Filters>
        <select @bind="_statusFilter" @bind:after="OnFilterChanged" class="py-3 px-4 text-sm text-gray-700 dark:text-slate-200 bg-gray-50 dark:bg-slate-700 border-0 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500/20 cursor-pointer">
            <option value="">All statuses</option>
            <option value="Draft">Draft</option>
            <option value="Sent">Sent</option>
            <option value="Accepted">Accepted</option>
            <option value="Rejected">Rejected</option>
            <option value="Expired">Expired</option>
            <option value="Converted">Converted</option>
        </select>
    </Filters>
    <ChildContent>
        @if (_isLoading)
        {
            <LoadingGrid Variant="LoadingGrid.LoadingGridVariant.Default" />
        }
        else if (_response == null || !_response.Items.Any())
        {
            <EmptyState Title="No estimates found"
                        Message="@(HasActiveFilters ? "No estimates match your filters. Try adjusting your search." : "Get started by creating your first estimate.")"
                        IconType="EmptyState.EmptyStateIcon.Document"
                        ActionUrl="@(HasActiveFilters ? null : "estimates/new")"
                        ActionText="@(HasActiveFilters ? null : "New Estimate")" />
        }
        else
        {
            <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-gray-100 dark:border-slate-700 overflow-hidden">
                <table class="min-w-full divide-y divide-gray-100 dark:divide-slate-700">
                    <thead class="bg-gray-50/50 dark:bg-slate-800/50">
                        <tr>
                            <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-gray-500 dark:text-slate-400 uppercase tracking-wider">Estimate</th>
                            <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-gray-500 dark:text-slate-400 uppercase tracking-wider">Client</th>
                            <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-gray-500 dark:text-slate-400 uppercase tracking-wider">Date</th>
                            <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-gray-500 dark:text-slate-400 uppercase tracking-wider">Status</th>
                            <th scope="col" class="px-6 py-4 text-right text-xs font-semibold text-gray-500 dark:text-slate-400 uppercase tracking-wider">Total</th>
                            <th scope="col" class="px-6 py-4 text-right text-xs font-semibold text-gray-500 dark:text-slate-400 uppercase tracking-wider">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100 dark:divide-slate-700">
                        @foreach (var estimate in _response.Items)
                        {
                            <tr class="hover:bg-gray-50/50 dark:hover:bg-slate-700/50 transition-colors cursor-pointer" @onclick="() => NavigateTo(estimate.Id)">
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="text-sm font-semibold text-gray-900 dark:text-slate-100">@estimate.EstimateNumber</div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="text-sm text-gray-700 dark:text-slate-300">@estimate.ClientName</div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="text-sm text-gray-600 dark:text-slate-400">@estimate.EstimateDate.ToString("MMM dd, yyyy")</div>
                                    @if (estimate.ExpiryDate.HasValue)
                                    {
                                        <div class="text-xs text-gray-400 dark:text-slate-500">Expires: @estimate.ExpiryDate.Value.ToString("MMM dd, yyyy")</div>
                                    }
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    @{
                                        var (bgClass, textClass) = GetStatusClasses(estimate.Status);
                                    }
                                    <span class="inline-flex items-center px-2.5 py-1 text-xs font-medium rounded-lg @bgClass @textClass">
                                        @estimate.Status
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-right">
                                    <div class="text-sm font-semibold text-gray-900 dark:text-slate-100">@CurrencyExtensions.GetSymbol(estimate.Currency)@estimate.Total.ToString("N2")</div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-right" @onclick:stopPropagation="true">
                                    <div class="flex items-center justify-end gap-2">
                                        <IconButton Href="@($"estimates/{estimate.Id}")" Title="View">
                                            <ViewIcon />
                                        </IconButton>
                                        <IconButton Href="@($"estimates/{estimate.Id}/edit")" Title="Edit">
                                            <EditIcon />
                                        </IconButton>
                                        <IconButton OnClick="() => DeleteEstimateAsync(estimate)" Variant="IconButton.IconButtonVariant.Danger" Title="Delete">
                                            <DeleteIcon />
                                        </IconButton>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <Pagination CurrentPage="_response.Page"
                        TotalItems="_response.TotalCount"
                        PageSize="_response.PageSize"
                        ItemName="estimates"
                        OnPageChanged="OnPageChanged" />
        }
    </ChildContent>
</ListPageLayout>

@code {
    private PaginatedResponse<EstimateSummaryDto>? _response;
    private bool _isLoading = true;
    private string _searchTerm = "";
    private string _statusFilter = "";
    private int _currentPage = 1;
    private const int PageSize = 15;

    private bool HasActiveFilters => !string.IsNullOrEmpty(_searchTerm) || !string.IsNullOrEmpty(_statusFilter);

    protected override async Task OnInitializedAsync()
    {
        await LoadEstimates();
    }

    private async Task LoadEstimates()
    {
        _isLoading = true;
        try
        {
            _response = await GetEstimatesCall.Call(new GetEstimates
            {
                Status = string.IsNullOrEmpty(_statusFilter) ? null : _statusFilter,
                Page = _currentPage,
                PageSize = PageSize,
                Search = _searchTerm
            });
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading estimates: {ex.Message}");
            _response = new PaginatedResponse<EstimateSummaryDto>();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnFilterChanged()
    {
        _currentPage = 1;
        await LoadEstimates();
    }

    private async Task OnPageChanged(int page)
    {
        _currentPage = page;
        await LoadEstimates();
    }

    private async Task OnSearchChanged(string value)
    {
        _searchTerm = value;
        _currentPage = 1;
        await LoadEstimates();
    }

    private void NavigateTo(Guid id)
    {
        NavigationManager.NavigateTo($"estimates/{id}");
    }

    private (string bgClass, string textClass) GetStatusClasses(string status) => status switch
    {
        "Draft" => ("bg-gray-50 dark:bg-slate-700 ring-1 ring-inset ring-gray-500/20 dark:ring-slate-500/30", "text-gray-600 dark:text-slate-400"),
        "Sent" => ("bg-blue-50 dark:bg-blue-900/30 ring-1 ring-inset ring-blue-600/20", "text-blue-700 dark:text-blue-400"),
        "Accepted" => ("bg-emerald-50 dark:bg-emerald-900/30 ring-1 ring-inset ring-emerald-600/20", "text-emerald-700 dark:text-emerald-400"),
        "Rejected" => ("bg-red-50 dark:bg-red-900/30 ring-1 ring-inset ring-red-600/20", "text-red-700 dark:text-red-400"),
        "Expired" => ("bg-amber-50 dark:bg-amber-900/30 ring-1 ring-inset ring-amber-600/20", "text-amber-700 dark:text-amber-400"),
        "Converted" => ("bg-purple-50 dark:bg-purple-900/30 ring-1 ring-inset ring-purple-600/20", "text-purple-700 dark:text-purple-400"),
        _ => ("bg-gray-50 dark:bg-slate-700 ring-1 ring-inset ring-gray-500/20", "text-gray-600 dark:text-slate-400")
    };

    private async Task DeleteEstimateAsync(EstimateSummaryDto estimate)
    {
        var confirmed = await ModalService.ShowAsync<bool>(
            typeof(DeleteConfirmationModal),
            "Delete Estimate",
            new Dictionary<string, object>
            {
                { "ItemName", estimate.EstimateNumber },
                { "WarningMessage", "This will permanently delete this estimate. This action cannot be undone." }
            },
            new ModalOptions { Size = ModalSize.Small });

        if (!confirmed) return;

        try
        {
            await DeleteEstimateCall.Call(new DeleteEstimate { Id = estimate.Id });
            await LoadEstimates();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting estimate: {ex.Message}");
        }
    }
}
