@page "/estimates/{Id:guid}"

@inject ICall<GetEstimate, EstimateDetailDto?> GetEstimateCall
@inject ICall<GetBusinessProfile, BusinessProfileDto?> GetBusinessProfileCall
@inject ICall<GetBusinessLogo, byte[]?> GetBusinessLogoCall
@inject ICall<GetEstimatePdf, byte[]?> GetEstimatePdfCall
@inject ICall<SendEstimate> SendEstimateCall
@inject ICall<ConvertEstimateToInvoice, Guid> ConvertEstimateCall
@inject ICall<DeleteEstimate> DeleteEstimateCall
@inject IJSRuntime JS

<PageTitle>Estimate Details - InvoicePro</PageTitle>

<div class="space-y-6">
    <PageHeader Title="@(_estimate?.EstimateNumber ?? "Loading...")"
                Description="@(_estimate != null ? $"Estimate for {_estimate.ClientName}" : "")"
                ShowBackButton="true"
                BackUrl="estimates"
                Breadcrumbs="@_breadcrumbs">
        <Actions>
            @if (_estimate != null)
            {
                <div class="flex items-center gap-3">
                    <!-- PDF Download -->
                    <button @onclick="DownloadPdfAsync" disabled="@_isDownloading"
                        class="inline-flex items-center gap-2 px-4 py-2.5 text-sm font-medium text-gray-700 dark:text-slate-300 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-600 rounded-xl hover:bg-gray-50 dark:hover:bg-slate-700 transition-all duration-200 disabled:opacity-50">
                        @if (_isDownloading)
                        {
                            <div class="w-4 h-4 border-2 border-gray-300 border-t-gray-600 rounded-full animate-spin"></div>
                        }
                        else
                        {
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                            </svg>
                        }
                        PDF
                    </button>

                    @if (_estimate.Status == "Draft")
                    {
                        <button @onclick="SendEstimateAsync" disabled="@_isSending"
                            class="inline-flex items-center gap-2 px-4 py-2.5 text-sm font-medium text-gray-700 dark:text-slate-300 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-600 rounded-xl hover:bg-gray-50 dark:hover:bg-slate-700 transition-all duration-200 disabled:opacity-50">
                            @if (_isSending)
                            {
                                <div class="w-4 h-4 border-2 border-gray-300 border-t-gray-600 rounded-full animate-spin"></div>
                            }
                            else
                            {
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                                </svg>
                            }
                            Send
                        </button>
                        <PrimaryButton Href="@($"estimates/{Id}/edit")" Text="Edit" ShowIcon="false" />
                    }
                    @if (_estimate.Status == "Sent" || _estimate.Status == "Accepted")
                    {
                        <PrimaryButton Text="Convert to Invoice" OnClick="ConvertToInvoiceAsync" IsLoading="_isConverting" ShowIcon="false" />
                    }
                </div>
            }
        </Actions>
    </PageHeader>

    @if (_isLoading)
    {
        <LoadingSpinner Padding="py-20" />
    }
    else if (_estimate == null)
    {
        <EmptyState Title="Estimate not found"
                    Message="The estimate you're looking for doesn't exist or has been deleted."
                    IconType="EmptyState.EmptyStateIcon.Document"
                    ActionUrl="estimates"
                    ActionText="Back to Estimates" />
    }
    else
    {
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Main Content - Estimate View -->
            <div class="lg:col-span-2">
                <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-xl border border-gray-100 dark:border-slate-700 overflow-hidden">
                    <EstimateViewContent
                        EstimateNumber="@_estimate.EstimateNumber"
                        Status="@_estimate.Status"
                        Currency="@_estimate.Currency"
                        EstimateDate="@_estimate.EstimateDate"
                        ExpiryDate="@_estimate.ExpiryDate"
                        AcceptedDate="@_estimate.AcceptedDate"
                        RejectedDate="@_estimate.RejectedDate"
                        BusinessName="@(_businessProfile?.TradingName ?? _businessProfile?.CompanyName)"
                        BusinessAddress="@GetBusinessAddress()"
                        BusinessEmail="@_businessProfile?.Email"
                        BusinessPhone="@_businessProfile?.Phone"
                        BusinessLogo="@_businessLogo"
                        TaxNumber="@_businessProfile?.TaxNumber"
                        RegistrationNumber="@_businessProfile?.RegistrationNumber"
                        ClientName="@_estimate.ClientName"
                        ClientCompanyName="@_estimate.ClientCompanyName"
                        ClientAddress="@GetClientAddress()"
                        ClientEmail="@_estimate.ClientEmail"
                        Subtotal="@_estimate.Subtotal"
                        TaxRate="@_estimate.TaxRate"
                        TaxAmount="@_estimate.TaxAmount"
                        Total="@_estimate.Total"
                        Notes="@_estimate.Notes"
                        Terms="@_estimate.Terms"
                        LineItems="@_estimate.LineItems"
                        PrimaryColor="@PrimaryColor"
                        AccentColor="@AccentColor"
                        ShowLogo="@ShowLogo"
                        HeaderLayout="@HeaderLayout"
                        ItemsLayout="@ItemsLayout"
                        FooterLayout="@FooterLayout" />
                </div>
            </div>

            <!-- Sidebar -->
            <div class="space-y-6">
                <!-- Details Card -->
                <Card Title="Details">
                    <dl class="space-y-3">
                        <div class="flex justify-between items-center">
                            <dt class="text-sm text-gray-500 dark:text-slate-400">Status</dt>
                            <dd>
                                <StatusBadge Status="@_estimate.Status" Type="StatusBadge.StatusType.Estimate" />
                            </dd>
                        </div>
                        <div class="flex justify-between">
                            <dt class="text-sm text-gray-500 dark:text-slate-400">Estimate Date</dt>
                            <dd class="text-sm font-medium text-gray-900 dark:text-slate-100">@_estimate.EstimateDate.ToString("MMM dd, yyyy")</dd>
                        </div>
                        @if (_estimate.ExpiryDate.HasValue)
                        {
                            <div class="flex justify-between">
                                <dt class="text-sm text-gray-500 dark:text-slate-400">Valid Until</dt>
                                <dd class="text-sm font-medium text-gray-900 dark:text-slate-100">@_estimate.ExpiryDate.Value.ToString("MMM dd, yyyy")</dd>
                            </div>
                        }
                        @if (_estimate.AcceptedDate.HasValue)
                        {
                            <div class="flex justify-between">
                                <dt class="text-sm text-gray-500 dark:text-slate-400">Accepted On</dt>
                                <dd class="text-sm font-medium text-emerald-600 dark:text-emerald-400">@_estimate.AcceptedDate.Value.ToString("MMM dd, yyyy")</dd>
                            </div>
                        }
                        @if (_estimate.RejectedDate.HasValue)
                        {
                            <div class="flex justify-between">
                                <dt class="text-sm text-gray-500 dark:text-slate-400">Rejected On</dt>
                                <dd class="text-sm font-medium text-red-600 dark:text-red-400">@_estimate.RejectedDate.Value.ToString("MMM dd, yyyy")</dd>
                            </div>
                        }
                        @if (_estimate.ConvertedInvoiceId.HasValue)
                        {
                            <div class="flex justify-between items-center pt-2 border-t border-gray-100 dark:border-slate-700">
                                <dt class="text-sm text-gray-500 dark:text-slate-400">Invoice</dt>
                                <dd>
                                    <a href="@($"invoices/{_estimate.ConvertedInvoiceId}")" class="text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:underline">View Invoice</a>
                                </dd>
                            </div>
                        }
                    </dl>
                </Card>

                <!-- Client Card -->
                <Card Title="Client">
                    <div class="space-y-3">
                        <div>
                            <p class="text-sm font-medium text-gray-900 dark:text-slate-100">@_estimate.ClientName</p>
                            @if (!string.IsNullOrEmpty(_estimate.ClientCompanyName))
                            {
                                <p class="text-sm text-gray-600 dark:text-slate-400">@_estimate.ClientCompanyName</p>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(_estimate.ClientEmail))
                        {
                            <p class="text-sm text-gray-600 dark:text-slate-400">@_estimate.ClientEmail</p>
                        }
                        <div class="pt-2">
                            <a href="@($"clients/{_estimate.ClientId}")" class="text-sm text-indigo-600 dark:text-indigo-400 hover:underline">View Client</a>
                        </div>
                    </div>
                </Card>

                <!-- Actions Card -->
                <Card Title="Actions">
                    <div class="space-y-3">
                        @if (_estimate.PublicAccessToken.HasValue)
                        {
                            <a href="@($"/estimate/{_estimate.PublicAccessToken.Value}")" target="_blank" class="flex items-center gap-2 text-sm text-indigo-600 dark:text-indigo-400 hover:underline">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                                </svg>
                                View Public Link
                            </a>
                            <button @onclick="CopyPublicLinkAsync" class="flex items-center gap-2 text-sm text-gray-600 dark:text-slate-400 hover:text-gray-900 dark:hover:text-slate-200">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                                </svg>
                                Copy Link
                            </button>
                        }
                        <button @onclick="DeleteEstimateAsync" class="flex items-center gap-2 text-sm text-red-600 dark:text-red-400 hover:underline">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                            </svg>
                            Delete Estimate
                        </button>
                    </div>
                </Card>
            </div>
        </div>
    }
</div>

<ErrorAlert Message="@_errorMessage" />

@code {
    [Parameter]
    public Guid Id { get; set; }

    private EstimateDetailDto? _estimate;
    private BusinessProfileDto? _businessProfile;
    private byte[]? _businessLogo;
    private bool _isLoading = true;
    private bool _isSending;
    private bool _isConverting;
    private bool _isDownloading;
    private string? _errorMessage;
    private List<PageHeader.BreadcrumbItem> _breadcrumbs = [];

    protected override async Task OnInitializedAsync()
    {
        _breadcrumbs =
        [
            new PageHeader.BreadcrumbItem("Estimates", "/estimates"),
            new PageHeader.BreadcrumbItem("Details")
        ];

        await LoadData();
    }

    private async Task LoadData()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            _estimate = await GetEstimateCall.Call(new GetEstimate { Id = Id });

            if (_estimate != null)
            {
                _breadcrumbs =
                [
                    new PageHeader.BreadcrumbItem("Estimates", "/estimates"),
                    new PageHeader.BreadcrumbItem(_estimate.EstimateNumber)
                ];
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load estimate: {ex.Message}";
        }

        // Load business profile and logo separately - these are optional
        try
        {
            _businessProfile = await GetBusinessProfileCall.Call(new GetBusinessProfile());
        }
        catch
        {
            // Business profile is optional for display
        }

        try
        {
            _businessLogo = await GetBusinessLogoCall.Call(new GetBusinessLogo());
        }
        catch
        {
            // Logo is optional for display
        }

        _isLoading = false;
    }

    private string GetBusinessAddress()
    {
        if (_businessProfile == null) return "";
        var parts = new List<string>();
        if (!string.IsNullOrEmpty(_businessProfile.Street)) parts.Add(_businessProfile.Street);
        var cityLine = string.Join(", ", new[] { _businessProfile.City, _businessProfile.State, _businessProfile.PostalCode }.Where(s => !string.IsNullOrEmpty(s)));
        if (!string.IsNullOrEmpty(cityLine)) parts.Add(cityLine);
        if (!string.IsNullOrEmpty(_businessProfile.Country)) parts.Add(_businessProfile.Country);
        return string.Join("\n", parts);
    }

    private string GetClientAddress()
    {
        if (_estimate == null) return "";
        var parts = new List<string>();
        if (!string.IsNullOrEmpty(_estimate.ClientStreet)) parts.Add(_estimate.ClientStreet);
        var cityLine = string.Join(", ", new[] { _estimate.ClientCity, _estimate.ClientState, _estimate.ClientPostalCode }.Where(s => !string.IsNullOrEmpty(s)));
        if (!string.IsNullOrEmpty(cityLine)) parts.Add(cityLine);
        if (!string.IsNullOrEmpty(_estimate.ClientCountry)) parts.Add(_estimate.ClientCountry);
        return string.Join("\n", parts);
    }

    private async Task DownloadPdfAsync()
    {
        _isDownloading = true;
        _errorMessage = null;
        try
        {
            var pdfBytes = await GetEstimatePdfCall.Call(new GetEstimatePdf { Id = Id });
            if (pdfBytes != null)
            {
                var fileName = $"Estimate-{_estimate?.EstimateNumber ?? Id.ToString()}.pdf";
                await JS.InvokeVoidAsync("downloadFile", fileName, Convert.ToBase64String(pdfBytes), "application/pdf");
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to download PDF: {ex.Message}";
        }
        finally
        {
            _isDownloading = false;
        }
    }

    private async Task SendEstimateAsync()
    {
        _isSending = true;
        _errorMessage = null;
        try
        {
            await SendEstimateCall.Call(new SendEstimate { Id = Id });
            await LoadData();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to send estimate: {ex.Message}";
        }
        finally
        {
            _isSending = false;
        }
    }

    private async Task ConvertToInvoiceAsync()
    {
        _isConverting = true;
        _errorMessage = null;
        try
        {
            var invoiceId = await ConvertEstimateCall.Call(new ConvertEstimateToInvoice { Id = Id });
            NavigationManager.NavigateTo($"invoices/{invoiceId}");
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to convert estimate: {ex.Message}";
        }
        finally
        {
            _isConverting = false;
        }
    }

    private async Task CopyPublicLinkAsync()
    {
        if (_estimate?.PublicAccessToken.HasValue == true)
        {
            var link = NavigationManager.ToAbsoluteUri($"/estimate/{_estimate.PublicAccessToken.Value}").ToString();
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", link);
        }
    }

    private async Task DeleteEstimateAsync()
    {
        var confirmed = await ModalService.ShowAsync<bool>(
            typeof(DeleteConfirmationModal),
            "Delete Estimate",
            new Dictionary<string, object>
            {
                { "ItemName", _estimate?.EstimateNumber ?? "this estimate" },
                { "WarningMessage", "This will permanently delete this estimate. This action cannot be undone." }
            },
            new ModalOptions { Size = ModalSize.Small });

        if (!confirmed) return;

        try
        {
            await DeleteEstimateCall.Call(new DeleteEstimate { Id = Id });
            NavigationManager.NavigateTo("estimates");
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to delete estimate: {ex.Message}";
        }
    }

    // Template helper properties
    private string PrimaryColor => _estimate?.Template?.PrimaryColor ?? "#4f46e5";
    private string AccentColor => _estimate?.Template?.AccentColor ?? "#059669";
    private string HeaderLayout => _estimate?.Template?.HeaderLayout?.ToLowerInvariant() ?? "standard";
    private string ItemsLayout => _estimate?.Template?.ItemsLayout?.ToLowerInvariant() ?? "standard";
    private string FooterLayout => _estimate?.Template?.FooterLayout?.ToLowerInvariant() ?? "standard";
    private bool ShowLogo => _estimate?.Template?.ShowLogo ?? true;
}
