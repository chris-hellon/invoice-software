@page "/estimate/{Token:guid}"
@layout EmptyLayout

@inject ICall<GetPublicEstimate, PublicEstimateDto?> GetPublicEstimateCall
@inject ICall<AcceptEstimatePublic> AcceptEstimateCall
@inject ICall<RejectEstimatePublic> RejectEstimateCall

<PageTitle>@(_estimate != null ? $"Estimate {_estimate.EstimateNumber}" : "Estimate")</PageTitle>

<div class="min-h-screen bg-gradient-to-br from-slate-50 to-slate-100 dark:from-slate-900 dark:to-slate-800 py-8 px-4">
    <div class="max-w-4xl mx-auto">
        @if (_isLoading)
        {
            <div class="flex justify-center py-20">
                <div class="w-8 h-8 border-2 border-gray-200 border-t-indigo-600 rounded-full animate-spin"></div>
            </div>
        }
        else if (_estimate == null)
        {
            <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-xl border border-gray-100 dark:border-slate-700">
                <div class="text-center py-16 px-6">
                    <div class="mx-auto w-16 h-16 rounded-2xl flex items-center justify-center mb-4"
                         style="background: linear-gradient(135deg, #fef2f2 0%, #fee2e2 100%);">
                        <svg class="h-8 w-8 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                    <h3 class="text-base font-semibold text-gray-900 dark:text-white">Estimate not found</h3>
                    <p class="mt-1 text-sm text-gray-500 dark:text-slate-400">This estimate link may have expired or is invalid.</p>
                </div>
            </div>
        }
        else
        {
            <!-- Accept/Reject Actions for Sent estimates -->
            @if (_estimate.Status == "Sent" && !_actionTaken)
            {
                <div class="mb-6 bg-white dark:bg-slate-800 rounded-2xl shadow-lg border border-gray-100 dark:border-slate-700 p-6">
                    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
                        <div>
                            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Review this estimate</h3>
                            <p class="text-sm text-gray-500 dark:text-slate-400">Please review the details below and let us know your decision.</p>
                        </div>
                        <div class="flex items-center gap-3">
                            <button @onclick="RejectEstimateAsync" disabled="@_isProcessing"
                                class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium text-red-700 dark:text-red-400 bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 rounded-xl hover:bg-red-100 dark:hover:bg-red-900/50 transition-all duration-200 disabled:opacity-50">
                                @if (_isProcessing && _rejecting)
                                {
                                    <div class="w-4 h-4 border-2 border-red-300 border-t-red-600 rounded-full animate-spin"></div>
                                }
                                else
                                {
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                                    </svg>
                                }
                                Decline
                            </button>
                            <button @onclick="AcceptEstimateAsync" disabled="@_isProcessing"
                                class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium text-white rounded-xl transition-all duration-200 hover:shadow-lg active:scale-[0.98] disabled:opacity-50"
                                style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); box-shadow: 0 4px 14px rgba(16, 185, 129, 0.35);">
                                @if (_isProcessing && !_rejecting)
                                {
                                    <div class="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>
                                }
                                else
                                {
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                    </svg>
                                }
                                Accept Estimate
                            </button>
                        </div>
                    </div>
                </div>
            }

            <!-- Success message after action -->
            @if (_actionTaken)
            {
                <div class="mb-6 @(_accepted ? "bg-emerald-50 dark:bg-emerald-900/30 border-emerald-200 dark:border-emerald-800" : "bg-red-50 dark:bg-red-900/30 border-red-200 dark:border-red-800") rounded-2xl shadow-lg border p-6">
                    <div class="flex items-center gap-4">
                        <div class="flex items-center justify-center w-10 h-10 rounded-full @(_accepted ? "bg-emerald-600" : "bg-red-600")">
                            @if (_accepted)
                            {
                                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                </svg>
                            }
                            else
                            {
                                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                                </svg>
                            }
                        </div>
                        <div>
                            <h3 class="text-lg font-semibold @(_accepted ? "text-emerald-700 dark:text-emerald-300" : "text-red-700 dark:text-red-300")">
                                @(_accepted ? "Estimate Accepted" : "Estimate Declined")
                            </h3>
                            <p class="text-sm @(_accepted ? "text-emerald-600 dark:text-emerald-400" : "text-red-600 dark:text-red-400")">
                                @(_accepted ? "Thank you! We'll be in touch shortly to proceed with your project." : "Thank you for letting us know. Feel free to reach out if you have any questions.")
                            </p>
                        </div>
                    </div>
                </div>
            }

            <!-- Estimate Document -->
            <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-xl border border-gray-100 dark:border-slate-700 overflow-hidden">
                <EstimateViewContent
                    EstimateNumber="@_estimate.EstimateNumber"
                    Status="@_estimate.Status"
                    Currency="@_estimate.Currency"
                    EstimateDate="@_estimate.EstimateDate"
                    ExpiryDate="@_estimate.ExpiryDate"
                    AcceptedDate="@_estimate.AcceptedDate"
                    RejectedDate="@_estimate.RejectedDate"
                    BusinessName="@_estimate.BusinessName"
                    BusinessAddress="@GetBusinessAddress()"
                    BusinessEmail="@_estimate.BusinessEmail"
                    BusinessPhone="@_estimate.BusinessPhone"
                    BusinessLogo="@_estimate.BusinessLogo"
                    TaxNumber="@_estimate.TaxNumber"
                    RegistrationNumber="@_estimate.RegistrationNumber"
                    ClientName="@_estimate.ClientName"
                    ClientCompanyName="@_estimate.ClientCompanyName"
                    ClientAddress="@_estimate.ClientAddress"
                    ClientEmail="@_estimate.ClientEmail"
                    Subtotal="@_estimate.Subtotal"
                    TaxRate="@_estimate.TaxRate"
                    TaxAmount="@_estimate.TaxAmount"
                    Total="@_estimate.Total"
                    Notes="@_estimate.Notes"
                    Terms="@_estimate.Terms"
                    LineItems="@_estimate.LineItems"
                    PrimaryColor="@(_estimate.PrimaryColor ?? "#4f46e5")"
                    AccentColor="@(_estimate.AccentColor ?? "#059669")"
                    ShowLogo="@_estimate.ShowLogo"
                    HeaderLayout="@(_estimate.HeaderLayout?.ToLowerInvariant() ?? "standard")"
                    ItemsLayout="@(_estimate.ItemsLayout?.ToLowerInvariant() ?? "standard")"
                    FooterLayout="@(_estimate.FooterLayout?.ToLowerInvariant() ?? "standard")" />
            </div>

            <!-- Powered by footer -->
            <div class="mt-6 text-center">
                <p class="text-xs text-gray-400 dark:text-slate-500">
                    Powered by <span class="font-semibold">Invoice<span class="text-indigo-500">Pro</span></span>
                </p>
            </div>
        }
    </div>
</div>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="fixed bottom-4 right-4 max-w-sm bg-red-50 dark:bg-red-900/80 border border-red-200 dark:border-red-800 rounded-xl shadow-lg p-4">
        <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <p class="text-sm text-red-700 dark:text-red-300">@_errorMessage</p>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid Token { get; set; }

    private PublicEstimateDto? _estimate;
    private bool _isLoading = true;
    private bool _isProcessing;
    private bool _rejecting;
    private bool _actionTaken;
    private bool _accepted;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _estimate = await GetPublicEstimateCall.Call(new GetPublicEstimate { Token = Token });
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading public estimate: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private string GetBusinessAddress()
    {
        if (_estimate == null) return "";
        var parts = new List<string>();
        if (!string.IsNullOrEmpty(_estimate.BusinessStreet)) parts.Add(_estimate.BusinessStreet);
        var cityLine = string.Join(", ", new[] { _estimate.BusinessCity, _estimate.BusinessState, _estimate.BusinessPostalCode }.Where(s => !string.IsNullOrEmpty(s)));
        if (!string.IsNullOrEmpty(cityLine)) parts.Add(cityLine);
        if (!string.IsNullOrEmpty(_estimate.BusinessCountry)) parts.Add(_estimate.BusinessCountry);
        return string.Join("\n", parts);
    }

    private async Task AcceptEstimateAsync()
    {
        if (_estimate == null) return;

        _isProcessing = true;
        _rejecting = false;
        _errorMessage = null;

        try
        {
            await AcceptEstimateCall.Call(new AcceptEstimatePublic { Token = Token });
            _actionTaken = true;
            _accepted = true;
            // Reload to get updated status
            _estimate = await GetPublicEstimateCall.Call(new GetPublicEstimate { Token = Token });
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to accept estimate: {ex.Message}";
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task RejectEstimateAsync()
    {
        if (_estimate == null) return;

        _isProcessing = true;
        _rejecting = true;
        _errorMessage = null;

        try
        {
            await RejectEstimateCall.Call(new RejectEstimatePublic { Token = Token });
            _actionTaken = true;
            _accepted = false;
            // Reload to get updated status
            _estimate = await GetPublicEstimateCall.Call(new GetPublicEstimate { Token = Token });
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to decline estimate: {ex.Message}";
        }
        finally
        {
            _isProcessing = false;
        }
    }
}
