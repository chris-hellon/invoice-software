@page "/projects/{Id:guid}"

@inject ICall<GetProject, ProjectDetailDto> GetProjectCall
@inject ICall<DeleteProject> DeleteProjectCall
@inject NavigationManager NavigationManager

<PageTitle>@(_project != null ? _project.Name : "Project") - InvoicePro</PageTitle>

<div class="space-y-6">
    <!-- Header with Breadcrumbs -->
    <PageHeader Title="@(_project != null ? _project.Name : "Project")"
                Description="@_project?.ClientName"
                ShowBackButton="true"
                BackUrl="projects"
                Breadcrumbs="@_breadcrumbs">
        @if (_project != null)
        {
            <div class="flex items-center gap-3">
                <a href="projects/@Id/edit" class="btn-secondary">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                    Edit Project
                </a>
                <button @onclick="DeleteProjectAsync" disabled="@_isDeleting"
                        class="inline-flex items-center gap-2 px-4 py-2.5 text-sm font-medium text-red-700 dark:text-red-300 bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 rounded-xl hover:bg-red-100 dark:hover:bg-red-900/50 transition-all duration-200 disabled:opacity-50 disabled:cursor-not-allowed">
                    @if (_isDeleting)
                    {
                        <div class="w-4 h-4 border-2 border-red-300 border-t-red-600 rounded-full animate-spin"></div>
                    }
                    else
                    {
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                    }
                    Delete
                </button>
            </div>
        }
    </PageHeader>

    @if (_isLoading)
    {
        <div class="flex justify-center py-20">
            <div class="w-8 h-8 border-2 border-gray-200 border-t-indigo-600 rounded-full animate-spin"></div>
        </div>
    }
    else if (_project == null)
    {
        <div class="bg-white rounded-2xl border border-gray-100">
            <div class="text-center py-16 px-6">
                <div class="mx-auto w-16 h-16 rounded-2xl flex items-center justify-center mb-4"
                     style="background: linear-gradient(135deg, #fef2f2 0%, #fee2e2 100%);">
                    <svg class="h-8 w-8 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
                <h3 class="text-base font-semibold text-gray-900">Project not found</h3>
                <p class="mt-1 text-sm text-gray-500">The requested project could not be found.</p>
                <div class="mt-6">
                    <a href="projects" class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium text-white rounded-xl transition-all duration-200 hover:shadow-lg active:scale-[0.98]"
                       style="background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); box-shadow: 0 4px 14px rgba(99, 102, 241, 0.35);">
                        Back to Projects
                    </a>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Status Banner -->
        @if (_project.Status == "Active")
        {
            <div class="bg-gradient-to-r from-emerald-50 to-teal-50 dark:from-emerald-900/30 dark:to-teal-900/30 border border-emerald-100 dark:border-emerald-800 rounded-2xl px-6 py-4">
                <div class="flex items-center justify-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-emerald-100 dark:bg-emerald-800 flex items-center justify-center">
                        <svg class="w-4 h-4 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                    </div>
                    <div>
                        <span class="text-sm font-semibold text-emerald-800 dark:text-emerald-200">Active</span>
                        <span class="text-sm text-emerald-600 dark:text-emerald-400 ml-2">Project is currently in progress</span>
                    </div>
                </div>
            </div>
        }
        else if (_project.Status == "OnHold")
        {
            <div class="bg-gradient-to-r from-amber-50 to-yellow-50 dark:from-amber-900/30 dark:to-yellow-900/30 border border-amber-100 dark:border-amber-800 rounded-2xl px-6 py-4">
                <div class="flex items-center justify-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-amber-100 dark:bg-amber-800 flex items-center justify-center">
                        <svg class="w-4 h-4 text-amber-600 dark:text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                    <div>
                        <span class="text-sm font-semibold text-amber-800 dark:text-amber-200">On Hold</span>
                        <span class="text-sm text-amber-600 dark:text-amber-400 ml-2">Project is temporarily paused</span>
                    </div>
                </div>
            </div>
        }
        else if (_project.Status == "Completed")
        {
            <div class="bg-gradient-to-r from-blue-50 to-indigo-50 dark:from-blue-900/30 dark:to-indigo-900/30 border border-blue-100 dark:border-blue-800 rounded-2xl px-6 py-4">
                <div class="flex items-center justify-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-blue-100 dark:bg-blue-800 flex items-center justify-center">
                        <svg class="w-4 h-4 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                    <div>
                        <span class="text-sm font-semibold text-blue-800 dark:text-blue-200">Completed</span>
                        <span class="text-sm text-blue-600 dark:text-blue-400 ml-2">Project has been finished</span>
                    </div>
                </div>
            </div>
        }
        else if (_project.Status == "Archived")
        {
            <div class="bg-gradient-to-r from-gray-50 to-slate-50 dark:from-gray-900/30 dark:to-slate-900/30 border border-gray-200 dark:border-gray-700 rounded-2xl px-6 py-4">
                <div class="flex items-center justify-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-gray-100 dark:bg-gray-800 flex items-center justify-center">
                        <svg class="w-4 h-4 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
                        </svg>
                    </div>
                    <div>
                        <span class="text-sm font-semibold text-gray-700 dark:text-gray-300">Archived</span>
                        <span class="text-sm text-gray-500 dark:text-gray-400 ml-2">Project has been archived</span>
                    </div>
                </div>
            </div>
        }

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Project Info -->
            <div class="lg:col-span-1 space-y-6">
                <!-- Details Card -->
                <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden">
                    <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, #eef2ff 0%, #e0e7ff 100%);">
                                <svg class="w-4 h-4 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
                                </svg>
                            </div>
                            <h3 class="text-sm font-semibold text-gray-900">Project Details</h3>
                        </div>
                    </div>
                    <div class="p-6 space-y-4">
                        @if (!string.IsNullOrEmpty(_project.Description))
                        {
                            <div>
                                <div class="text-xs text-gray-500 mb-1">Description</div>
                                <p class="text-sm text-gray-900">@_project.Description</p>
                            </div>
                        }

                        @if (_project.StartDate.HasValue || _project.EndDate.HasValue)
                        {
                            <div class="flex items-start gap-3">
                                <svg class="w-5 h-5 text-gray-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                </svg>
                                <div>
                                    <div class="text-xs text-gray-500 mb-0.5">Timeline</div>
                                    <div class="text-sm font-medium text-gray-900">
                                        @if (_project.StartDate.HasValue && _project.EndDate.HasValue)
                                        {
                                            <span>@_project.StartDate.Value.ToString("MMM d, yyyy") - @_project.EndDate.Value.ToString("MMM d, yyyy")</span>
                                        }
                                        else if (_project.StartDate.HasValue)
                                        {
                                            <span>Started @_project.StartDate.Value.ToString("MMM d, yyyy")</span>
                                        }
                                        else if (_project.EndDate.HasValue)
                                        {
                                            <span>Due @_project.EndDate.Value.ToString("MMM d, yyyy")</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        }

                        @if (_project.HourlyRateOverride.HasValue)
                        {
                            <div class="flex items-start gap-3">
                                <svg class="w-5 h-5 text-gray-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                <div>
                                    <div class="text-xs text-gray-500 mb-0.5">Hourly Rate Override</div>
                                    <div class="text-sm font-semibold text-gray-900">$@_project.HourlyRateOverride.Value.ToString("N2")/hr</div>
                                </div>
                            </div>
                        }

                        <div class="flex items-start gap-3 pt-2 border-t border-gray-100">
                            <svg class="w-5 h-5 text-gray-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                            </svg>
                            <div>
                                <div class="text-xs text-gray-500 mb-0.5">Client</div>
                                <a href="clients/@_project.ClientId" class="text-sm font-medium text-indigo-600 hover:text-indigo-700 transition-colors">@_project.ClientName</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Jobs -->
            <div class="lg:col-span-2">
                <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden">
                    <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50 flex items-center justify-between">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, #eef2ff 0%, #e0e7ff 100%);">
                                <svg class="w-4 h-4 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-sm font-semibold text-gray-900">Jobs</h3>
                                <p class="text-xs text-gray-500">@(_project.Jobs.Count) jobs in this project</p>
                            </div>
                        </div>
                        <a href="jobs/new" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-indigo-600 hover:text-indigo-700 hover:bg-indigo-50 rounded-lg transition-colors">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                            </svg>
                            Add Job
                        </a>
                    </div>
                    @if (!_project.Jobs.Any())
                    {
                        <div class="text-center py-12 px-6">
                            <div class="mx-auto w-14 h-14 rounded-2xl flex items-center justify-center mb-4"
                                 style="background: linear-gradient(135deg, #eef2ff 0%, #e0e7ff 100%);">
                                <svg class="h-7 w-7 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                                </svg>
                            </div>
                            <h3 class="text-base font-semibold text-gray-900">No jobs yet</h3>
                            <p class="mt-1 text-sm text-gray-500">Get started by adding a job to this project.</p>
                            <div class="mt-4">
                                <a href="jobs/new" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-indigo-600 hover:text-indigo-700 hover:bg-indigo-50 rounded-lg transition-colors">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                                    </svg>
                                    Add Job
                                </a>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="divide-y divide-gray-100">
                            @foreach (var job in _project.Jobs)
                            {
                                <a href="jobs/@job.Id" class="flex items-center justify-between px-6 py-4 hover:bg-gray-50/50 transition-colors group">
                                    <div class="min-w-0 flex-1">
                                        <div class="flex items-center gap-2">
                                            <span class="font-medium text-gray-900 group-hover:text-indigo-600 transition-colors">@job.Name</span>
                                            <span class="@JobStatusExtensions.Parse(job.Status).GetSmallBadgeClass()">@JobStatusExtensions.Parse(job.Status).GetDisplayName()</span>
                                        </div>
                                        @if (!string.IsNullOrEmpty(job.Description))
                                        {
                                            <p class="text-sm text-gray-500 truncate mt-0.5">@job.Description</p>
                                        }
                                    </div>
                                    <div class="ml-4 flex items-center gap-4 text-sm text-gray-500">
                                        @if (job.EstimatedHours.HasValue)
                                        {
                                            <span>@job.EstimatedHours.Value.ToString("N1") hrs est.</span>
                                        }
                                        <svg class="w-4 h-4 text-gray-400 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                        </svg>
                                    </div>
                                </a>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public Guid Id { get; set; }

    private ProjectDetailDto? _project;
    private bool _isLoading = true;
    private bool _isDeleting;
    private List<PageHeader.BreadcrumbItem> _breadcrumbs = [];

    protected override async Task OnInitializedAsync()
    {
        _breadcrumbs =
        [
            new PageHeader.BreadcrumbItem("Projects", "/projects"),
            new PageHeader.BreadcrumbItem("Project Details")
        ];

        try
        {
            _project = await GetProjectCall.Call(new GetProject { Id = Id });
            if (_project != null)
            {
                _breadcrumbs[1] = new PageHeader.BreadcrumbItem(_project.Name);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading project: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task DeleteProjectAsync()
    {
        var confirmed = await ModalService.ShowAsync<bool>(
            typeof(DeleteConfirmationModal),
            "Delete Project",
            new Dictionary<string, object>
            {
                { "ItemName", _project?.Name ?? "this project" },
                { "WarningMessage", "All jobs, tasks, and time entries associated with this project will be permanently deleted." }
            },
            new ModalOptions { Size = ModalSize.Small });

        if (!confirmed) return;

        _isDeleting = true;

        try
        {
            await DeleteProjectCall.Call(new DeleteProject { Id = Id });
            NavigationManager.NavigateTo("projects");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting project: {ex.Message}");
        }
        finally
        {
            _isDeleting = false;
        }
    }
}
