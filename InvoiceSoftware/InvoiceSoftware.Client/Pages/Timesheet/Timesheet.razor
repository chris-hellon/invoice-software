@page "/timesheet"
@inject ICall<GetTimesheetJobs, List<TimesheetJobDto>> GetTimesheetJobsCall
@inject ICall<GetWeeklyTimeEntries, List<TimeEntryDto>> GetTimeEntriesCall
@inject ICall<LogTimeEntry, Guid> LogTimeEntryCall

<PageTitle>Timesheet - InvoicePro</PageTitle>

<div class="space-y-6">
    <!-- Header with Breadcrumbs -->
    <PageHeader Title="Weekly Timesheet"
                Description="Track and manage your working hours"
                Breadcrumbs="@(new List<PageHeader.BreadcrumbItem> { new("Timesheet") })" />

    <!-- Week Navigation Card -->
    <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-100 dark:border-slate-700 shadow-sm overflow-hidden">
        <div class="p-5 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div class="flex items-center gap-3">
                <button @onclick="PreviousWeek"
                        class="p-2.5 text-gray-500 dark:text-slate-400 hover:text-gray-700 dark:hover:text-slate-200 hover:bg-gray-100 dark:hover:bg-[#2d2a4a] rounded-xl transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                    </svg>
                </button>
                <div class="text-center min-w-[180px]">
                    <h2 class="text-base font-semibold text-gray-900 dark:text-slate-100">
                        @_weekStart.ToString("MMM d") - @_weekEnd.ToString("MMM d, yyyy")
                    </h2>
                    <button @onclick="GoToCurrentWeek" class="text-xs text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 font-medium mt-0.5">
                        Jump to today
                    </button>
                </div>
                <button @onclick="NextWeek"
                        class="p-2.5 text-gray-500 dark:text-slate-400 hover:text-gray-700 dark:hover:text-slate-200 hover:bg-gray-100 dark:hover:bg-[#2d2a4a] rounded-xl transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                </button>
            </div>

            <!-- Week Summary Stats -->
            <div class="flex items-center gap-6">
                <div class="text-center">
                    <div class="text-2xl font-bold text-indigo-600 dark:text-indigo-400" style="font-family: 'Plus Jakarta Sans', sans-serif;">
                        @GetWeekTotal().ToString("N2")
                    </div>
                    <div class="text-xs text-gray-500 dark:text-slate-400 font-medium">Hours logged</div>
                </div>
                <div class="h-10 w-px bg-gray-200 dark:bg-slate-600"></div>
                <div class="text-center">
                    <div class="text-2xl font-bold text-gray-900 dark:text-slate-100" style="font-family: 'Plus Jakarta Sans', sans-serif;">
                        @(_displayedJobs?.Count ?? 0)
                    </div>
                    <div class="text-xs text-gray-500 dark:text-slate-400 font-medium">Active jobs</div>
                </div>
            </div>

            <button @onclick="OpenJobPicker"
                    class="inline-flex items-center justify-center gap-2 px-5 py-2.5 text-sm font-medium text-white rounded-xl shadow-md transition-all duration-200 hover:shadow-lg active:scale-[0.98]"
                    style="background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); box-shadow: 0 4px 14px rgba(99, 102, 241, 0.35);">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                </svg>
                Add Jobs
            </button>
        </div>
    </div>

    <!-- Timesheet Content -->
    @if (_isLoading)
    {
        <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-100 dark:border-slate-700 shadow-sm">
            <div class="flex flex-col items-center justify-center py-20">
                <div class="w-10 h-10 border-2 border-gray-200 dark:border-slate-600 border-t-indigo-600 rounded-full animate-spin"></div>
                <p class="mt-4 text-sm text-gray-500 dark:text-slate-400">Loading timesheet...</p>
            </div>
        </div>
    }
    else if (_displayedJobs == null || !_displayedJobs.Any())
    {
        <!-- Empty State -->
        <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-100 dark:border-slate-700 shadow-sm">
            <div class="text-center py-20 px-6">
                <div class="mx-auto w-20 h-20 rounded-2xl flex items-center justify-center mb-6"
                     style="background: linear-gradient(135deg, #eef2ff 0%, #e0e7ff 100%);">
                    <svg class="h-10 w-10 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
                <h3 class="text-lg font-semibold text-gray-900 dark:text-slate-100">No jobs on your timesheet</h3>
                <p class="mt-2 text-sm text-gray-500 dark:text-slate-400 max-w-sm mx-auto">
                    Add jobs to start tracking your time. You can select from your active projects and jobs.
                </p>
                <div class="mt-8">
                    <button @onclick="OpenJobPicker"
                            class="inline-flex items-center gap-2 px-6 py-3 text-sm font-medium text-white rounded-xl transition-all duration-200 hover:shadow-lg active:scale-[0.98]"
                            style="background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); box-shadow: 0 4px 14px rgba(99, 102, 241, 0.35);">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                        </svg>
                        Add Your First Job
                    </button>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Timesheet Grid -->
        <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-100 dark:border-slate-700 shadow-sm overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead>
                        <tr class="border-b border-gray-100 dark:border-slate-700">
                            <th class="px-5 py-4 text-left text-xs font-semibold text-gray-500 dark:text-slate-400 uppercase tracking-wider bg-gray-50/50 dark:bg-slate-700/50 sticky left-0 z-10 min-w-[240px]">
                                Job / Project
                            </th>
                            @foreach (var day in _weekDays)
                            {
                                var isToday = day == DateOnly.FromDateTime(DateTime.Today);
                                var isWeekend = day.DayOfWeek == DayOfWeek.Saturday || day.DayOfWeek == DayOfWeek.Sunday;
                                <th class="px-2 py-4 text-center min-w-[80px] @(isWeekend ? "bg-gray-50/80 dark:bg-slate-700/80" : "bg-gray-50/50 dark:bg-slate-700/50")">
                                    <div class="text-xs font-semibold uppercase tracking-wider @(isToday ? "text-indigo-600 dark:text-indigo-400" : "text-gray-500 dark:text-slate-400")">
                                        @day.ToString("ddd")
                                    </div>
                                    <div class="mt-1 @(isToday ? "inline-flex items-center justify-center w-7 h-7 rounded-full bg-indigo-600 text-white text-sm font-semibold" : "text-sm text-gray-400 dark:text-slate-500")">
                                        @day.Day
                                    </div>
                                </th>
                            }
                            <th class="px-5 py-4 text-center text-xs font-semibold text-gray-500 dark:text-slate-400 uppercase tracking-wider bg-gray-50/50 dark:bg-slate-700/50 min-w-[80px]">
                                Total
                            </th>
                            <th class="px-3 py-4 bg-gray-50/50 dark:bg-slate-700/50 w-12"></th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50 dark:divide-slate-700">
                        @foreach (var job in _displayedJobs)
                        {
                            var jobTotal = GetJobTotal(job.Id);
                            var isInactive = !job.IsActive;
                            <tr class="group hover:bg-indigo-50/30 dark:hover:bg-indigo-900/20 transition-colors @(isInactive ? "opacity-75" : "")">
                                <td class="px-5 py-4 sticky left-0 z-10 bg-white dark:bg-slate-800 group-hover:bg-indigo-50/30 dark:group-hover:bg-indigo-900/20 transition-colors">
                                    <div class="flex items-center gap-3">
                                        <div class="w-2 h-10 rounded-full @(isInactive ? "bg-gradient-to-b from-gray-300 to-gray-400 dark:from-slate-500 dark:to-slate-600" : "bg-gradient-to-b from-indigo-400 to-indigo-600")"></div>
                                        <div class="min-w-0">
                                            <div class="flex items-center gap-2">
                                                <span class="text-sm font-semibold text-gray-900 dark:text-slate-100 truncate">@job.Name</span>
                                                @if (isInactive)
                                                {
                                                    <span class="inline-flex items-center px-1.5 py-0.5 text-[10px] font-medium rounded bg-gray-100 dark:bg-slate-700 text-gray-500 dark:text-slate-400">
                                                        Completed
                                                    </span>
                                                }
                                            </div>
                                            <div class="text-xs text-gray-500 dark:text-slate-400 truncate">@job.ProjectName &bull; @job.ClientName</div>
                                        </div>
                                    </div>
                                </td>
                                @foreach (var day in _weekDays)
                                {
                                    var entry = GetTimeEntry(job.Id, day);
                                    var isToday = day == DateOnly.FromDateTime(DateTime.Today);
                                    var isWeekend = day.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday;
                                    var hasHours = entry is { Hours: > 0 };
                                    <td class="px-2 py-3 text-center @(isWeekend ? "bg-gray-50/40 dark:bg-slate-700/30" : "")">
                                        <div class="relative">
                                            @if (isInactive)
                                            {
                                                <!-- Read-only display for completed jobs -->
                                                <div class="w-full max-w-[64px] mx-auto text-center border rounded-lg py-2 px-1 text-sm font-medium @(hasHours ? "bg-gray-100 dark:bg-slate-700 border-gray-200 dark:border-slate-600 text-gray-600 dark:text-slate-300" : "bg-gray-50 dark:bg-slate-800 border-gray-100 dark:border-slate-700 text-gray-400 dark:text-slate-500")">
                                                    @FormatHoursToTime(entry?.Hours ?? 0)
                                                </div>
                                            }
                                            else
                                            {
                                                <input type="text"
                                                       inputmode="decimal"
                                                       placeholder="0:00"
                                                       value="@FormatHoursToTime(entry?.Hours ?? 0)"
                                                       @onchange="@(e => UpdateTimeEntry(job.Id, day, e.Value?.ToString()))"
                                                       onfocus="this.select()"
                                                       class="w-full max-w-[64px] mx-auto text-center border rounded-lg py-2 px-1 text-sm font-medium transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-400 @(hasHours ? "bg-indigo-100 dark:bg-indigo-900/50 border-indigo-300 dark:border-indigo-700 text-indigo-700 dark:text-indigo-300" : "bg-white dark:bg-slate-800 border-gray-200 dark:border-slate-600 text-gray-600 dark:text-slate-300 hover:border-gray-300 dark:hover:border-slate-500") @(isToday && !hasHours ? "ring-2 ring-indigo-100 dark:ring-indigo-900" : "")" />
                                            }
                                        </div>
                                    </td>
                                }
                                <td class="px-5 py-4 text-center">
                                    <span class="inline-flex items-center justify-center min-w-[48px] px-2.5 py-1.5 rounded-lg text-sm font-semibold @(jobTotal > 0 ? (isInactive ? "bg-gray-100 dark:bg-slate-700 text-gray-600 dark:text-slate-300" : "bg-indigo-100 dark:bg-indigo-900/50 text-indigo-700 dark:text-indigo-300") : "bg-gray-100 dark:bg-slate-700 text-gray-400 dark:text-slate-500")">
                                        @jobTotal.ToString("N2")
                                    </span>
                                </td>
                                <td class="px-3 py-4 text-center">
                                    <button @onclick="() => RemoveJobFromTimesheet(job.Id)"
                                            class="p-2 text-gray-300 dark:text-slate-600 hover:text-red-500 dark:hover:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/50 rounded-lg transition-all opacity-0 group-hover:opacity-100"
                                            title="Remove from timesheet">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                        </svg>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="border-t-2 border-gray-100 dark:border-slate-700 bg-gray-50/80 dark:bg-slate-700/50">
                            <td class="px-5 py-4 sticky left-0 z-10 bg-gray-50/80 dark:bg-slate-700/50">
                                <span class="text-sm font-semibold text-gray-700 dark:text-slate-200">Daily Totals</span>
                            </td>
                            @foreach (var day in _weekDays)
                            {
                                var dayTotal = GetDayTotal(day);
                                var isWeekend = day.DayOfWeek == DayOfWeek.Saturday || day.DayOfWeek == DayOfWeek.Sunday;
                                <td class="px-2 py-4 text-center @(isWeekend ? "bg-gray-100/50 dark:bg-slate-600/30" : "")">
                                    <span class="text-sm font-semibold @(dayTotal > 0 ? "text-gray-900 dark:text-slate-100" : "text-gray-400 dark:text-slate-500")">
                                        @dayTotal.ToString("N2")
                                    </span>
                                </td>
                            }
                            <td class="px-5 py-4 text-center">
                                <span class="inline-flex items-center justify-center min-w-[56px] px-3 py-2 rounded-xl text-base font-bold text-white"
                                      style="background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);">
                                    @GetWeekTotal().ToString("N2")
                                </span>
                            </td>
                            <td class="bg-gray-50/80 dark:bg-slate-700/50"></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>

        <!-- Quick Tips -->
        <div class="flex items-center gap-3 text-xs text-gray-500 dark:text-slate-400">
            <svg class="w-4 h-4 text-gray-400 dark:text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>Tip: Enter time as hours:minutes (e.g., 2:30 for 2½ hours). You can also type 2.5 or just 2. Changes are saved automatically.</span>
        </div>
    }
</div>

<!-- Saving Toast -->
@if (_isSaving)
{
    <div class="fixed bottom-6 right-6 z-50 px-5 py-3 rounded-xl shadow-lg text-sm font-medium flex items-center gap-3 text-white animate-fade-in"
         style="background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); box-shadow: 0 10px 40px rgba(99, 102, 241, 0.4);">
        <svg class="animate-spin h-5 w-5" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        Saving changes...
    </div>
}

@if (!string.IsNullOrEmpty(_saveMessage))
{
    <div class="fixed bottom-6 right-6 z-50 px-5 py-3 rounded-xl shadow-lg text-sm font-medium flex items-center gap-3 bg-emerald-500 text-white animate-fade-in"
         style="box-shadow: 0 10px 40px rgba(16, 185, 129, 0.4);">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        @_saveMessage
    </div>
}

<style>
    @@keyframes fade-in {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-in {
        animation: fade-in 0.2s ease-out;
    }
</style>

@code {
    private List<TimesheetJobDto>? _allJobs;
    private List<TimesheetJobDto>? _displayedJobs;
    private HashSet<Guid> _selectedJobIds = [];
    private List<TimeEntryDto> _timeEntries = [];
    private bool _isLoading = true;
    private bool _isSaving;
    private string? _saveMessage;
    private DateOnly _weekStart;
    private DateOnly _weekEnd;
    private readonly DateOnly[] _weekDays = new DateOnly[7];

    protected override async Task OnInitializedAsync()
    {
        GoToCurrentWeek();
        await LoadData();
    }

    private void GoToCurrentWeek()
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        var diff = (7 + ((int)today.DayOfWeek - (int)DayOfWeek.Monday)) % 7;
        _weekStart = today.AddDays(-diff);
        UpdateWeekDays();
    }

    private void PreviousWeek()
    {
        _weekStart = _weekStart.AddDays(-7);
        UpdateWeekDays();
        _ = LoadDataForWeek();
    }

    private void NextWeek()
    {
        _weekStart = _weekStart.AddDays(7);
        UpdateWeekDays();
        _ = LoadDataForWeek();
    }

    private async Task LoadDataForWeek()
    {
        try
        {
            _allJobs = await GetTimesheetJobsCall.Call(new GetTimesheetJobs { WeekStart = _weekStart });
            _timeEntries = await GetTimeEntriesCall.Call(new GetWeeklyTimeEntries { WeekStart = _weekStart }) ?? [];

            // Only show jobs that have time entries in THIS specific week
            _selectedJobIds = _timeEntries.Select(e => e.JobId).Distinct().ToHashSet();

            UpdateDisplayedJobs();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
            _timeEntries = [];
        }
        StateHasChanged();
    }

    private void UpdateWeekDays()
    {
        _weekEnd = _weekStart.AddDays(6);
        for (int i = 0; i < 7; i++)
        {
            _weekDays[i] = _weekStart.AddDays(i);
        }
    }

    private async Task LoadData()
    {
        try
        {
            _allJobs = await GetTimesheetJobsCall.Call(new GetTimesheetJobs { WeekStart = _weekStart });
            _timeEntries = await GetTimeEntriesCall.Call(new GetWeeklyTimeEntries { WeekStart = _weekStart }) ?? [];

            // Auto-select jobs that have time entries this week
            var jobsWithEntries = _timeEntries.Select(e => e.JobId).Distinct().ToHashSet();
            _selectedJobIds = jobsWithEntries;

            UpdateDisplayedJobs();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
            _allJobs = [];
            _displayedJobs = [];
            _timeEntries = [];
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void UpdateDisplayedJobs()
    {
        _displayedJobs = _allJobs != null ? _allJobs.Where(j => _selectedJobIds.Contains(j.Id)).ToList() : [];
    }

    private async Task RefreshTimeEntries()
    {
        try
        {
            _timeEntries = await GetTimeEntriesCall.Call(new GetWeeklyTimeEntries { WeekStart = _weekStart }) ?? [];
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading time entries: {ex.Message}");
            _timeEntries = [];
        }
        StateHasChanged();
    }

    private async Task OpenJobPicker()
    {
        var parameters = new Dictionary<string, object>
        {
            ["InitialSelection"] = _selectedJobIds
        };

        var options = new ModalOptions
        {
            Size = ModalSize.Large,
            CloseOnBackdropClick = true
        };

        var result = await ModalService.ShowAsync<HashSet<Guid>>(
            typeof(SelectJobsModal),
            "Select Jobs for Timesheet",
            parameters,
            options);

        if (result != null)
        {
            _selectedJobIds = result;
            UpdateDisplayedJobs();
        }
    }

    private void RemoveJobFromTimesheet(Guid jobId)
    {
        _selectedJobIds.Remove(jobId);
        UpdateDisplayedJobs();
    }

    private TimeEntryDto? GetTimeEntry(Guid jobId, DateOnly date)
    {
        return _timeEntries.FirstOrDefault(e => e.JobId == jobId && e.Date == date);
    }

    private decimal GetJobTotal(Guid jobId)
    {
        return _timeEntries.Where(e => e.JobId == jobId).Sum(e => e.Hours);
    }

    private decimal GetDayTotal(DateOnly date)
    {
        return _timeEntries.Where(e => e.Date == date && _selectedJobIds.Contains(e.JobId)).Sum(e => e.Hours);
    }

    private decimal GetWeekTotal()
    {
        return _timeEntries.Where(e => _selectedJobIds.Contains(e.JobId)).Sum(e => e.Hours);
    }

    private async Task UpdateTimeEntry(Guid jobId, DateOnly date, string? value)
    {
        var hours = ParseTimeInput(value);
        hours = Math.Max(0, Math.Min(24, hours));

        var existingEntry = GetTimeEntry(jobId, date);

        if (hours == 0 && existingEntry == null)
        {
            return;
        }

        _isSaving = true;
        _saveMessage = null;
        StateHasChanged();

        try
        {
            await LogTimeEntryCall.Call(new LogTimeEntry
            {
                JobId = jobId,
                Date = date,
                Hours = hours,
                Description = null
            });
            await RefreshTimeEntries();
            _saveMessage = "Changes saved";
            _ = ClearSaveMessage();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving time entry: {ex.Message}");
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    private async Task ClearSaveMessage()
    {
        await Task.Delay(2000);
        _saveMessage = null;
        StateHasChanged();
    }

    /// <summary>
    /// Parses various time input formats to decimal hours.
    /// Supports: "2:30" (H:MM), "2.30" (converted to 2:30), "2.5" (decimal), "2" (whole hours)
    /// </summary>
    private static decimal ParseTimeInput(string? input)
    {
        if (string.IsNullOrWhiteSpace(input))
            return 0;

        input = input.Trim();

        // Handle colon format (H:MM or HH:MM)
        if (input.Contains(':'))
        {
            var parts = input.Split(':');
            if (parts.Length == 2 &&
                int.TryParse(parts[0], out var hours) &&
                int.TryParse(parts[1], out var minutes))
            {
                // Clamp minutes to valid range
                minutes = Math.Max(0, Math.Min(59, minutes));
                return hours + (minutes / 60m);
            }
        }

        // Handle period - could be decimal (2.5) or time-like (2.30)
        if (input.Contains('.'))
        {
            var parts = input.Split('.');
            if (parts.Length == 2)
            {
                // If the part after the decimal is 2 digits and looks like minutes (00-59)
                // treat it as H.MM format (e.g., 2.30 = 2:30 = 2.5 hours)
                if (parts[1].Length == 2 &&
                    int.TryParse(parts[0], out var hours) &&
                    int.TryParse(parts[1], out var minutePart) &&
                    minutePart is >= 0 and <= 59)
                {
                    return hours + (minutePart / 60m);
                }

                // Otherwise treat as decimal (e.g., 2.5 = 2.5 hours)
                if (decimal.TryParse(input, out var decimalHours))
                {
                    return decimalHours;
                }
            }
        }

        // Plain number
        if (decimal.TryParse(input, out var plainHours))
        {
            return plainHours;
        }

        return 0;
    }

    /// <summary>
    /// Formats decimal hours to H:MM display format.
    /// Returns null for zero/no hours.
    /// </summary>
    private static string? FormatHoursToTime(decimal hours)
    {
        if (hours == 0)
            return null;

        var totalMinutes = (int)Math.Round(hours * 60);
        var h = totalMinutes / 60;
        var m = totalMinutes % 60;
        return $"{h}:{m:D2}";
    }

}
