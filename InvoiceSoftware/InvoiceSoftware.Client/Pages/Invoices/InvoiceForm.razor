@page "/invoices/new"

@inject ICall<GetClients, PaginatedResponse<ClientDto>> GetClientsCall
@inject ICall<GetUnbilledTimeEntries, List<UnbilledTimeEntryDto>> GetUnbilledTimeEntriesCall
@inject ICall<GetUnbilledExpenses, List<ExpenseSummaryDto>> GetUnbilledExpensesCall
@inject ICall<GetProducts, PaginatedResponse<ProductDto>> GetProductsCall
@inject ICall<CreateInvoice, Guid> CreateInvoiceCall
@inject ICall<GetInvoiceTemplates, List<InvoiceTemplateDto>> GetInvoiceTemplatesCall

<PageTitle>New Invoice - InvoicePro</PageTitle>

<div class="space-y-6">
    <!-- Header with Breadcrumbs -->
    <PageHeader Title="Create Invoice"
                Description="Generate an invoice from unbilled time entries"
                ShowBackButton="true"
                BackUrl="invoices"
                Breadcrumbs="@(new List<PageHeader.BreadcrumbItem> { new("Invoices", "/invoices"), new("New Invoice") })" />

    <!-- Progress Steps -->
    <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-100 dark:border-slate-700 p-4">
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="@GetStepClass(1)">
                    <span class="text-sm font-semibold">1</span>
                </div>
                <span class="text-sm font-medium @(CurrentStep >= 1 ? "text-gray-900 dark:text-slate-100" : "text-gray-400 dark:text-slate-500")">Select Client</span>
            </div>
            <div class="flex-1 h-0.5 mx-4 @(CurrentStep >= 2 ? "bg-indigo-500" : "bg-gray-200 dark:bg-slate-600")"></div>
            <div class="flex items-center gap-3">
                <div class="@GetStepClass(2)">
                    <span class="text-sm font-semibold">2</span>
                </div>
                <span class="text-sm font-medium @(CurrentStep >= 2 ? "text-gray-900 dark:text-slate-100" : "text-gray-400 dark:text-slate-500")">Select Items</span>
            </div>
            <div class="flex-1 h-0.5 mx-4 @(CurrentStep >= 3 ? "bg-indigo-500" : "bg-gray-200 dark:bg-slate-600")"></div>
            <div class="flex items-center gap-3">
                <div class="@GetStepClass(3)">
                    <span class="text-sm font-semibold">3</span>
                </div>
                <span class="text-sm font-medium @(CurrentStep >= 3 ? "text-gray-900 dark:text-slate-100" : "text-gray-400 dark:text-slate-500")">Details</span>
            </div>
        </div>
    </div>

    @if (_isLoading)
    {
        <div class="flex justify-center py-12">
            <div class="w-8 h-8 border-2 border-gray-200 border-t-indigo-600 rounded-full animate-spin"></div>
        </div>
    }
    else
    {
        <!-- Step 1: Select Client -->
        <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, #eef2ff 0%, #e0e7ff 100%);">
                        <svg class="w-4 h-4 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                        </svg>
                    </div>
                    <h2 class="text-sm font-semibold text-gray-900">Select Client</h2>
                </div>
            </div>
            <div class="p-6">
                <select @bind="_selectedClientId" @bind:after="OnClientSelected"
                        class="w-full px-4 py-3 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl transition-all duration-200 focus:outline-none focus:border-indigo-400 focus:ring-4 focus:ring-indigo-500/10 hover:border-gray-300 cursor-pointer">
                    <option value="">Select a client...</option>
                    @if (_clients != null)
                    {
                        @foreach (var client in _clients)
                        {
                            <option value="@client.Id">@client.Name</option>
                        }
                    }
                </select>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_selectedClientId))
        {
            <!-- Step 2: Select Time Entries -->
            <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-100 dark:border-slate-700 overflow-hidden">
                <div class="px-6 py-4 border-b border-gray-100 dark:border-slate-700 bg-gray-50/50 dark:bg-slate-700/50">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%);">
                            <svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                        </div>
                        <h2 class="text-sm font-semibold text-gray-900 dark:text-slate-100">Select Time Entries</h2>
                    </div>
                </div>

                <TimeEntrySelector Entries="_allUnbilledEntries"
                                   Currency="@ClientCurrency"
                                   IsLoading="_isLoadingEntries"
                                   SelectedEntryIds="_selectedEntries"
                                   SelectedEntryIdsChanged="OnTimeEntrySelectionChanged" />
            </div>

            <!-- Step 2b: Select Expenses -->
            <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-100 dark:border-slate-700 overflow-hidden">
                <div class="px-6 py-4 border-b border-gray-100 dark:border-slate-700 bg-gray-50/50 dark:bg-slate-700/50">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);">
                            <svg class="w-4 h-4 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                            </svg>
                        </div>
                        <h2 class="text-sm font-semibold text-gray-900 dark:text-slate-100">Select Expenses</h2>
                        <span class="text-xs text-gray-500 dark:text-slate-400">(Optional)</span>
                    </div>
                </div>

                <ExpenseSelector Expenses="_allUnbilledExpenses"
                                 Currency="@ClientCurrency"
                                 IsLoading="_isLoadingExpenses"
                                 SelectedExpenseIds="_selectedExpenses"
                                 SelectedExpenseIdsChanged="OnExpenseSelectionChanged" />
            </div>

            <!-- Step 2c: Add Products -->
            <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-100 dark:border-slate-700 overflow-hidden">
                <div class="px-6 py-4 border-b border-gray-100 dark:border-slate-700 bg-gray-50/50 dark:bg-slate-700/50">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);">
                            <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                            </svg>
                        </div>
                        <h2 class="text-sm font-semibold text-gray-900 dark:text-slate-100">Add Products</h2>
                        <span class="text-xs text-gray-500 dark:text-slate-400">(Optional)</span>
                    </div>
                </div>

                <ProductSelector Products="_availableProducts"
                                 Currency="@ClientCurrency"
                                 IsLoading="_isLoadingProducts"
                                 LineItems="_productLineItems"
                                 LineItemsChanged="OnProductLineItemsChanged" />
            </div>

            @if (HasSelectedItems)
            {
                <!-- Step 3: Invoice Details -->
                <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden">
                    <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, #eef2ff 0%, #e0e7ff 100%);">
                                <svg class="w-4 h-4 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                </svg>
                            </div>
                            <h2 class="text-sm font-semibold text-gray-900">Invoice Details</h2>
                        </div>
                    </div>
                    <div class="p-6 space-y-5">
                        <div class="grid grid-cols-1 gap-5 sm:grid-cols-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-2">Issue Date</label>
                                <input type="date" @bind="_issueDate"
                                       class="w-full px-4 py-3 text-sm text-gray-900 dark:text-slate-100 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-600 rounded-xl transition-all duration-200 focus:outline-none focus:border-indigo-400 focus:ring-4 focus:ring-indigo-500/10 hover:border-gray-300 dark:hover:border-slate-500" />
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-2">Due Date</label>
                                <input type="date" @bind="_dueDate"
                                       class="w-full px-4 py-3 text-sm text-gray-900 dark:text-slate-100 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-600 rounded-xl transition-all duration-200 focus:outline-none focus:border-indigo-400 focus:ring-4 focus:ring-indigo-500/10 hover:border-gray-300 dark:hover:border-slate-500" />
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-2">Tax Rate (%)</label>
                                <input type="number" step="0.01" @bind="_taxRate"
                                       class="w-full px-4 py-3 text-sm text-gray-900 dark:text-slate-100 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-600 rounded-xl transition-all duration-200 focus:outline-none focus:border-indigo-400 focus:ring-4 focus:ring-indigo-500/10 hover:border-gray-300 dark:hover:border-slate-500" />
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-2">Template</label>
                                <select @bind="_selectedTemplateId"
                                        class="w-full px-4 py-3 text-sm text-gray-900 dark:text-slate-100 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-600 rounded-xl transition-all duration-200 focus:outline-none focus:border-indigo-400 focus:ring-4 focus:ring-indigo-500/10 hover:border-gray-300 dark:hover:border-slate-500 cursor-pointer">
                                    <option value="">Default</option>
                                    @if (_templates != null)
                                    {
                                        @foreach (var template in _templates)
                                        {
                                            <option value="@template.Id">
                                                @template.Name @(template.IsDefault ? "(Default)" : "")
                                            </option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-2">Notes</label>
                            <textarea @bind="_notes" rows="3" placeholder="Add any notes to appear on the invoice..."
                                      class="w-full px-4 py-3 text-sm text-gray-900 dark:text-slate-100 bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-600 rounded-xl transition-all duration-200 placeholder:text-gray-400 dark:placeholder:text-slate-500 focus:outline-none focus:border-indigo-400 focus:ring-4 focus:ring-indigo-500/10 hover:border-gray-300 dark:hover:border-slate-500 resize-none"></textarea>
                        </div>
                    </div>
                </div>

                <!-- Summary -->
                <div class="bg-white dark:bg-slate-800 rounded-2xl border border-gray-100 dark:border-slate-700 overflow-hidden">
                    <div class="px-6 py-4 border-b border-gray-100 dark:border-slate-700 bg-gray-50/50 dark:bg-slate-700/50">
                        <h2 class="text-sm font-semibold text-gray-900 dark:text-slate-100">Invoice Summary</h2>
                    </div>
                    <div class="p-6">
                        <dl class="space-y-3">
                            @if (_selectedEntries.Any())
                            {
                                <div class="flex justify-between items-center">
                                    <dt class="text-sm text-gray-600 dark:text-slate-400">Time Entries (@_selectedEntries.Count)</dt>
                                    <dd class="text-sm font-medium text-gray-900 dark:text-slate-100">@CurrencyExtensions.GetSymbol(ClientCurrency)@TimeSubtotal.ToString("N2")</dd>
                                </div>
                            }
                            @if (_selectedExpenses.Any())
                            {
                                <div class="flex justify-between items-center">
                                    <dt class="text-sm text-gray-600 dark:text-slate-400">Expenses (@_selectedExpenses.Count)</dt>
                                    <dd class="text-sm font-medium text-gray-900 dark:text-slate-100">@CurrencyExtensions.GetSymbol(ClientCurrency)@ExpenseSubtotal.ToString("N2")</dd>
                                </div>
                            }
                            @if (ValidProductLineItems.Any())
                            {
                                <div class="flex justify-between items-center">
                                    <dt class="text-sm text-gray-600 dark:text-slate-400">Products (@ValidProductLineItems.Count())</dt>
                                    <dd class="text-sm font-medium text-gray-900 dark:text-slate-100">@CurrencyExtensions.GetSymbol(ClientCurrency)@ProductSubtotal.ToString("N2")</dd>
                                </div>
                            }
                            <div class="flex justify-between items-center pt-2 border-t border-gray-100 dark:border-slate-700">
                                <dt class="text-sm text-gray-600 dark:text-slate-400">Subtotal</dt>
                                <dd class="text-sm font-medium text-gray-900 dark:text-slate-100">@CurrencyExtensions.GetSymbol(ClientCurrency)@Subtotal.ToString("N2")</dd>
                            </div>
                            <div class="flex justify-between items-center">
                                <dt class="text-sm text-gray-600 dark:text-slate-400">Tax (@_taxRate%)</dt>
                                <dd class="text-sm font-medium text-gray-900 dark:text-slate-100">@CurrencyExtensions.GetSymbol(ClientCurrency)@TaxAmount.ToString("N2")</dd>
                            </div>
                            <div class="flex justify-between items-center pt-3 border-t border-gray-100 dark:border-slate-700">
                                <dt class="text-base font-semibold text-gray-900 dark:text-slate-100">Total</dt>
                                <dd class="text-xl font-bold text-indigo-600 dark:text-indigo-400">@CurrencyExtensions.GetSymbol(ClientCurrency)@Total.ToString("N2")</dd>
                            </div>
                        </dl>
                    </div>
                </div>

                <!-- Error Message -->
                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="bg-red-50 border border-red-100 rounded-xl p-4">
                        <div class="flex gap-3">
                            <svg class="h-5 w-5 text-red-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            <p class="text-sm text-red-700">@_errorMessage</p>
                        </div>
                    </div>
                }

                <!-- Actions -->
                <div class="flex justify-end gap-3">
                    <a href="invoices" class="px-5 py-2.5 text-sm font-medium text-gray-700 bg-white border border-gray-200 rounded-xl hover:bg-gray-50 hover:border-gray-300 transition-all duration-200">
                        Cancel
                    </a>
                    <button @onclick="CreateInvoice" disabled="@_isCreating"
                            class="inline-flex items-center justify-center gap-2 px-5 py-2.5 text-sm font-medium text-white rounded-xl shadow-md transition-all duration-200 hover:shadow-lg active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:shadow-md disabled:active:scale-100"
                            style="background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); box-shadow: 0 4px 14px rgba(99, 102, 241, 0.35);">
                        @if (_isCreating)
                        {
                            <div class="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>
                            <span>Creating...</span>
                        }
                        else
                        {
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                            </svg>
                            <span>Create Invoice</span>
                        }
                    </button>
                </div>
            }
        }
    }
</div>

@code {
    private List<ClientDto>? _clients;
    private List<UnbilledTimeEntryDto>? _allUnbilledEntries;
    private List<ExpenseSummaryDto>? _allUnbilledExpenses;
    private List<ProductDto>? _availableProducts;
    private List<InvoiceTemplateDto>? _templates;
    private HashSet<Guid> _selectedEntries = [];
    private HashSet<Guid> _selectedExpenses = [];
    private List<ProductSelector.ProductLineItemModel> _productLineItems = [];
    private string _selectedClientId = "";
    private string _selectedTemplateId = "";
    private DateOnly _issueDate = DateOnly.FromDateTime(DateTime.Today);
    private DateOnly _dueDate = DateOnly.FromDateTime(DateTime.Today.AddDays(30));
    private decimal _taxRate;
    private string? _notes;
    private bool _isLoading = true;
    private bool _isLoadingEntries;
    private bool _isLoadingExpenses;
    private bool _isLoadingProducts;
    private bool _isCreating;
    private string? _errorMessage;

    private string ClientCurrency =>
        _clients?.FirstOrDefault(c => c.Id.ToString() == _selectedClientId)?.Currency ?? "USD";

    private bool HasSelectedItems => _selectedEntries.Any() || _selectedExpenses.Any() || ValidProductLineItems.Any();

    private IEnumerable<ProductSelector.ProductLineItemModel> ValidProductLineItems =>
        _productLineItems.Where(li => !string.IsNullOrEmpty(li.Description));

    private int CurrentStep => string.IsNullOrEmpty(_selectedClientId) ? 1 : HasSelectedItems ? 3 : 2;

    private decimal TimeSubtotal => _allUnbilledEntries != null
        ? _allUnbilledEntries.Where(e => _selectedEntries.Contains(e.Id)).Sum(e => e.Hours * e.HourlyRate)
        : 0;

    private decimal ExpenseSubtotal => _allUnbilledExpenses != null
        ? _allUnbilledExpenses.Where(e => _selectedExpenses.Contains(e.Id)).Sum(e => e.Amount + e.TaxAmount)
        : 0;

    private decimal ProductSubtotal => ValidProductLineItems.Sum(li => li.Quantity * li.UnitPrice);

    private decimal Subtotal => TimeSubtotal + ExpenseSubtotal + ProductSubtotal;

    private decimal TaxAmount => Subtotal * (_taxRate / 100);

    private decimal Total => Subtotal + TaxAmount;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Load clients, products, and templates in parallel
            var clientsTask = GetClientsCall.Call(new GetClients { PageSize = 1000 });
            var productsTask = GetProductsCall.Call(new GetProducts { ActiveOnly = true, PageSize = 1000 });
            var templatesTask = GetInvoiceTemplatesCall.Call(new GetInvoiceTemplates { IncludeSystem = true });

            await Task.WhenAll(clientsTask, productsTask, templatesTask);

            _clients = (await clientsTask)?.Items ?? [];
            _availableProducts = (await productsTask)?.Items?.ToList() ?? [];
            _templates = await templatesTask ?? [];

            // Pre-select default template if available
            var defaultTemplate = _templates?.FirstOrDefault(t => t.IsDefault);
            if (defaultTemplate != null)
            {
                _selectedTemplateId = defaultTemplate.Id.ToString();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
            _clients = [];
            _availableProducts = [];
            _templates = [];
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnClientSelected()
    {
        if (string.IsNullOrEmpty(_selectedClientId))
        {
            _allUnbilledEntries = null;
            _allUnbilledExpenses = null;
            _selectedEntries.Clear();
            _selectedExpenses.Clear();
            _productLineItems.Clear();
            return;
        }

        _isLoadingEntries = true;
        _isLoadingExpenses = true;
        _selectedEntries.Clear();
        _selectedExpenses.Clear();
        _productLineItems.Clear();

        var clientId = Guid.Parse(_selectedClientId);

        // Load time entries
        try
        {
            var entries = await GetUnbilledTimeEntriesCall.Call(new GetUnbilledTimeEntries { ClientId = clientId });
            _allUnbilledEntries = entries.ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading entries: {ex.Message}");
            _allUnbilledEntries = [];
        }
        finally
        {
            _isLoadingEntries = false;
        }

        // Load expenses
        try
        {
            var expenses = await GetUnbilledExpensesCall.Call(new GetUnbilledExpenses { ClientId = clientId });
            _allUnbilledExpenses = expenses.ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading expenses: {ex.Message}");
            _allUnbilledExpenses = [];
        }
        finally
        {
            _isLoadingExpenses = false;
        }
    }

    private void OnTimeEntrySelectionChanged(HashSet<Guid> newSelection)
    {
        _selectedEntries = newSelection;
        StateHasChanged();
    }

    private void OnExpenseSelectionChanged(HashSet<Guid> newSelection)
    {
        _selectedExpenses = newSelection;
        StateHasChanged();
    }

    private void OnProductLineItemsChanged(List<ProductSelector.ProductLineItemModel> lineItems)
    {
        _productLineItems = lineItems;
        StateHasChanged();
    }

    private async Task CreateInvoice()
    {
        _isCreating = true;
        _errorMessage = null;

        try
        {
            var productLineItems = ValidProductLineItems
                .Select(li => new ProductLineItemRequest(
                    li.ProductId,
                    li.Description,
                    li.Quantity,
                    li.UnitPrice))
                .ToList();

            await CreateInvoiceCall.Call(new CreateInvoice
            {
                ClientId = Guid.Parse(_selectedClientId),
                TimeEntryIds = _selectedEntries.ToList(),
                ExpenseIds = _selectedExpenses.ToList(),
                ProductLineItems = productLineItems,
                IssueDate = _issueDate,
                DueDate = _dueDate,
                TaxRate = _taxRate,
                Notes = _notes,
                TemplateId = string.IsNullOrEmpty(_selectedTemplateId) ? null : Guid.Parse(_selectedTemplateId)
            });
            NavigationManager.NavigateTo("invoices");
        }
        catch (Exception ex)
        {
            _errorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            _isCreating = false;
        }
    }

    private string GetStepClass(int step) => CurrentStep >= step
        ? "w-8 h-8 rounded-full flex items-center justify-center bg-indigo-600 text-white"
        : "w-8 h-8 rounded-full flex items-center justify-center bg-gray-100 dark:bg-slate-600 text-gray-400 dark:text-slate-300";
}
