@page "/invoice/view/{Token:guid}"
@layout EmptyLayout

@inject ICall<GetPublicInvoice, PublicInvoiceDto?> GetPublicInvoiceCall

<PageTitle>@(_invoice != null ? $"Invoice {_invoice.InvoiceNumber}" : "Invoice")</PageTitle>

<div class="min-h-screen bg-gradient-to-br from-slate-50 to-slate-100 dark:from-slate-900 dark:to-slate-800 py-8 px-4">
    <div class="max-w-4xl mx-auto">
        @if (_isLoading)
        {
            <div class="flex justify-center py-20">
                <div class="w-8 h-8 border-2 border-gray-200 border-t-indigo-600 rounded-full animate-spin"></div>
            </div>
        }
        else if (_invoice == null)
        {
            <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-xl border border-gray-100 dark:border-slate-700">
                <div class="text-center py-16 px-6">
                    <div class="mx-auto w-16 h-16 rounded-2xl flex items-center justify-center mb-4"
                         style="background: linear-gradient(135deg, #fef2f2 0%, #fee2e2 100%);">
                        <svg class="h-8 w-8 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                    <h3 class="text-base font-semibold text-gray-900 dark:text-white">Invoice not found</h3>
                    <p class="mt-1 text-sm text-gray-500 dark:text-slate-400">This invoice link may have expired or is invalid.</p>
                </div>
            </div>
        }
        else
        {
            <!-- Invoice Document -->
            <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-xl border border-gray-100 dark:border-slate-700 overflow-hidden">
                <!-- Use shared InvoiceViewContent component with ALL data -->
                <InvoiceViewContent
                    InvoiceNumber="@_invoice.InvoiceNumber"
                    Status="@_invoice.Status"
                    Currency="@_invoice.Currency"
                    IssueDate="@_invoice.IssueDate"
                    DueDate="@_invoice.DueDate"
                    PaidDate="@_invoice.PaidDate"
                    BusinessName="@_invoice.BusinessName"
                    BusinessAddress="@_invoice.BusinessAddress"
                    BusinessEmail="@_invoice.BusinessEmail"
                    BusinessPhone="@_invoice.BusinessPhone"
                    BusinessLogo="@_invoice.BusinessLogo"
                    TaxNumber="@_invoice.TaxNumber"
                    RegistrationNumber="@_invoice.RegistrationNumber"
                    ClientName="@_invoice.ClientName"
                    ClientCompanyName="@_invoice.ClientCompanyName"
                    ClientAddress="@_invoice.ClientAddress"
                    ClientEmail="@_invoice.ClientEmail"
                    Subtotal="@_invoice.Subtotal"
                    TaxRate="@_invoice.TaxRate"
                    TaxAmount="@_invoice.TaxAmount"
                    Total="@_invoice.Total"
                    Notes="@_invoice.Notes"
                    LineItems="@_invoice.LineItems"
                    ExpenseLineItems="@_invoice.ExpenseLineItems"
                    ProductLineItems="@_invoice.ProductLineItems"
                    PrimaryColor="@PrimaryColor"
                    AccentColor="@AccentColor"
                    ShowLogo="@ShowLogo"
                    ShowItemDescriptions="@ShowItemDescriptions"
                    HeaderLayout="@HeaderLayout"
                    ItemsLayout="@ItemsLayout"
                    FooterLayout="@FooterLayout"
                    PayPalMeUsername="@_invoice.PayPalMeUsername"
                    WiseEmail="@_invoice.WiseEmail"
                    RevolutUsername="@_invoice.RevolutUsername"
                    DefaultCurrency="@_invoice.DefaultCurrency"
                    VndToDefaultCurrencyRate="@_invoice.VndToDefaultCurrencyRate"
                    CurrencyPaymentSettings="@_invoice.CurrencyPaymentSettings" />
            </div>
            
            <!-- Powered by footer -->
            <div class="mt-6 text-center">
                <p class="text-xs text-gray-400 dark:text-slate-500">
                    Powered by <span class="font-semibold">Invoice<span class="text-indigo-500">Pro</span></span>
                </p>
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public Guid Token { get; set; }

    private PublicInvoiceDto? _invoice;
    private bool _isLoading = true;

    // Template color helpers
    private string PrimaryColor => _invoice?.Template?.PrimaryColor ?? "#4f46e5";
    private string AccentColor => _invoice?.Template?.AccentColor ?? "#059669";

    // Template layout helpers
    private string HeaderLayout => _invoice?.Template?.HeaderLayout?.ToLowerInvariant() ?? "standard";
    private string ItemsLayout => _invoice?.Template?.ItemsLayout?.ToLowerInvariant() ?? "standard";
    private string FooterLayout => _invoice?.Template?.FooterLayout?.ToLowerInvariant() ?? "standard";
    private bool ShowLogo => _invoice?.Template?.ShowLogo ?? true;
    private bool ShowItemDescriptions => _invoice?.Template?.ShowItemDescriptions ?? true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _invoice = await GetPublicInvoiceCall.Call(new GetPublicInvoice { Token = Token });
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading public invoice: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }
}
