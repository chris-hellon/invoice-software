@page "/settings/languages"

@inject ICall<GetSupportedLanguages, List<LanguageDto>> GetLanguagesCall
@inject ICall<GetUserLanguageSettings, UserLanguageSettingsDto?> GetSettingsCall
@inject ICall<UpdateUserLanguageSettings> UpdateSettingsCall

<PageTitle>Language Settings - InvoicePro</PageTitle>

<div class="space-y-6">
    <PageHeader Title="Language Settings"
                Description="Configure language preferences for your invoices and estimates."
                Breadcrumbs="@(new List<PageHeader.BreadcrumbItem> { new("Settings"), new("Languages") })" />

    @if (_isLoading)
    {
        <LoadingSpinner Padding="py-20" />
    }
    else
    {
        <form @onsubmit="SaveAsync">
            <div class="space-y-6">
                <Card Title="Language Preferences" Description="Choose which languages to use for different document types.">
                    <div class="space-y-6">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-2">Default Language</label>
                            <p class="text-xs text-gray-500 dark:text-slate-400 mb-2">The primary language used throughout the application.</p>
                            <select @bind="_defaultLanguage" class="w-full px-4 py-2.5 bg-gray-50 dark:bg-slate-700 border-0 rounded-xl focus:ring-2 focus:ring-indigo-500/20 text-gray-900 dark:text-slate-100">
                                @foreach (var lang in _languages)
                                {
                                    <option value="@lang.Code">@lang.Name (@lang.NativeName)</option>
                                }
                            </select>
                        </div>

                        <div class="border-t border-gray-100 dark:border-slate-700 pt-6">
                            <h4 class="text-sm font-medium text-gray-900 dark:text-slate-100 mb-4">Document Languages</h4>
                            <p class="text-xs text-gray-500 dark:text-slate-400 mb-4">
                                These settings determine the language used for labels and text on generated PDFs.
                            </p>

                            <div class="space-y-4">
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-2">Invoice Language</label>
                                    <select @bind="_invoiceLanguage" class="w-full px-4 py-2.5 bg-gray-50 dark:bg-slate-700 border-0 rounded-xl focus:ring-2 focus:ring-indigo-500/20 text-gray-900 dark:text-slate-100">
                                        @foreach (var lang in _languages)
                                        {
                                            <option value="@lang.Code">@lang.Name (@lang.NativeName)</option>
                                        }
                                    </select>
                                </div>

                                <div>
                                    <label class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-2">Estimate Language</label>
                                    <select @bind="_estimateLanguage" class="w-full px-4 py-2.5 bg-gray-50 dark:bg-slate-700 border-0 rounded-xl focus:ring-2 focus:ring-indigo-500/20 text-gray-900 dark:text-slate-100">
                                        @foreach (var lang in _languages)
                                        {
                                            <option value="@lang.Code">@lang.Name (@lang.NativeName)</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                </Card>

                <!-- Language Preview -->
                <Card Title="Preview" Description="Sample labels in the selected invoice language.">
                    <div class="bg-gray-50 dark:bg-slate-700 rounded-xl p-4">
                        <div class="grid grid-cols-2 gap-4 text-sm">
                            <div>
                                <span class="text-gray-500 dark:text-slate-400">Invoice:</span>
                                <span class="ml-2 font-medium text-gray-900 dark:text-slate-100">@GetLocalizedLabel("Invoice")</span>
                            </div>
                            <div>
                                <span class="text-gray-500 dark:text-slate-400">Date:</span>
                                <span class="ml-2 font-medium text-gray-900 dark:text-slate-100">@GetLocalizedLabel("Date")</span>
                            </div>
                            <div>
                                <span class="text-gray-500 dark:text-slate-400">Due Date:</span>
                                <span class="ml-2 font-medium text-gray-900 dark:text-slate-100">@GetLocalizedLabel("DueDate")</span>
                            </div>
                            <div>
                                <span class="text-gray-500 dark:text-slate-400">Total:</span>
                                <span class="ml-2 font-medium text-gray-900 dark:text-slate-100">@GetLocalizedLabel("Total")</span>
                            </div>
                            <div>
                                <span class="text-gray-500 dark:text-slate-400">Subtotal:</span>
                                <span class="ml-2 font-medium text-gray-900 dark:text-slate-100">@GetLocalizedLabel("Subtotal")</span>
                            </div>
                            <div>
                                <span class="text-gray-500 dark:text-slate-400">Tax:</span>
                                <span class="ml-2 font-medium text-gray-900 dark:text-slate-100">@GetLocalizedLabel("Tax")</span>
                            </div>
                        </div>
                    </div>
                </Card>

                @if (!string.IsNullOrEmpty(_successMessage))
                {
                    <div class="rounded-xl bg-emerald-50 dark:bg-emerald-900/20 p-4">
                        <div class="flex items-center">
                            <svg class="h-5 w-5 text-emerald-400" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                            </svg>
                            <p class="ml-3 text-sm font-medium text-emerald-700 dark:text-emerald-400">@_successMessage</p>
                        </div>
                    </div>
                }

                <!-- Actions -->
                <div class="flex items-center justify-end gap-3">
                    <PrimaryButton ButtonType="submit" Text="Save Settings" IsLoading="_isSaving" ShowIcon="false" />
                </div>
            </div>
        </form>
    }
</div>

<ErrorAlert Message="@_errorMessage" />

@code {
    private List<LanguageDto> _languages = new();
    private string _defaultLanguage = "en";
    private string _invoiceLanguage = "en";
    private string _estimateLanguage = "en";
    private bool _isLoading = true;
    private bool _isSaving;
    private string? _errorMessage;
    private string? _successMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _isLoading = true;
        try
        {
            _languages = await GetLanguagesCall.Call(new GetSupportedLanguages());

            var settings = await GetSettingsCall.Call(new GetUserLanguageSettings());
            if (settings != null)
            {
                _defaultLanguage = settings.DefaultLanguage;
                _invoiceLanguage = settings.InvoiceLanguage;
                _estimateLanguage = settings.EstimateLanguage;
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load settings: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SaveAsync()
    {
        _isSaving = true;
        _errorMessage = null;
        _successMessage = null;

        try
        {
            await UpdateSettingsCall.Call(new UpdateUserLanguageSettings
            {
                DefaultLanguage = _defaultLanguage,
                InvoiceLanguage = _invoiceLanguage,
                EstimateLanguage = _estimateLanguage
            });

            _successMessage = "Language settings saved successfully.";
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to save settings: {ex.Message}";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private string GetLocalizedLabel(string key)
    {
        // Sample translations for preview
        var translations = new Dictionary<string, Dictionary<string, string>>
        {
            ["en"] = new() { ["Invoice"] = "Invoice", ["Date"] = "Date", ["DueDate"] = "Due Date", ["Total"] = "Total", ["Subtotal"] = "Subtotal", ["Tax"] = "Tax" },
            ["es"] = new() { ["Invoice"] = "Factura", ["Date"] = "Fecha", ["DueDate"] = "Fecha de Vencimiento", ["Total"] = "Total", ["Subtotal"] = "Subtotal", ["Tax"] = "Impuesto" },
            ["fr"] = new() { ["Invoice"] = "Facture", ["Date"] = "Date", ["DueDate"] = "Date d'Echance", ["Total"] = "Total", ["Subtotal"] = "Sous-total", ["Tax"] = "Taxe" },
            ["de"] = new() { ["Invoice"] = "Rechnung", ["Date"] = "Datum", ["DueDate"] = "Falligkeitsdatum", ["Total"] = "Gesamt", ["Subtotal"] = "Zwischensumme", ["Tax"] = "Steuer" },
            ["zh"] = new() { ["Invoice"] = "发票", ["Date"] = "日期", ["DueDate"] = "到期日", ["Total"] = "总计", ["Subtotal"] = "小计", ["Tax"] = "税" },
            ["vi"] = new() { ["Invoice"] = "Hoa don", ["Date"] = "Ngay", ["DueDate"] = "Ngay dao han", ["Total"] = "Tong cong", ["Subtotal"] = "Tam tinh", ["Tax"] = "Thue" }
        };

        if (translations.TryGetValue(_invoiceLanguage, out var langDict) && langDict.TryGetValue(key, out var label))
        {
            return label;
        }

        return translations["en"].GetValueOrDefault(key, key);
    }
}
