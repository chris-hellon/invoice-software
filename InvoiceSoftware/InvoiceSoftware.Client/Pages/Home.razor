@code {
    private bool _isLoading = true;
    private string _currency = "£";
    private DashboardMetricsDto? _metrics;
    private InvoiceStatusBreakdownDto? _statusBreakdown;
    private List<TopClientDto> _topClients = [];
    private List<InvoiceSummaryDto> _recentInvoices = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Load dashboard data in parallel for faster loading
            var metricsTask = GetMetricsCall.Call(new GetDashboardMetrics { Period = "month" });
            var statusTask = GetStatusBreakdownCall.Call(new GetInvoiceStatusBreakdown());
            var topClientsTask = GetTopClientsCall.Call(new GetTopClients { Count = 5 });
            var invoicesTask = GetInvoicesCall.Call(new GetInvoices { PageSize = 5 });

            await Task.WhenAll(metricsTask, statusTask, topClientsTask, invoicesTask);

            _metrics = await metricsTask;
            _statusBreakdown = await statusTask;
            _topClients = await topClientsTask ?? [];
            var invoicesResponse = await invoicesTask;
            _recentInvoices = invoicesResponse?.Items?.ToList() ?? [];
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading dashboard: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static string GetGreeting()
    {
        var hour = DateTime.Now.Hour;

        if (hour < 12)
            return "morning";

        if (hour < 17)
            return "afternoon";

        return "evening";
    }
}
