@page "/"
@inject ICall<GetDashboardMetrics, DashboardMetricsDto> GetMetricsCall
@inject ICall<GetInvoiceStatusBreakdown, InvoiceStatusBreakdownDto> GetStatusBreakdownCall
@inject ICall<GetTopClients, List<TopClientDto>> GetTopClientsCall
@inject ICall<GetRevenueChart, RevenueChartDataDto> GetRevenueChartCall
@inject ICall<GetInvoices, PaginatedResponse<InvoiceSummaryDto>> GetInvoicesCall
@inject ICall<GetEstimates, PaginatedResponse<EstimateSummaryDto>> GetEstimatesCall

<PageTitle>Dashboard - InvoicePro</PageTitle>

<div class="space-y-8">
    <!-- Header with Breadcrumbs -->
    <PageHeader Title="@($"Good {GetGreeting()}")"
                Description="Here's what's happening with your business today."
                Breadcrumbs="@(new List<PageHeader.BreadcrumbItem> { new("Dashboard") })">
        <a href="invoices/new" class="btn-primary">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
            </svg>
            Create Invoice
        </a>
    </PageHeader>

    <!-- Stats Cards -->
    @if (_isLoading)
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            @for (int i = 0; i < 4; i++)
            {
                <div class="stat-card animate-pulse">
                    <div class="h-12 w-12 bg-gray-100 dark:bg-slate-700 rounded-xl mb-4"></div>
                    <div class="h-8 w-16 bg-gray-100 dark:bg-slate-700 rounded mb-2"></div>
                    <div class="h-4 w-24 bg-gray-100 dark:bg-slate-700 rounded"></div>
                </div>
            }
        </div>
    }
    else if (_metrics != null)
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            <!-- Total Revenue -->
            <div class="group stat-card transition-all duration-200 hover:border-emerald-200 dark:hover:border-emerald-800 hover:shadow-lg hover:shadow-emerald-500/5">
                <div class="flex items-center justify-between mb-4">
                    <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-gradient-to-br from-emerald-50 to-emerald-100 dark:from-emerald-950/50 dark:to-emerald-900/50">
                        <svg class="w-6 h-6 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                    <a href="invoices" class="p-2 rounded-lg text-gray-400 dark:text-slate-500 hover:text-emerald-600 dark:hover:text-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-900/50 opacity-0 group-hover:opacity-100 transition-all">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                    </a>
                </div>
                <div class="stat-card-value text-emerald-600 dark:text-emerald-400">@_currency@_metrics.PaidRevenue.ToString("N0")</div>
                <p class="stat-card-label">Paid This Month</p>
            </div>

            <!-- Outstanding -->
            <div class="group stat-card transition-all duration-200 hover:border-amber-200 dark:hover:border-amber-800 hover:shadow-lg hover:shadow-amber-500/5">
                <div class="flex items-center justify-between mb-4">
                    <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-gradient-to-br from-amber-50 to-amber-100 dark:from-amber-950/50 dark:to-amber-900/50">
                        <svg class="w-6 h-6 text-amber-600 dark:text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                    <a href="invoices?status=Sent" class="p-2 rounded-lg text-gray-400 dark:text-slate-500 hover:text-amber-600 dark:hover:text-amber-400 hover:bg-amber-50 dark:hover:bg-amber-900/50 opacity-0 group-hover:opacity-100 transition-all">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                    </a>
                </div>
                <div class="stat-card-value text-amber-600 dark:text-amber-400">@_currency@_metrics.OutstandingAmount.ToString("N0")</div>
                <p class="stat-card-label">Awaiting Payment (@_metrics.OutstandingInvoices)</p>
            </div>

            <!-- Overdue -->
            <div class="group stat-card transition-all duration-200 hover:border-red-200 dark:hover:border-red-800 hover:shadow-lg hover:shadow-red-500/5">
                <div class="flex items-center justify-between mb-4">
                    <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-gradient-to-br from-red-50 to-red-100 dark:from-red-950/50 dark:to-red-900/50">
                        <svg class="w-6 h-6 text-red-600 dark:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                </div>
                <div class="stat-card-value text-red-600 dark:text-red-400">@_currency@_metrics.OverdueAmount.ToString("N0")</div>
                <p class="stat-card-label">Overdue (@_metrics.OverdueInvoices)</p>
            </div>

            <!-- Unbilled Hours -->
            <div class="group stat-card transition-all duration-200 hover:border-violet-200 dark:hover:border-violet-800 hover:shadow-lg hover:shadow-violet-500/5">
                <div class="flex items-center justify-between mb-4">
                    <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-gradient-to-br from-violet-50 to-violet-100 dark:from-violet-950/50 dark:to-violet-900/50">
                        <svg class="w-6 h-6 text-violet-600 dark:text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                    </div>
                    <a href="timesheet" class="p-2 rounded-lg text-gray-400 dark:text-slate-500 hover:text-violet-600 dark:hover:text-violet-400 hover:bg-violet-50 dark:hover:bg-violet-900/50 opacity-0 group-hover:opacity-100 transition-all">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                    </a>
                </div>
                <div class="stat-card-value">@_metrics.UnbilledHours.ToString("N1")h</div>
                <p class="stat-card-label">Unbilled Time (All Time)</p>
            </div>
        </div>
    }

    <!-- Invoice Status & Top Clients -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Invoice Status Breakdown -->
        <div class="lg:col-span-2 card overflow-hidden">
            <div class="card-header flex items-center justify-between">
                <h2 class="text-lg font-semibold text-gray-900 dark:text-slate-100" style="font-family: 'Plus Jakarta Sans', sans-serif;">Invoice Status</h2>
                <a href="invoices" class="text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300">View all invoices</a>
            </div>
            <div class="p-6">
                @if (_isLoading || _statusBreakdown == null)
                {
                    <div class="grid grid-cols-1 sm:grid-cols-4 gap-6 animate-pulse">
                        @for (int i = 0; i < 4; i++)
                        {
                            <div class="h-24 bg-gray-100 dark:bg-slate-700 rounded-xl"></div>
                        }
                    </div>
                }
                else
                {
                    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
                        <!-- Draft -->
                        <div class="p-4 rounded-xl bg-gray-50 dark:bg-slate-700/50">
                            <div class="flex items-center gap-2 mb-2">
                                <div class="w-3 h-3 rounded-full bg-gray-400"></div>
                                <span class="text-sm font-medium text-gray-600 dark:text-slate-400">Draft</span>
                            </div>
                            <p class="text-2xl font-bold text-gray-900 dark:text-slate-100">@_statusBreakdown.Draft</p>
                            <p class="text-xs text-gray-500 dark:text-slate-400">@_currency@_statusBreakdown.DraftTotal.ToString("N0")</p>
                        </div>

                        <!-- Sent -->
                        <div class="p-4 rounded-xl bg-blue-50 dark:bg-blue-900/30">
                            <div class="flex items-center gap-2 mb-2">
                                <div class="w-3 h-3 rounded-full bg-blue-500"></div>
                                <span class="text-sm font-medium text-blue-600 dark:text-blue-400">Sent</span>
                            </div>
                            <p class="text-2xl font-bold text-blue-700 dark:text-blue-300">@_statusBreakdown.Sent</p>
                            <p class="text-xs text-blue-500 dark:text-blue-400">@_currency@_statusBreakdown.SentTotal.ToString("N0")</p>
                        </div>

                        <!-- Paid -->
                        <div class="p-4 rounded-xl bg-emerald-50 dark:bg-emerald-900/30">
                            <div class="flex items-center gap-2 mb-2">
                                <div class="w-3 h-3 rounded-full bg-emerald-500"></div>
                                <span class="text-sm font-medium text-emerald-600 dark:text-emerald-400">Paid</span>
                            </div>
                            <p class="text-2xl font-bold text-emerald-700 dark:text-emerald-300">@_statusBreakdown.Paid</p>
                            <p class="text-xs text-emerald-500 dark:text-emerald-400">@_currency@_statusBreakdown.PaidTotal.ToString("N0")</p>
                        </div>

                        <!-- Overdue -->
                        <div class="p-4 rounded-xl bg-red-50 dark:bg-red-900/30">
                            <div class="flex items-center gap-2 mb-2">
                                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                                <span class="text-sm font-medium text-red-600 dark:text-red-400">Overdue</span>
                            </div>
                            <p class="text-2xl font-bold text-red-700 dark:text-red-300">@_statusBreakdown.Overdue</p>
                            <p class="text-xs text-red-500 dark:text-red-400">@_currency@_statusBreakdown.OverdueTotal.ToString("N0")</p>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Active Stats -->
        <div class="card overflow-hidden">
            <div class="card-header">
                <h2 class="text-lg font-semibold text-gray-900 dark:text-slate-100" style="font-family: 'Plus Jakarta Sans', sans-serif;">Activity</h2>
            </div>
            <div class="p-6 space-y-4">
                @if (_isLoading || _metrics == null)
                {
                    <div class="animate-pulse space-y-4">
                        @for (int i = 0; i < 3; i++)
                        {
                            <div class="h-12 bg-gray-100 dark:bg-slate-700 rounded-xl"></div>
                        }
                    </div>
                }
                else
                {
                    <div class="flex items-center justify-between p-3 rounded-xl bg-indigo-50 dark:bg-indigo-900/30">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-xl bg-indigo-100 dark:bg-indigo-900/50 flex items-center justify-center">
                                <svg class="w-5 h-5 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                                </svg>
                            </div>
                            <span class="text-sm font-medium text-gray-700 dark:text-slate-300">Total Clients</span>
                        </div>
                        <span class="text-lg font-bold text-indigo-600 dark:text-indigo-400">@_metrics.ActiveClients</span>
                    </div>

                    <div class="flex items-center justify-between p-3 rounded-xl bg-emerald-50 dark:bg-emerald-900/30">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-xl bg-emerald-100 dark:bg-emerald-900/50 flex items-center justify-center">
                                <svg class="w-5 h-5 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
                                </svg>
                            </div>
                            <span class="text-sm font-medium text-gray-700 dark:text-slate-300">Active Projects</span>
                        </div>
                        <span class="text-lg font-bold text-emerald-600 dark:text-emerald-400">@_metrics.ActiveProjects</span>
                    </div>

                    <div class="flex items-center justify-between p-3 rounded-xl bg-amber-50 dark:bg-amber-900/30">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-xl bg-amber-100 dark:bg-amber-900/50 flex items-center justify-center">
                                <svg class="w-5 h-5 text-amber-600 dark:text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                            </div>
                            <span class="text-sm font-medium text-gray-700 dark:text-slate-300">Hours This Month</span>
                        </div>
                        <span class="text-lg font-bold text-amber-600 dark:text-amber-400">@_metrics.BillableHours.ToString("N1")h</span>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Recent Invoices & Top Clients -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Recent Invoices -->
        <div class="lg:col-span-2 card overflow-hidden">
            <div class="card-header flex items-center justify-between">
                <h2 class="text-lg font-semibold text-gray-900 dark:text-slate-100" style="font-family: 'Plus Jakarta Sans', sans-serif;">Recent Invoices</h2>
                <a href="invoices/new" class="inline-flex items-center gap-1 text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                    </svg>
                    New Invoice
                </a>
            </div>
            @if (_isLoading)
            {
                <div class="p-6 space-y-3 animate-pulse">
                    @for (int i = 0; i < 4; i++)
                    {
                        <div class="h-16 bg-gray-100 dark:bg-slate-700 rounded-xl"></div>
                    }
                </div>
            }
            else if (_recentInvoices.Count == 0)
            {
                <div class="p-8 text-center">
                    <div class="mx-auto w-14 h-14 rounded-2xl flex items-center justify-center mb-4"
                         style="background: linear-gradient(135deg, #eef2ff 0%, #e0e7ff 100%);">
                        <svg class="h-7 w-7 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                    </div>
                    <p class="text-sm text-gray-500 dark:text-slate-400 mb-3">No invoices yet</p>
                    <a href="invoices/new" class="text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300">
                        Create your first invoice
                    </a>
                </div>
            }
            else
            {
                <div class="divide-y divide-gray-100 dark:divide-slate-700">
                    @foreach (var inv in _recentInvoices.Take(5))
                    {
                        var isOverdue = inv.Status != "Paid" && inv.Status != "Void" && inv.DueDate < DateOnly.FromDateTime(DateTime.Today);
                        <a href="invoices/@inv.Id" class="flex items-center justify-between px-6 py-4 hover:bg-gray-50 dark:hover:bg-[#2d2a4a]/50 transition-colors group">
                            <div class="flex items-center gap-4 min-w-0">
                                <div class="w-10 h-10 rounded-xl flex items-center justify-center @(isOverdue ? "bg-red-100 dark:bg-red-900/50" : inv.Status == "Paid" ? "bg-emerald-100 dark:bg-emerald-900/50" : "bg-indigo-100 dark:bg-indigo-900/50")">
                                    <svg class="w-5 h-5 @(isOverdue ? "text-red-600 dark:text-red-400" : inv.Status == "Paid" ? "text-emerald-600 dark:text-emerald-400" : "text-indigo-600 dark:text-indigo-400")" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        @if (isOverdue)
                                        {
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                        }
                                        else if (inv.Status == "Paid")
                                        {
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                        }
                                        else
                                        {
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                        }
                                    </svg>
                                </div>
                                <div class="min-w-0">
                                    <div class="flex items-center gap-2">
                                        <span class="font-medium text-gray-900 dark:text-slate-100">@inv.InvoiceNumber</span>
                                        <span class="@(isOverdue ? "badge-danger" : InvoiceStatusExtensions.Parse(inv.Status).GetBadgeClass())">
                                            @(isOverdue ? "Overdue" : inv.Status)
                                        </span>
                                    </div>
                                    <p class="text-sm text-gray-500 dark:text-slate-400 truncate">@inv.ClientName</p>
                                </div>
                            </div>
                            <div class="flex items-center gap-4">
                                <div class="text-right">
                                    <p class="font-semibold text-gray-900 dark:text-slate-100">@CurrencyExtensions.GetSymbol(inv.Currency)@inv.Total.ToString("N2")</p>
                                    <p class="text-xs text-gray-500 dark:text-slate-400">Due @inv.DueDate.ToString("MMM d")</p>
                                </div>
                                <svg class="w-4 h-4 text-gray-400 dark:text-slate-500 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                </svg>
                            </div>
                        </a>
                    }
                </div>
            }
        </div>

        <!-- Top Clients -->
        <div class="card overflow-hidden">
            <div class="card-header flex items-center justify-between">
                <h2 class="text-lg font-semibold text-gray-900 dark:text-slate-100" style="font-family: 'Plus Jakarta Sans', sans-serif;">Top Clients</h2>
                <a href="clients" class="text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300">View all</a>
            </div>
            @if (_isLoading)
            {
                <div class="p-4 space-y-3 animate-pulse">
                    @for (int i = 0; i < 5; i++)
                    {
                        <div class="h-12 bg-gray-100 dark:bg-slate-700 rounded-xl"></div>
                    }
                </div>
            }
            else if (_topClients.Count == 0)
            {
                <div class="p-8 text-center">
                    <p class="text-sm text-gray-500 dark:text-slate-400">No client data yet</p>
                </div>
            }
            else
            {
                <div class="divide-y divide-gray-100 dark:divide-slate-700">
                    @foreach (var client in _topClients)
                    {
                        <a href="clients/@client.ClientId" class="flex items-center justify-between px-4 py-3 hover:bg-gray-50 dark:hover:bg-[#2d2a4a]/50 transition-colors group">
                            <div class="flex items-center gap-3 min-w-0">
                                <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-indigo-500 to-purple-500 flex items-center justify-center text-white text-xs font-semibold">
                                    @client.ClientName[..1].ToUpper()
                                </div>
                                <div class="min-w-0">
                                    <p class="text-sm font-medium text-gray-900 dark:text-slate-100 truncate">@client.ClientName</p>
                                    <p class="text-xs text-gray-500 dark:text-slate-400">@client.InvoiceCount invoices</p>
                                </div>
                            </div>
                            <div class="text-right">
                                <p class="text-sm font-semibold text-gray-900 dark:text-slate-100">@CurrencyExtensions.GetSymbol(client.Currency)@client.TotalRevenue.ToString("N0")</p>
                            </div>
                        </a>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="card overflow-hidden">
        <div class="card-header">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-slate-100" style="font-family: 'Plus Jakarta Sans', sans-serif;">Quick Actions</h2>
        </div>
        <div class="p-4 grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-6 gap-3">
            <a href="invoices/new" class="flex flex-col items-center gap-2 p-4 rounded-xl hover:bg-indigo-50 dark:hover:bg-indigo-900/30 transition-colors group">
                <div class="w-12 h-12 rounded-xl bg-indigo-100 dark:bg-indigo-900/50 flex items-center justify-center group-hover:scale-105 transition-transform">
                    <svg class="w-6 h-6 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                </div>
                <span class="text-xs font-medium text-gray-700 dark:text-slate-300">New Invoice</span>
            </a>

            <a href="estimates/new" class="flex flex-col items-center gap-2 p-4 rounded-xl hover:bg-purple-50 dark:hover:bg-purple-900/30 transition-colors group">
                <div class="w-12 h-12 rounded-xl bg-purple-100 dark:bg-purple-900/50 flex items-center justify-center group-hover:scale-105 transition-transform">
