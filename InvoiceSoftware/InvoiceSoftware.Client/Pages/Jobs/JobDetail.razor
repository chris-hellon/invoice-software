@page "/jobs/{Id:guid}"

@inject ICall<GetJob, JobDetailDto> GetJobCall
@inject ICall<CreateJobTask, JobTaskDto> CreateJobTaskCall
@inject ICall<UpdateJobTask, JobTaskDto> UpdateJobTaskCall
@inject ICall<DeleteJobTask> DeleteJobTaskCall
@inject ICall<ToggleJobTaskComplete, JobTaskDto> ToggleJobTaskCall
@inject ICall<DeleteJob> DeleteJobCall
@inject NavigationManager NavigationManager

<PageTitle>@(_job != null ? _job.Name : "Job") - InvoicePro</PageTitle>

<div class="space-y-6">
    <!-- Header with Breadcrumbs -->
    <PageHeader Title="@(_job != null ? _job.Name : "Job")"
                Description="@(_job != null ? $"{_job.ProjectName}{(!string.IsNullOrEmpty(_job.SectionName) ? $" / {_job.SectionName}" : "")} • {_job.ClientName}" : "")"
                ShowBackButton="true"
                BackUrl="jobs"
                Breadcrumbs="@_breadcrumbs">
        @if (_job != null)
        {
            <div class="flex items-center gap-3">
                <a href="jobs/@Id/edit" class="btn-secondary">
                    <EditIcon />
                    Edit Job
                </a>
                <button @onclick="DeleteJobAsync" disabled="@_isDeleting"
                        class="inline-flex items-center gap-2 px-4 py-2.5 text-sm font-medium text-red-700 dark:text-red-300 bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 rounded-xl hover:bg-red-100 dark:hover:bg-red-900/50 transition-all duration-200 disabled:opacity-50 disabled:cursor-not-allowed">
                    @if (_isDeleting)
                    {
                        <div class="w-4 h-4 border-2 border-red-300 border-t-red-600 rounded-full animate-spin"></div>
                    }
                    else
                    {
                        <DeleteIcon />
                    }
                    Delete
                </button>
            </div>
        }
    </PageHeader>

    @if (_isLoading)
    {
        <div class="flex justify-center py-20">
            <div class="w-8 h-8 border-2 border-gray-200 border-t-indigo-600 rounded-full animate-spin"></div>
        </div>
    }
    else if (_job == null)
    {
        <div class="bg-white rounded-2xl border border-gray-100">
            <div class="text-center py-16 px-6">
                <div class="mx-auto w-16 h-16 rounded-2xl flex items-center justify-center mb-4"
                     style="background: linear-gradient(135deg, #fef2f2 0%, #fee2e2 100%);">
                    <svg class="h-8 w-8 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
                <h3 class="text-base font-semibold text-gray-900">Job not found</h3>
                <p class="mt-1 text-sm text-gray-500">The requested job could not be found.</p>
                <div class="mt-6">
                    <a href="jobs" class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium text-white rounded-xl transition-all duration-200 hover:shadow-lg active:scale-[0.98]"
                       style="background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); box-shadow: 0 4px 14px rgba(99, 102, 241, 0.35);">
                        Back to Jobs
                    </a>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Status & Priority Banner -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <!-- Status -->
            <div class="@GetStatusBannerClass(_job.Status) rounded-2xl px-5 py-4">
                <div class="flex items-center gap-3">
                    <div class="@GetStatusIconBgClass(_job.Status) w-10 h-10 rounded-xl flex items-center justify-center">
                        @if (_job.Status == "Active")
                        {
                            <svg class="w-5 h-5 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                            </svg>
                        }
                        else if (_job.Status == "OnHold")
                        {
                            <svg class="w-5 h-5 text-amber-600 dark:text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                        }
                        else
                        {
                            <svg class="w-5 h-5 text-sky-600 dark:text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                        }
                    </div>
                    <div>
                        <div class="text-xs text-gray-500 dark:text-slate-400 uppercase tracking-wide font-medium">Status</div>
                        <div class="@GetStatusTextClass(_job.Status) text-base font-semibold">@JobStatusExtensions.Parse(_job.Status).GetDisplayName()</div>
                    </div>
                </div>
            </div>

            <!-- Priority -->
            <div class="@GetPriorityBannerClass(_job.Priority) rounded-2xl px-5 py-4">
                <div class="flex items-center gap-3">
                    <div class="@GetPriorityIconBgClass(_job.Priority) w-10 h-10 rounded-xl flex items-center justify-center">
                        @if (_job.Priority == "Urgent")
                        {
                            <svg class="w-5 h-5 text-red-600 dark:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                            </svg>
                        }
                        else if (_job.Priority == "High")
                        {
                            <svg class="w-5 h-5 text-orange-600 dark:text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
                            </svg>
                        }
                        else if (_job.Priority == "Medium")
                        {
                            <svg class="w-5 h-5 text-yellow-600 dark:text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4" />
                            </svg>
                        }
                        else
                        {
                            <svg class="w-5 h-5 text-slate-500 dark:text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
                            </svg>
                        }
                    </div>
                    <div>
                        <div class="text-xs text-gray-500 dark:text-slate-400 uppercase tracking-wide font-medium">Priority</div>
                        <div class="@GetPriorityTextClass(_job.Priority) text-base font-semibold">@_job.Priority</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Job Info -->
            <div class="lg:col-span-1 space-y-6">
                <!-- Details Card -->
                <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden">
                    <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, #eef2ff 0%, #e0e7ff 100%);">
                                <svg class="w-4 h-4 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                                </svg>
                            </div>
                            <h3 class="text-sm font-semibold text-gray-900">Job Details</h3>
                        </div>
                    </div>
                    <div class="p-6 space-y-4">
                        <!-- Description -->
                        <div>
                            <div class="text-xs text-gray-500 dark:text-slate-400 mb-1">Description</div>
                            @if (!string.IsNullOrEmpty(_job.Description))
                            {
                                <p class="text-sm text-gray-900 dark:text-slate-100">@_job.Description</p>
                            }
                            else
                            {
                                <p class="text-sm text-gray-400 dark:text-slate-500 italic">No description</p>
                            }
                        </div>

                        <!-- Dates -->
                        <div class="grid grid-cols-2 gap-4 pt-3 border-t border-gray-100 dark:border-slate-700">
                            <div>
                                <div class="text-xs text-gray-500 dark:text-slate-400 mb-1">Start Date</div>
                                @if (_job.StartDate.HasValue)
                                {
                                    <div class="text-sm font-medium text-gray-900 dark:text-slate-100">@_job.StartDate.Value.ToString("MMM d, yyyy")</div>
                                }
                                else
                                {
                                    <div class="text-sm text-gray-400 dark:text-slate-500 italic">Not set</div>
                                }
                            </div>
                            <div>
                                <div class="text-xs text-gray-500 dark:text-slate-400 mb-1">Due Date</div>
                                @if (_job.DueDate.HasValue)
                                {
                                    <div class="text-sm font-medium text-gray-900 dark:text-slate-100">@_job.DueDate.Value.ToString("MMM d, yyyy")</div>
                                }
                                else
                                {
                                    <div class="text-sm text-gray-400 dark:text-slate-500 italic">Not set</div>
                                }
                            </div>
                        </div>

                        <!-- Time & Estimates -->
                        <div class="grid grid-cols-2 gap-4 pt-3 border-t border-gray-100 dark:border-slate-700">
                            <div>
                                <div class="text-xs text-gray-500 dark:text-slate-400 mb-1">Estimated Hours</div>
                                @if (_job.EstimatedHours.HasValue)
                                {
                                    <div class="text-sm font-medium text-gray-900 dark:text-slate-100">@_job.EstimatedHours.Value.ToString("N1") hrs</div>
                                }
                                else
                                {
                                    <div class="text-sm text-gray-400 dark:text-slate-500 italic">Not set</div>
                                }
                            </div>
                            <div>
                                <div class="text-xs text-gray-500 dark:text-slate-400 mb-1">Time Tracked</div>
                                <div class="text-sm font-medium text-gray-900 dark:text-slate-100">@_job.TotalHours.ToString("N2") hrs</div>
                                @if (_job.BilledHours > 0)
                                {
                                    <div class="text-xs text-gray-500 dark:text-slate-400">@_job.BilledHours.ToString("N2") hrs billed</div>
                                }
                            </div>
                        </div>

                        <!-- Hourly Rate -->
                        <div class="pt-3 border-t border-gray-100 dark:border-slate-700">
                            <div class="text-xs text-gray-500 dark:text-slate-400 mb-1">Hourly Rate Override</div>
                            @if (_job.HourlyRateOverride.HasValue)
                            {
                                <div class="text-sm font-medium text-gray-900 dark:text-slate-100">$@_job.HourlyRateOverride.Value.ToString("N2")/hr</div>
                            }
                            else
                            {
                                <div class="text-sm text-gray-400 dark:text-slate-500 italic">Using project/client rate</div>
                            }
                        </div>

                        <!-- Project & Client Links -->
                        <div class="grid grid-cols-2 gap-4 pt-3 border-t border-gray-100 dark:border-slate-700">
                            <div>
                                <div class="text-xs text-gray-500 dark:text-slate-400 mb-1">Project</div>
                                <a href="projects/@_job.ProjectId" class="text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 transition-colors">@_job.ProjectName</a>
                            </div>
                            <div>
                                <div class="text-xs text-gray-500 dark:text-slate-400 mb-1">Client</div>
                                <a href="clients/@_job.ClientId" class="text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 transition-colors">@_job.ClientName</a>
                            </div>
                        </div>

                        <!-- Section -->
                        @if (!string.IsNullOrEmpty(_job.SectionName))
                        {
                            <div class="pt-3 border-t border-gray-100 dark:border-slate-700">
                                <div class="text-xs text-gray-500 dark:text-slate-400 mb-1">Section</div>
                                <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-sm font-medium bg-indigo-100 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300">@_job.SectionName</span>
                            </div>
                        }
                    </div>
                </div>

                <!-- Notes Card -->
                <div class="card overflow-hidden">
                    <div class="card-header">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);">
                                <svg class="w-4 h-4 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                </svg>
                            </div>
                            <h3 class="text-sm font-semibold text-gray-900 dark:text-slate-100">Notes</h3>
                        </div>
                    </div>
                    <div class="p-6">
                        @if (!string.IsNullOrEmpty(_job.Notes))
                        {
                            <p class="text-sm text-gray-700 dark:text-slate-300 whitespace-pre-wrap">@_job.Notes</p>
                        }
                        else
                        {
                            <p class="text-sm text-gray-400 dark:text-slate-500 italic">No notes added</p>
                        }
                    </div>
                </div>
            </div>

            <!-- Tasks -->
            <div class="lg:col-span-2">
                <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden">
                    <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50 flex items-center justify-between">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%);">
                                <svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-sm font-semibold text-gray-900">Tasks</h3>
                                <p class="text-xs text-gray-500">
                                    @{
                                        var completedCount = _tasks.Count(t => t.IsComplete);
                                        var totalCount = _tasks.Count;
                                    }
                                    @completedCount of @totalCount completed
                                </p>
                            </div>
                        </div>
                        <button type="button" @onclick="ShowAddTaskForm" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-indigo-600 hover:text-indigo-700 hover:bg-indigo-50 rounded-lg transition-colors">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                            </svg>
                            Add Task
                        </button>
                    </div>

                    <!-- Progress Bar -->
                    @if (_tasks.Any())
                    {
                        <div class="px-6 py-3 bg-gray-50/30 border-b border-gray-100">
                            <div class="flex items-center gap-3">
                                <div class="flex-1 h-2 bg-gray-100 rounded-full overflow-hidden">
                                    @{
                                        var progressPercent = _tasks.Count > 0 ? (double)_tasks.Count(t => t.IsComplete) / _tasks.Count * 100 : 0;
                                    }
                                    <div class="h-full bg-emerald-500 rounded-full transition-all duration-300" style="width: @progressPercent.ToString("N0")%"></div>
                                </div>
                                <span class="text-xs font-medium text-gray-500">@progressPercent.ToString("N0")%</span>
                            </div>
                        </div>
                    }

                    <!-- Add Task Form -->
                    @if (_showAddTaskForm)
                    {
                        <div class="px-6 py-4 border-b border-gray-100 bg-indigo-50/30">
                            <div class="space-y-3">
                                <div>
                                    <input type="text" @bind="_newTaskTitle" @bind:event="oninput" placeholder="Task title..."
                                           class="w-full px-4 py-2.5 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl transition-all duration-200 placeholder:text-gray-400 focus:outline-none focus:border-indigo-400 focus:ring-4 focus:ring-indigo-500/10" />
                                </div>
                                <div>
                                    <textarea @bind="_newTaskDescription" placeholder="Description (optional)..." rows="2"
                                              class="w-full px-4 py-2.5 text-sm text-gray-900 bg-white border border-gray-200 rounded-xl transition-all duration-200 placeholder:text-gray-400 focus:outline-none focus:border-indigo-400 focus:ring-4 focus:ring-indigo-500/10 resize-none"></textarea>
                                </div>
                                <div class="flex items-center gap-2">
                                    <button type="button" @onclick="AddTask" disabled="@(string.IsNullOrWhiteSpace(_newTaskTitle) || _isSavingTask)"
                                            class="inline-flex items-center px-4 py-2 text-sm font-medium text-white rounded-xl disabled:opacity-50 disabled:cursor-not-allowed transition-all duration-200 hover:shadow-lg"
                                            style="background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); box-shadow: 0 4px 14px rgba(99, 102, 241, 0.35);">
                                        @if (_isSavingTask)
                                        {
                                            <svg class="animate-spin -ml-0.5 mr-2 h-4 w-4" fill="none" viewBox="0 0 24 24">
                                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                                            </svg>
                                        }
                                        Add Task
                                    </button>
                                    <button type="button" @onclick="CancelAddTask"
                                            class="px-4 py-2 text-sm font-medium text-gray-600 hover:text-gray-700 hover:bg-gray-100 rounded-xl transition-colors">
                                        Cancel
                                    </button>
                                </div>
                            </div>
                        </div>
                    }

                    <!-- Task List -->
                    @if (!_tasks.Any() && !_showAddTaskForm)
                    {
                        <div class="text-center py-12 px-6">
                            <div class="mx-auto w-14 h-14 rounded-2xl flex items-center justify-center mb-4"
                                 style="background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%);">
                                <svg class="h-7 w-7 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                            </div>
                            <h3 class="text-base font-semibold text-gray-900">No tasks yet</h3>
                            <p class="mt-1 text-sm text-gray-500">Break down this job into smaller tasks to track progress.</p>
                            <div class="mt-4">
                                <button type="button" @onclick="ShowAddTaskForm" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-indigo-600 hover:text-indigo-700 hover:bg-indigo-50 rounded-lg transition-colors">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                                    </svg>
                                    Add First Task
                                </button>
                            </div>
                        </div>
                    }
                    else if (_tasks.Any())
                    {
                        <div class="divide-y divide-gray-100">
                            @foreach (var task in _tasks.OrderBy(t => t.IsComplete).ThenBy(t => t.Order))
                            {
                                <div class="flex items-start gap-4 px-6 py-4 hover:bg-gray-50/50 transition-colors group @(task.IsComplete ? "bg-gray-50/30" : "")">
                                    <!-- Checkbox -->
                                    <button type="button" @onclick="() => ToggleTaskComplete(task)"
                                            class="mt-0.5 shrink-0 w-5 h-5 rounded-md border-2 transition-all duration-200 flex items-center justify-center @(task.IsComplete ? "bg-emerald-500 border-emerald-500" : "border-gray-300 hover:border-indigo-400")">
                                        @if (task.IsComplete)
                                        {
                                            <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                                            </svg>
                                        }
                                    </button>

                                    <!-- Task Content -->
                                    @if (_editingTaskId == task.Id)
                                    {
                                        <div class="flex-1 space-y-2">
                                            <input type="text" @bind="_editTaskTitle" @bind:event="oninput"
                                                   class="w-full px-3 py-2 text-sm text-gray-900 bg-white border border-gray-200 rounded-lg transition-all duration-200 focus:outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-500/10" />
                                            <textarea @bind="_editTaskDescription" rows="2"
                                                      class="w-full px-3 py-2 text-sm text-gray-900 bg-white border border-gray-200 rounded-lg transition-all duration-200 focus:outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-500/10 resize-none"></textarea>
                                            <div class="flex items-center gap-2">
                                                <button type="button" @onclick="SaveEditTask" disabled="@(string.IsNullOrWhiteSpace(_editTaskTitle) || _isSavingTask)"
                                                        class="px-3 py-1.5 text-xs font-medium text-white bg-indigo-600 hover:bg-indigo-700 rounded-lg disabled:opacity-50 transition-colors">
                                                    Save
                                                </button>
                                                <button type="button" @onclick="CancelEditTask"
                                                        class="px-3 py-1.5 text-xs font-medium text-gray-600 hover:bg-gray-100 rounded-lg transition-colors">
                                                    Cancel
                                                </button>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="flex-1 min-w-0">
                                            <div class="text-sm font-medium @(task.IsComplete ? "text-gray-400 line-through" : "text-gray-900")">@task.Title</div>
                                            @if (!string.IsNullOrEmpty(task.Description))
                                            {
                                                <p class="text-sm @(task.IsComplete ? "text-gray-400" : "text-gray-500") mt-0.5">@task.Description</p>
                                            }
                                            @if (task.CompletedAt.HasValue)
                                            {
                                                <p class="text-xs text-gray-400 mt-1">Completed @task.CompletedAt.Value.ToString("MMM d, yyyy 'at' h:mm tt")</p>
                                            }
                                        </div>
                                    }

                                    <!-- Actions -->
                                    @if (_editingTaskId != task.Id)
                                    {
                                        <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                                            <button type="button" @onclick="() => StartEditTask(task)"
                                                    class="p-1.5 text-gray-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-colors">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
