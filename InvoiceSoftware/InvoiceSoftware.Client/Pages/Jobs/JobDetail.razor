@code {
    [Parameter]
    public Guid Id { get; set; }

    private JobDetailDto? _job;
    private List<JobTaskDto> _tasks = [];
    private bool _isLoading = true;
    private bool _isDeleting;
    private List<PageHeader.BreadcrumbItem> _breadcrumbs = [];

    // Add task form
    private bool _showAddTaskForm;
    private string _newTaskTitle = "";
    private string? _newTaskDescription;
    private bool _isSavingTask;

    // Edit task form
    private Guid? _editingTaskId;
    private string _editTaskTitle = "";
    private string? _editTaskDescription;

    protected override async Task OnInitializedAsync()
    {
        _breadcrumbs =
        [
            new PageHeader.BreadcrumbItem("Jobs", "/jobs"),
            new PageHeader.BreadcrumbItem("Job Details")
        ];

        await LoadJob();
    }

    private async Task LoadJob()
    {
        try
        {
            _job = await GetJobCall.Call(new GetJob { Id = Id });
            if (_job != null)
            {
                _breadcrumbs[1] = new PageHeader.BreadcrumbItem(_job.Name);
                _tasks = _job.Tasks.ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading job: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ShowAddTaskForm()
    {
        _showAddTaskForm = true;
        _newTaskTitle = "";
        _newTaskDescription = null;
    }

    private void CancelAddTask()
    {
        _showAddTaskForm = false;
        _newTaskTitle = "";
        _newTaskDescription = null;
    }

    private async Task AddTask()
    {
        if (string.IsNullOrWhiteSpace(_newTaskTitle)) return;

        _isSavingTask = true;
        try
        {
            var result = await CreateJobTaskCall.Call(new CreateJobTask
            {
                JobId = Id,
                Title = _newTaskTitle.Trim(),
                Description = _newTaskDescription?.Trim()
            });

            if (result != null)
            {
                _tasks.Add(result);
                _showAddTaskForm = false;
                _newTaskTitle = "";
                _newTaskDescription = null;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error adding task: {ex.Message}");
        }
        finally
        {
            _isSavingTask = false;
        }
    }

    private void StartEditTask(JobTaskDto task)
    {
        _editingTaskId = task.Id;
        _editTaskTitle = task.Title;
        _editTaskDescription = task.Description;
    }

    private void CancelEditTask()
    {
        _editingTaskId = null;
        _editTaskTitle = "";
        _editTaskDescription = null;
    }

    private async Task SaveEditTask()
    {
        if (_editingTaskId == null || string.IsNullOrWhiteSpace(_editTaskTitle)) return;

        _isSavingTask = true;
        try
        {
            var result = await UpdateJobTaskCall.Call(new UpdateJobTask
            {
                JobId = Id,
                TaskId = _editingTaskId.Value,
                Title = _editTaskTitle.Trim(),
                Description = _editTaskDescription?.Trim()
            });

            if (result != null)
            {
                var index = _tasks.FindIndex(t => t.Id == _editingTaskId.Value);
                if (index >= 0)
                {
                    _tasks[index] = result;
                }
                _editingTaskId = null;
                _editTaskTitle = "";
                _editTaskDescription = null;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating task: {ex.Message}");
        }
        finally
        {
            _isSavingTask = false;
        }
    }

    private async Task ToggleTaskComplete(JobTaskDto task)
    {
        try
        {
            var result = await ToggleJobTaskCall.Call(new ToggleJobTaskComplete
            {
                JobId = Id,
                TaskId = task.Id
            });

            if (result != null)
            {
                var index = _tasks.FindIndex(t => t.Id == task.Id);
                if (index >= 0)
                {
                    _tasks[index] = result;
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error toggling task: {ex.Message}");
        }
    }

    private async Task DeleteTask(JobTaskDto task)
    {
        try
        {
            await DeleteJobTaskCall.Call(new DeleteJobTask
            {
                JobId = Id,
                TaskId = task.Id
            });

            _tasks.RemoveAll(t => t.Id == task.Id);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting task: {ex.Message}");
        }
    }

    private async Task DeleteJobAsync()
    {
        var confirmed = await ModalService.ShowAsync<bool>(
            typeof(DeleteConfirmationModal),
            "Delete Job",
            new Dictionary<string, object>
            {
                { "ItemName", _job?.Name ?? "this job" },
                { "WarningMessage", "All tasks and time entries associated with this job will be permanently deleted." }
            },
            new ModalOptions { Size = ModalSize.Small });

        if (!confirmed) return;

        _isDeleting = true;

        try
        {
            await DeleteJobCall.Call(new DeleteJob { Id = Id });
            NavigationManager.NavigateTo("jobs");
        }
        catch (Exception)
        {
            // ignored
        }
        finally
        {
            _isDeleting = false;
        }
    }

