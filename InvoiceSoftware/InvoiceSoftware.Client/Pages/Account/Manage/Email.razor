@page "/account/manage/email"

@inject ICall<GetEmail, EmailDto> GetEmailCall
@inject ICall<ChangeEmail> ChangeEmailCall
@inject ICall<SendVerificationEmail> SendVerificationEmailCall

<PageTitle>Email - InvoicePro</PageTitle>

<div class="space-y-6">
    <div>
        <h2 class="text-lg font-semibold text-gray-900 dark:text-slate-100">Email</h2>
        <p class="mt-1 text-sm text-gray-500 dark:text-slate-400">Manage your email address and verification status.</p>
    </div>

    @if (!string.IsNullOrEmpty(_statusMessage))
    {
        <div class="@(_isError ? "bg-red-50 dark:bg-red-900/30 border-red-200 dark:border-red-800 text-red-700 dark:text-red-300" : "bg-emerald-50 dark:bg-emerald-900/30 border-emerald-200 dark:border-emerald-800 text-emerald-700 dark:text-emerald-300") p-4 rounded-xl border text-sm">
            @_statusMessage
        </div>
    }

    @if (_isLoading)
    {
        <div class="flex justify-center py-8">
            <div class="w-8 h-8 border-4 border-indigo-200 dark:border-indigo-800 border-t-indigo-600 dark:border-t-indigo-400 rounded-full animate-spin"></div>
        </div>
    }
    else if (_emailDto is not null)
    {
        <!-- Current Email -->
        <div class="bg-gray-50 dark:bg-[#1a1827] rounded-xl p-4 border border-gray-200 dark:border-[#3d3a5c]">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-gray-700 dark:text-slate-300">Current Email</p>
                    <p class="mt-1 text-base text-gray-900 dark:text-slate-100">@_emailDto.Email</p>
                </div>
                <div class="flex items-center gap-2">
                    @if (_emailDto.IsConfirmed)
                    {
                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-emerald-100 dark:bg-emerald-900/50 text-emerald-700 dark:text-emerald-300">
                            <svg class="w-3.5 h-3.5 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                            </svg>
                            Verified
                        </span>
                    }
                    else
                    {
                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-amber-100 dark:bg-amber-900/50 text-amber-700 dark:text-amber-300">
                            <svg class="w-3.5 h-3.5 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                            </svg>
                            Unverified
                        </span>
                        <button @onclick="SendVerificationEmail" disabled="@_isSendingVerification"
                            class="text-sm text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 font-medium disabled:opacity-50">
                            @if (_isSendingVerification)
                            {
                                <span>Sending...</span>
                            }
                            else
                            {
                                <span>Resend verification</span>
                            }
                        </button>
                    }
                </div>
            </div>
        </div>

        <!-- Change Email Form -->
        <div class="border-t border-gray-200 dark:border-[#3d3a5c] pt-6">
            <h3 class="text-base font-medium text-gray-900 dark:text-slate-100 mb-4">Change Email Address</h3>
            <EditForm Model="_input" OnValidSubmit="OnSubmit" class="space-y-5">
                <DataAnnotationsValidator />

                <div>
                    <label for="newEmail" class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-2">New Email Address</label>
                    <InputText @bind-Value="_input.NewEmail" id="newEmail"
                        class="w-full px-4 py-3 text-sm text-gray-900 dark:text-slate-100 bg-white dark:bg-[#1a1827] border border-gray-200 dark:border-[#3d3a5c] rounded-xl transition-all duration-200 placeholder:text-gray-400 dark:placeholder:text-slate-500 focus:outline-none focus:border-indigo-400 dark:focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 hover:border-gray-300 dark:hover:border-[#4d4a6a]"
                        placeholder="Enter new email address" />
                    <ValidationMessage For="() => _input.NewEmail" class="mt-1.5 text-xs text-red-600 dark:text-red-400" />
                </div>

                <p class="text-sm text-gray-500 dark:text-slate-400">
                    A confirmation link will be sent to your new email address. Click the link to confirm the change.
                </p>

                <div class="pt-2">
                    <button type="submit" disabled="@_isSaving"
                        class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 py-3 text-sm font-medium text-white rounded-xl transition-all duration-200 hover:shadow-lg active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed"
                        style="background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); box-shadow: 0 4px 14px rgba(99, 102, 241, 0.35);">
                        @if (_isSaving)
                        {
                            <div class="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>
                            <span>Sending...</span>
                        }
                        else
                        {
                            <span>Change Email</span>
                        }
                    </button>
                </div>
            </EditForm>
        </div>
    }
</div>

@code {
    private EmailDto? _emailDto;
    private InputModel _input = new();
    private bool _isLoading = true;
    private bool _isSaving;
    private bool _isSendingVerification;
    private string? _statusMessage;
    private bool _isError;

    protected override async Task OnInitializedAsync()
    {
        await LoadEmail();
    }

    private async Task LoadEmail()
    {
        try
        {
            _emailDto = await GetEmailCall.Call(new GetEmail());
        }
        catch (Exception ex)
        {
            _statusMessage = $"Error loading email: {ex.Message}";
            _isError = true;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SendVerificationEmail()
    {
        _isSendingVerification = true;
        _statusMessage = null;

        try
        {
            await SendVerificationEmailCall.Call(new SendVerificationEmail());
            _statusMessage = "Verification email sent. Please check your inbox.";
            _isError = false;
        }
        catch (Exception ex)
        {
            _statusMessage = $"Error: {ex.Message}";
            _isError = true;
        }
        finally
        {
            _isSendingVerification = false;
        }
    }

    private async Task OnSubmit()
    {
        _isSaving = true;
        _statusMessage = null;

        try
        {
            await ChangeEmailCall.Call(new ChangeEmail
            {
                NewEmail = _input.NewEmail
            });
            _statusMessage = "Confirmation link sent to your new email address. Please check your inbox.";
            _isError = false;
            _input = new();
        }
        catch (Exception ex)
        {
            _statusMessage = $"Error: {ex.Message}";
            _isError = true;
        }
        finally
        {
            _isSaving = false;
        }
    }

    private class InputModel
    {
        [Required]
        [EmailAddress]
        public string NewEmail { get; set; } = "";
    }
}
