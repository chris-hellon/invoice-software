@page "/account/manage"

@inject ICall<GetProfile, ProfileDto> GetProfileCall
@inject ICall<UpdateProfile> UpdateProfileCall

<PageTitle>Profile - InvoicePro</PageTitle>

<div class="space-y-6">
    <div>
        <h2 class="text-lg font-semibold text-gray-900 dark:text-slate-100">Profile</h2>
        <p class="mt-1 text-sm text-gray-500 dark:text-slate-400">Update your account profile information.</p>
    </div>

    @if (!string.IsNullOrEmpty(_statusMessage))
    {
        <div class="@(_isError ? "bg-red-50 dark:bg-red-900/30 border-red-200 dark:border-red-800 text-red-700 dark:text-red-300" : "bg-emerald-50 dark:bg-emerald-900/30 border-emerald-200 dark:border-emerald-800 text-emerald-700 dark:text-emerald-300") p-4 rounded-xl border text-sm">
            @_statusMessage
        </div>
    }

    @if (_isLoading)
    {
        <div class="flex justify-center py-12">
            <div class="w-8 h-8 border-2 border-gray-200 dark:border-slate-700 border-t-indigo-600 rounded-full animate-spin"></div>
        </div>
    }
    else if (_profile != null)
    {
        <EditForm Model="_input" OnValidSubmit="OnSubmit" class="space-y-5">
            <DataAnnotationsValidator />

            <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-2">Username</label>
                <input type="text" value="@_profile.Username" disabled
                    class="w-full px-4 py-3 text-sm text-gray-500 dark:text-slate-400 bg-gray-50 dark:bg-[#0f0e1a] border border-gray-200 dark:border-[#2d2a4a] rounded-xl cursor-not-allowed" />
                <p class="mt-1.5 text-xs text-gray-500 dark:text-slate-500">Your username cannot be changed.</p>
            </div>

            <div>
                <label for="phoneNumber" class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-2">Phone number</label>
                <InputText @bind-Value="_input.PhoneNumber" id="phoneNumber"
                    class="w-full px-4 py-3 text-sm text-gray-900 dark:text-slate-100 bg-white dark:bg-[#1a1827] border border-gray-200 dark:border-[#3d3a5c] rounded-xl transition-all duration-200 placeholder:text-gray-400 dark:placeholder:text-slate-500 focus:outline-none focus:border-indigo-400 dark:focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 hover:border-gray-300 dark:hover:border-[#4d4a6a]"
                    placeholder="Enter your phone number" />
                <ValidationMessage For="() => _input.PhoneNumber" class="mt-1.5 text-xs text-red-600 dark:text-red-400" />
            </div>

            <div class="pt-4">
                <button type="submit" disabled="@_isSaving"
                    class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 py-3 text-sm font-medium text-white rounded-xl transition-all duration-200 hover:shadow-lg active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed"
                    style="background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); box-shadow: 0 4px 14px rgba(99, 102, 241, 0.35);">
                    @if (_isSaving)
                    {
                        <div class="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>
                        <span>Saving...</span>
                    }
                    else
                    {
                        <span>Save Changes</span>
                    }
                </button>
            </div>
        </EditForm>
    }
</div>

@code {
    private ProfileDto? _profile;
    private InputModel _input = new();
    private bool _isLoading = true;
    private bool _isSaving;
    private string? _statusMessage;
    private bool _isError;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _profile = await GetProfileCall.Call(new GetProfile());
            _input.PhoneNumber = _profile?.PhoneNumber;
        }
        catch (Exception ex)
        {
            _statusMessage = $"Error loading profile: {ex.Message}";
            _isError = true;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnSubmit()
    {
        _isSaving = true;
        _statusMessage = null;

        try
        {
            await UpdateProfileCall.Call(new UpdateProfile { PhoneNumber = _input.PhoneNumber });
            _statusMessage = "Your profile has been updated.";
            _isError = false;
        }
        catch (Exception ex)
        {
            _statusMessage = $"Error: {ex.Message}";
            _isError = true;
        }
        finally
        {
            _isSaving = false;
        }
    }

    private class InputModel
    {
        [Phone]
        public string? PhoneNumber { get; set; }
    }
}
