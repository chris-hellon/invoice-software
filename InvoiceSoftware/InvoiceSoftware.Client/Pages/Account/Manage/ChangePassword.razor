@page "/account/manage/change-password"

@inject ICall<InvoiceSoftware.Shared.Api.Account.ChangePassword> ChangePasswordCall

<PageTitle>Change Password - InvoicePro</PageTitle>

<div class="space-y-6">
    <div>
        <h2 class="text-lg font-semibold text-gray-900 dark:text-slate-100">Change Password</h2>
        <p class="mt-1 text-sm text-gray-500 dark:text-slate-400">Update your account password.</p>
    </div>

    @if (!string.IsNullOrEmpty(_statusMessage))
    {
        <div class="@(_isError ? "bg-red-50 dark:bg-red-900/30 border-red-200 dark:border-red-800 text-red-700 dark:text-red-300" : "bg-emerald-50 dark:bg-emerald-900/30 border-emerald-200 dark:border-emerald-800 text-emerald-700 dark:text-emerald-300") p-4 rounded-xl border text-sm">
            @_statusMessage
        </div>
    }

    <EditForm Model="_input" OnValidSubmit="OnSubmit" class="space-y-5">
        <DataAnnotationsValidator />
        <ValidationSummary class="p-4 bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 rounded-xl text-sm text-red-700 dark:text-red-300" role="alert" />

        <div>
            <label for="currentPassword" class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-2">Current Password</label>
            <InputText type="password" @bind-Value="_input.CurrentPassword" id="currentPassword"
                class="w-full px-4 py-3 text-sm text-gray-900 dark:text-slate-100 bg-white dark:bg-[#1a1827] border border-gray-200 dark:border-[#3d3a5c] rounded-xl transition-all duration-200 placeholder:text-gray-400 dark:placeholder:text-slate-500 focus:outline-none focus:border-indigo-400 dark:focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 hover:border-gray-300 dark:hover:border-[#4d4a6a]"
                autocomplete="current-password" placeholder="Enter current password" />
            <ValidationMessage For="() => _input.CurrentPassword" class="mt-1.5 text-xs text-red-600 dark:text-red-400" />
        </div>

        <div>
            <label for="newPassword" class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-2">New Password</label>
            <InputText type="password" @bind-Value="_input.NewPassword" id="newPassword"
                class="w-full px-4 py-3 text-sm text-gray-900 dark:text-slate-100 bg-white dark:bg-[#1a1827] border border-gray-200 dark:border-[#3d3a5c] rounded-xl transition-all duration-200 placeholder:text-gray-400 dark:placeholder:text-slate-500 focus:outline-none focus:border-indigo-400 dark:focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 hover:border-gray-300 dark:hover:border-[#4d4a6a]"
                autocomplete="new-password" placeholder="Enter new password" />
            <ValidationMessage For="() => _input.NewPassword" class="mt-1.5 text-xs text-red-600 dark:text-red-400" />
        </div>

        <div>
            <label for="confirmPassword" class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-2">Confirm New Password</label>
            <InputText type="password" @bind-Value="_input.ConfirmPassword" id="confirmPassword"
                class="w-full px-4 py-3 text-sm text-gray-900 dark:text-slate-100 bg-white dark:bg-[#1a1827] border border-gray-200 dark:border-[#3d3a5c] rounded-xl transition-all duration-200 placeholder:text-gray-400 dark:placeholder:text-slate-500 focus:outline-none focus:border-indigo-400 dark:focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 hover:border-gray-300 dark:hover:border-[#4d4a6a]"
                autocomplete="new-password" placeholder="Confirm new password" />
            <ValidationMessage For="() => _input.ConfirmPassword" class="mt-1.5 text-xs text-red-600 dark:text-red-400" />
        </div>

        <div class="pt-4">
            <button type="submit" disabled="@_isSaving"
                class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 py-3 text-sm font-medium text-white rounded-xl transition-all duration-200 hover:shadow-lg active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed"
                style="background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); box-shadow: 0 4px 14px rgba(99, 102, 241, 0.35);">
                @if (_isSaving)
                {
                    <div class="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>
                    <span>Updating...</span>
                }
                else
                {
                    <span>Update Password</span>
                }
            </button>
        </div>
    </EditForm>
</div>

@code {
    private InputModel _input = new();
    private bool _isSaving;
    private string? _statusMessage;
    private bool _isError;

    private async Task OnSubmit()
    {
        _isSaving = true;
        _statusMessage = null;

        try
        {
            await ChangePasswordCall.Call(new InvoiceSoftware.Shared.Api.Account.ChangePassword
            {
                CurrentPassword = _input.CurrentPassword,
                NewPassword = _input.NewPassword
            });
            _statusMessage = "Your password has been changed.";
            _isError = false;
            _input = new(); // Clear the form
        }
        catch (Exception ex)
        {
            _statusMessage = $"Error: {ex.Message}";
            _isError = true;
        }
        finally
        {
            _isSaving = false;
        }
    }

    private class InputModel
    {
        [Required]
        [DataType(DataType.Password)]
        public string CurrentPassword { get; set; } = "";

        [Required]
        [StringLength(100, ErrorMessage = "The {0} must be at least {2} and at max {1} characters long.", MinimumLength = 6)]
        [DataType(DataType.Password)]
        public string NewPassword { get; set; } = "";

        [DataType(DataType.Password)]
        [Compare("NewPassword", ErrorMessage = "The new password and confirmation password do not match.")]
        public string ConfirmPassword { get; set; } = "";
    }
}
