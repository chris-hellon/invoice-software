@inherits LayoutComponentBase
@layout MainLayout

<div class="space-y-6">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-gray-900 dark:text-slate-100 tracking-tight" style="font-family: 'Plus Jakarta Sans', sans-serif;">Account Settings</h1>
            <p class="mt-1 text-sm text-gray-500 dark:text-slate-400">Manage your account settings and preferences.</p>
        </div>
    </div>

    <div class="flex flex-col lg:flex-row gap-6">
        <!-- Sidebar Navigation -->
        <aside class="lg:w-64 flex-shrink-0">
            <div class="bg-white dark:bg-[#1a1827] rounded-2xl border border-gray-100 dark:border-[#2d2a4a] p-4 sticky top-24">
                <ManageNavMenu />
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 min-w-0">
            <div class="bg-white dark:bg-[#1a1827] rounded-2xl border border-gray-100 dark:border-[#2d2a4a] p-6">
                @Body
            </div>
        </main>
    </div>
</div>
